    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .rm-biblio-list li {
    font-size: 0.8125rem;
    line-height: 1.5;
    opacity: 0.45;
  }
  .rm-biblio-list li strong {
    opacity: 1;
    font-weight: 600;
  }
  .rm-biblio-list li em {
    font-style: italic;
  }
  .rm-phase-refs {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .rm-phase-refs p {
    font-size: 0.8125rem;
