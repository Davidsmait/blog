  }
  .tl-lessons.hidden {
    max-height: 0 !important;
    opacity: 0;
    margin-top: 0;
  }
  .tl-lessons:not(.hidden) {
    opacity: 1;
  }

  .tl-lesson {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem;
    margin: 0 -0.5rem;
    font-size: 0.8125rem;
    text-decoration: none;
    color: inherit;
    border-radius: 0.375rem;
    transition: background 0.12s ease;
  }
  a.tl-lesson:hover {
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  /* Lesson status icons */
  .tl-lesson-status-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }
  .tl-lesson-icon-check {
    width: 0.75rem;
    height: 0.75rem;
    color: color-mix(in srgb, #22c55e 55%, transparent);
  }
  .tl-lesson-icon-unread {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
  /* Read lesson */
  .tl-lesson-available.is-read .tl-lesson-icon-check {
    display: block !important;
  }
  .tl-lesson-available.is-read .tl-lesson-icon-unread {
    display: none;
  }
  .tl-lesson-available.is-read span:last-child {
    opacity: 0.55;
  }
  /* Unread lesson */
  .tl-lesson-available:not(.is-read) span:last-child {
    opacity: 0.75;
  }
  .tl-lesson-available {
    transition:
      background 0.12s ease,
      opacity 0.12s ease;
  }
  a.tl-lesson-available:hover span:last-child {
    opacity: 1;
    color: var(--color-accent);
  }
  a.tl-lesson-available:hover .tl-lesson-icon-check {
    color: var(--color-accent);
  }
  a.tl-lesson-available:hover .tl-lesson-icon-unread {
    background: var(--color-accent);
  }

  /* User progress bar */
  .rm-user-progress {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 0.375rem;
    max-width: 16rem;
  }
  .rm-user-progress-fill {
    height: 100%;
    border-radius: 9999px;
    background: color-mix(in srgb, #22c55e 50%, transparent);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .rm-user-progress-label {
    font-size: 0.625rem;
    opacity: 0.25;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.5rem;
  }

  .tl-lesson-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    flex-shrink: 0;
