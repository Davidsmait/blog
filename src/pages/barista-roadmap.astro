  /* User-complete: hidden by default, shown when user reads all lessons in phase */
  .tl-node-user-check {
    display: none;
  }
  .tl-phase.user-phase-complete .tl-node-user-check {
    display: block;
  }
  .tl-phase.user-phase-complete .tl-node-default {
