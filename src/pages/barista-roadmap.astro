<script>
  // ── Cookie helpers ──
  const COOKIE_NAME = 'roadmap_read'
  const COOKIE_DAYS = 365

  function getReadLessons(): Set<string> {
    const match = document.cookie.match(
      new RegExp('(?:^|; )' + COOKIE_NAME + '=([^;]*)')
    )
    if (!match) return new Set()
    try {
      return new Set(JSON.parse(decodeURIComponent(match[1])))
    } catch {
      return new Set()
    }
  }

  function saveReadLessons(slugs: Set<string>) {
    const expires = new Date(Date.now() + COOKIE_DAYS * 864e5).toUTCString()
    const value = encodeURIComponent(JSON.stringify([...slugs]))
    document.cookie = `${COOKIE_NAME}=${value}; expires=${expires}; path=/; SameSite=Lax`
  }

  function markLessonRead(slug: string) {
    const read = getReadLessons()
    if (!read.has(slug)) {
      read.add(slug)
      saveReadLessons(read)
    }
  }

  // ── UI update ──
  function updateProgressUI() {
    const read = getReadLessons()
    const allLessons =
      document.querySelectorAll<HTMLElement>('[data-lesson-slug]')
    let totalAvailable = 0
    let totalRead = 0

    allLessons.forEach((el) => {
      const slug = el.dataset.lessonSlug!
      totalAvailable++
      if (read.has(slug)) {
        el.classList.add('is-read')
        totalRead++
      } else {
        el.classList.remove('is-read')
      }
    })

    // Update user progress bar
    const userProgressEl = document.querySelector(
      '[data-user-progress]'
    ) as HTMLElement | null
    const userFill = document.querySelector(
      '[data-user-progress-fill]'
    ) as HTMLElement | null
    const userText = document.querySelector(
      '[data-user-progress-text]'
    ) as HTMLElement | null

    if (userProgressEl && userFill && userText && totalAvailable > 0) {
      userProgressEl.style.display = 'block'
      const pct = Math.round((totalRead / totalAvailable) * 100)
      userFill.style.width = pct + '%'
      userText.textContent = `${totalRead}/${totalAvailable} leídas`
    }

    // Update phase counters based on user reads
    document
      .querySelectorAll<HTMLElement>('[data-phase]')
      .forEach((phaseEl) => {
        const lessons =
          phaseEl.querySelectorAll<HTMLElement>('[data-lesson-slug]')
        const readInPhase = [...lessons].filter((l) =>
          read.has(l.dataset.lessonSlug!)
        ).length
        const counterEl = phaseEl.querySelector('.rm-phase-counter')
        if (counterEl && lessons.length > 0) {
          const total =
            counterEl.textContent?.split('/')[1] ?? String(lessons.length)
          counterEl.textContent = `${readInPhase}/${total}`
        }

        if (lessons.length > 0 && readInPhase === lessons.length) {
          phaseEl.classList.add('user-phase-complete')
        } else {
          phaseEl.classList.remove('user-phase-complete')
        }
      })
  }

  function attachLessonTracking() {
    document
      .querySelectorAll<HTMLElement>('[data-lesson-slug]')
      .forEach((el) => {
        if (el.hasAttribute('data-tracking-init')) return
        el.setAttribute('data-tracking-init', '')
        el.addEventListener('click', () => {
          markLessonRead(el.dataset.lessonSlug!)
        })
      })
  }

  // ── Expand/collapse ──
  function initRoadmap() {
    document.querySelectorAll('[data-phase-toggle]').forEach((btn) => {
      if (btn.hasAttribute('data-toggle-init')) return
      btn.setAttribute('data-toggle-init', '')
      btn.addEventListener('click', () => {
        const phase = btn.closest('[data-phase]')
        const panel = phase?.querySelector(
          '[data-lessons-panel]'
        ) as HTMLElement | null
        const chevron = btn.querySelector(
          '[data-chevron]'
        ) as HTMLElement | null
        if (!panel) return

        const isOpen = btn.getAttribute('aria-expanded') === 'true'

        if (isOpen) {
          panel.style.maxHeight = panel.scrollHeight + 'px'
          requestAnimationFrame(() => {
            panel.classList.add('hidden')
            panel.style.maxHeight = '0'
          })
        } else {
          panel.classList.remove('hidden')
          panel.style.maxHeight = panel.scrollHeight + 'px'
          const onEnd = () => {
            panel.style.maxHeight = ''
            panel.removeEventListener('transitionend', onEnd)
          }
          panel.addEventListener('transitionend', onEnd)
        }

        btn.setAttribute('aria-expanded', String(!isOpen))

        if (chevron) {
          chevron.style.transform = isOpen ? '' : 'rotate(90deg)'
        }
      })
    })

    // Auto-open active phase
    const active = document.querySelector(
      '[data-state="active"] [data-phase-toggle]'
    ) as HTMLElement | null
    const firstComplete = document.querySelector(
      '[data-state="complete"] [data-phase-toggle]'
    ) as HTMLElement | null
    if (active) active.click()
    else if (firstComplete) firstComplete.click()

    // Animate progress bar on load
    const fill = document.querySelector(
      '.rm-progress-fill'
    ) as HTMLElement | null
    if (fill) {
      const target = fill.style.width
      fill.style.width = '0%'
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          fill.style.width = target
        })
      })
    }

    updateProgressUI()
    attachLessonTracking()
    updateBonusContent()
  }

  // ── Bonus content unlock ──
  function updateBonusContent() {
    const read = getReadLessons()

    document
      .querySelectorAll<HTMLElement>('[data-bonus-link]')
      .forEach((link) => {
        const requiredPhase = parseInt(link.dataset.requiresPhase || '0')
        const phaseEl = document.querySelector(
          `[data-phase="${requiredPhase}"]`
        )
        if (!phaseEl) return

        const phaseLessons =
          phaseEl.querySelectorAll<HTMLElement>('[data-lesson-slug]')
        const allRead =
          phaseLessons.length > 0 &&
          [...phaseLessons].every((l) => read.has(l.dataset.lessonSlug!))

        if (allRead) {
          link.classList.remove('rm-bonus-locked')
          link.classList.add('rm-bonus-unlocked')
          const lockIcon = link.querySelector(
            '.rm-bonus-lock-icon'
          ) as HTMLElement
          const starIcon = link.querySelector(
            '.rm-bonus-star-icon'
          ) as HTMLElement
          if (lockIcon) lockIcon.style.display = 'none'
          if (starIcon) starIcon.style.display = 'block'
        } else {
          link.classList.add('rm-bonus-locked')
          link.classList.remove('rm-bonus-unlocked')
          const lockIcon = link.querySelector(
            '.rm-bonus-lock-icon'
          ) as HTMLElement
          const starIcon = link.querySelector(
            '.rm-bonus-star-icon'
          ) as HTMLElement
          if (lockIcon) lockIcon.style.display = 'block'
          if (starIcon) starIcon.style.display = 'none'
        }
      })
  }

  initRoadmap()
  document.addEventListener('astro:after-swap', initRoadmap)
</script>
