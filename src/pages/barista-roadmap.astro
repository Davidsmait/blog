---
import PageLayout from '@/layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

const allCafePosts = await getCollection('cafe')
const roadmapLessons = allCafePosts
  .filter((post) => post.data.phase !== undefined && !post.data.draft)
  .sort((a, b) => {
    const phaseA = a.data.phase ?? 0
    const phaseB = b.data.phase ?? 0
    if (phaseA !== phaseB) return phaseA - phaseB
    return (a.data.lessonOrder ?? 0) - (b.data.lessonOrder ?? 0)
  })

const lessonsByPhase: Record<number, typeof roadmapLessons> = {}
for (const lesson of roadmapLessons) {
  const phase = lesson.data.phase!
  if (!lessonsByPhase[phase]) lessonsByPhase[phase] = []
  lessonsByPhase[phase].push(lesson)
}

const phases = [
  {
    num: 1,
    title: 'Fundamentos del café',
    desc: 'Qué es el café de especialidad, variedades, procesamiento, extracción y agua.',
    totalLessons: 4
  },
  {
    num: 2,
    title: 'Espresso',
    desc: 'Anatomía del shot, dial-in, presión, temperatura, diagnóstico y mantenimiento.',
    totalLessons: 5,
    eta: 'Semana del 21 de abril'
  }
]

const plannedLessons: Record<number, string[]> = {}

// Phases that are not ready for public launch yet — force locked state
const lockedPhases = new Set<number>([])

const totalLessons = phases
  .filter((p) => !lockedPhases.has(p.num))
  .reduce((acc, p) => acc + p.totalLessons, 0)
const completedLessons = roadmapLessons.filter(
  (l) => !lockedPhases.has(l.data.phase)
).length
const progressPercent = Math.round((completedLessons / totalLessons) * 100)

function getPhaseState(phaseNum: number) {
  if (lockedPhases.has(phaseNum)) return 'locked'
  const lessons = lessonsByPhase[phaseNum] ?? []
  const total = phases.find((p) => p.num === phaseNum)!.totalLessons
  if (lessons.length >= total) return 'complete'
  if (lessons.length > 0) return 'active'
  if (lessons.length === 0 && phaseNum !== 1) return 'locked'
  const prevLessons = lessonsByPhase[phaseNum - 1] ?? []
  const prevTotal =
    phases.find((p) => p.num === phaseNum - 1)?.totalLessons ?? 0
  if (phaseNum === 1 || prevLessons.length >= prevTotal) return 'next'
  return 'locked'
}
---

<PageLayout
  frontmatter={{
    title: 'Roadmap Barista de Especialidad',
    description: `${totalLessons} lecciones en ${phases.length} fases publicadas (9 fases planeadas). Fundamentos del café y espresso. Aprende barismo de especialidad con Scott Rao, Gagné y la SCA.`,
    activeHeaderLink: 'Café'
  }}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Course',
      name: 'Roadmap Barista de Especialidad',
      description: `${totalLessons} lecciones en ${phases.length} fases publicadas (9 fases planeadas). Fundamentos del café y espresso.`,
      url: 'https://davidsanluisaguirre.com/barista-roadmap',
      inLanguage: 'es',
      numberOfCredits: totalLessons,
      educationalLevel: 'Beginner to Expert',
      provider: { '@id': 'https://davidsanluisaguirre.com/#person' },
      isPartOf: { '@id': 'https://davidsanluisaguirre.com/#website' },
      hasCourseInstance: phases.map((p) => ({
        '@type': 'CourseInstance',
        name: `Fase ${p.num}: ${p.title}`,
        description: p.desc,
        courseMode: 'online'
      })),
      about: [
        { '@type': 'Thing', name: 'Café de especialidad' },
        { '@type': 'Thing', name: 'Barista' },
        { '@type': 'Thing', name: 'Espresso' },
        { '@type': 'Thing', name: 'Latte art' },
        { '@type': 'Thing', name: 'SCA' }
      ]
    })}
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Qué es el Roadmap Barista de Especialidad?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `Un currículum gratuito con ${phases.length} fases publicadas (9 planeadas) y ${totalLessons} lecciones, creado por David San Luis Aguirre. Cubre fundamentos del café y espresso, basado en metodologías de Scott Rao, la SCA y Jonathan Gagné.`
          }
        },
        {
          '@type': 'Question',
          name: '¿Es gratis el roadmap de barista?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí, todas las lecciones son completamente gratuitas. El roadmap está disponible en español e inglés.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Qué temas cubre el roadmap de café de especialidad?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'El roadmap cubre fundamentos del café, espresso, métodos de filtrado, catación y paladar, leche y latte art, tueste y negocio, metodología Rao avanzada, física de la extracción y carrera profesional como barista.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Necesito experiencia previa para empezar?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. La Fase 1 comienza desde cero con los fundamentos del café. El roadmap avanza progresivamente hasta temas profesionales avanzados.'
          }
        }
      ]
    })}
  />
  <!-- ── Editorial Header ── -->
  <div class="reveal mb-10 sm:mb-16">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4 sm:gap-6">
        <span class="font-serif text-[13px] italic opacity-20">(03)</span>
        <h1
          class="m-0 font-serif text-[clamp(2.5rem,6vw,4rem)] italic leading-[1] tracking-tight text-accent"
        >
          Café
        </h1>
      </div>
      <a
        href="/en/barista-roadmap"
        class="rm-lang-pill"
        aria-label="Switch to English"
        data-astro-reload>EN</a
      >
    </div>
    <div class="hr-animated mt-3"></div>
  </div>

  <!-- ── Subtitle + Progress ── -->
  <div class="reveal reveal-delay-1 mb-12 sm:mb-16">
    <div
      class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <p
          class="m-0 font-display text-[clamp(1.1rem,2.5vw,1.4rem)] font-semibold leading-[1.3] tracking-tighter-brand text-accent sm:max-w-md"
        >
          Barista de Especialidad
        </p>
        <p class="mt-2 text-sm leading-relaxed opacity-50 sm:max-w-sm">
          {totalLessons} lecciones de cero a profesional. Desde los fundamentos del
          grano hasta la física de la extracción.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <div class="rm-progress-bar">
          <div
            class="rm-progress-fill"
            role="progressbar"
            aria-valuenow={completedLessons}
            aria-valuemin={0}
            aria-valuemax={totalLessons}
            style={`width: ${progressPercent}%`}
          >
          </div>
        </div>
        <span class="text-xs font-medium tabular-nums opacity-40"
          >{completedLessons}/{totalLessons}</span
        >
      </div>
    </div>
    <!-- User progress (shown via JS) -->
    <div class="rm-user-progress mt-2" data-user-progress style="display:none">
      <div class="flex items-center gap-3">
        <div class="rm-progress-bar rm-progress-bar--user">
          <div
            class="rm-progress-fill rm-progress-fill--user"
            data-user-progress-fill
          >
          </div>
        </div>
        <span
          class="text-xs font-medium tabular-nums opacity-40"
          data-user-progress-text></span>
      </div>
    </div>
  </div>

  <!-- ── Intro — Editorial prose ── -->
  <div class="reveal reveal-delay-2 mb-14 sm:mb-20">
    <div class="sm:ml-12">
      <p class="text-sm leading-[1.8] opacity-55 sm:max-w-lg">
        No soy barista profesional — soy un developer que armó este roadmap a
        partir de la SCA, Scott Rao y Gagné. Lo valido, lo practico, y cuando
        estoy seguro de que tiene sentido, lo publico.
        <strong class="font-semibold text-accent opacity-100"
          ><a href="/projects" class="text-accent no-underline opacity-100"
            >La Commune</a
          ></strong
        > es el brazo tecnológico — POS, fidelidad y menú digital para cafeterías
        de especialidad.
      </p>
      <a
        href="/cafe/2025-03-05-mi-camino-barista-especialidad"
        class="mt-4 inline-flex items-center gap-2 text-[13px] font-medium uppercase tracking-[0.12em] text-accent no-underline opacity-50 transition-opacity duration-500 hover:opacity-85"
      >
        Leer la historia completa
        <span
          class="text-[10px] transition-transform duration-300 group-hover:translate-x-1"
          >&nearr;</span
        >
      </a>
    </div>
  </div>

  <!-- ── Timeline — Editorial Phases ── -->
  <div class="rm-timeline stagger-children">
    {
      phases.map((phase, idx) => {
        const state = getPhaseState(phase.num)
        const isComplete = state === 'complete'
        const isActive = state === 'active'
        const isLocked = state === 'locked'
        // Hide lessons for force-locked phases
        const lessons = isLocked ? [] : (lessonsByPhase[phase.num] ?? [])
        const planned = isLocked ? [] : (plannedLessons[phase.num] ?? [])
        const hasContent = lessons.length > 0 || planned.length > 0
        const isLast = idx === phases.length - 1

        return (
          <div
            class={`rm-phase rm-phase--${state}`}
            data-phase={phase.num}
            data-state={state}
          >
            {/* ── Left: Phase number + vertical line ── */}
            <div class="rm-phase-track">
              <span class="rm-phase-node" data-phase-node>
                {/* User-complete check (hidden by default) */}
                <svg
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="rm-node-icon rm-node-check rm-node-user-check"
                >
                  <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                </svg>
                <span class="rm-node-default">
                  {isComplete ? (
                    <span class="rm-node-complete-dot" />
                  ) : isActive ? (
                    <span class="rm-node-pulse">
                      <span class="rm-pulse-ring" />
                      <span class="rm-pulse-dot" />
                    </span>
                  ) : isLocked ? (
                    <svg
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      class="rm-node-icon rm-node-lock"
                    >
                      <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                    </svg>
                  ) : (
                    <span class="rm-node-empty" />
                  )}
                </span>
              </span>
              {!isLast && (
                <span
                  class={`rm-phase-line ${isComplete ? 'rm-phase-line--done' : ''}`}
                  data-phase-line
                />
              )}
            </div>

            {/* ── Right: Content ── */}
            <div class="rm-phase-content">
              <button
                type="button"
                data-phase-toggle
                class="rm-phase-header"
                aria-expanded="false"
                aria-label={`Fase ${phase.num}: ${phase.title}`}
              >
                <div class="rm-phase-info">
                  <div class="flex items-center gap-3">
                    <span class="font-serif text-[13px] italic opacity-20">
                      ({String(phase.num).padStart(2, '0')})
                    </span>
                    <span class="rm-phase-title">{phase.title}</span>
                  </div>
                  <span class="rm-phase-desc">{phase.desc}</span>
                  {isLocked && phase.eta && (
                    <span class="rm-phase-eta">{phase.eta}</span>
                  )}
                </div>
                <span class="rm-phase-meta">
                  <span class="rm-phase-counter">
                    {lessons.length}/{phase.totalLessons}
                  </span>
                  {hasContent && (
                    <svg
                      class="rm-phase-chevron"
                      data-chevron
                      viewBox="0 0 16 16"
                      fill="currentColor"
                    >
                      <path d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z" />
                    </svg>
                  )}
                </span>
              </button>

              {/* ── Expandable lesson list ── */}
              {hasContent && (
                <div class="rm-lessons hidden" data-lessons-panel>
                  {lessons.map((lesson, li) => (
                    <a
                      href={`/cafe/${lesson.slug}`}
                      class="rm-lesson rm-lesson--available"
                      data-lesson-slug={lesson.slug}
                    >
                      <span class="rm-lesson-status">
                        <svg
                          viewBox="0 0 16 16"
                          fill="currentColor"
                          class="rm-lesson-check"
                          style="display:none"
                        >
                          <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                        </svg>
                        <span class="rm-lesson-dot" />
                      </span>
                      <span class="rm-lesson-title">{lesson.data.title}</span>
                      <span class="rm-lesson-arrow">&nearr;</span>
                    </a>
                  ))}
                  {planned.slice(lessons.length).map((title) => (
                    <div class="rm-lesson rm-lesson--pending">
                      <span class="rm-lesson-status">
                        <span class="rm-lesson-dot rm-lesson-dot--pending" />
                      </span>
                      <span class="rm-lesson-title">{title}</span>
                    </div>
                  ))}

                  {/* ── Bonus content after phase lessons ── */}
                  {phase.num === 1 && (
                    <div class="rm-bonus" data-bonus-phase="1">
                      <div class="rm-bonus-divider">
                        <span class="rm-bonus-divider-line" />
                        <span class="rm-bonus-divider-label">Bonus</span>
                        <span class="rm-bonus-divider-line" />
                      </div>
                      <a
                        href="/cafe/guia-herramientas-agua"
                        class="rm-lesson rm-lesson--bonus rm-bonus-locked"
                        data-bonus-link
                        data-requires-phase="1"
                      >
                        <span class="rm-lesson-status">
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-lock-icon"
                          >
                            <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                          </svg>
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-star-icon"
                            style="display:none"
                          >
                            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                          </svg>
                        </span>
                        <span class="rm-lesson-title">
                          <span class="rm-bonus-title-text">
                            Guía: Herramientas para medir tu agua
                          </span>
                          <span class="rm-bonus-unlock-hint" data-bonus-hint>
                            Completa las 4 lecciones para desbloquear
                          </span>
                        </span>
                        <span class="rm-lesson-arrow">&nearr;</span>
                      </a>
                      <a
                        href="/cafe/calculadora-gotas"
                        class="rm-lesson rm-lesson--bonus rm-bonus-locked"
                        data-bonus-link
                        data-requires-phase="1"
                      >
                        <span class="rm-lesson-status">
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-lock-icon"
                          >
                            <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                          </svg>
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-star-icon"
                            style="display:none"
                          >
                            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                          </svg>
                        </span>
                        <span class="rm-lesson-title">
                          <span class="rm-bonus-title-text">
                            Calculadora de Gotas — GH & KH
                          </span>
                          <span class="rm-bonus-unlock-hint" data-bonus-hint>
                            Completa las 4 lecciones para desbloquear
                          </span>
                        </span>
                        <span class="rm-lesson-arrow">&nearr;</span>
                      </a>
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>
        )
      })
    }
  </div>

  <!-- ── Teaser: Upcoming phases ── -->
  <div class="reveal mt-12 sm:mt-16">
    <div class="rm-teaser">
      <div class="rm-teaser-line"></div>
      <div class="rm-teaser-content">
        <span class="rm-teaser-label">En desarrollo</span>
        <p class="rm-teaser-text">
          7 fases más en camino — métodos de filtrado, catación, latte art,
          tueste, metodología Rao y más.
        </p>
      </div>
    </div>
  </div>

  <!-- ── Bibliography ── -->
  <div class="reveal mt-16 sm:mt-24">
    <div class="hr-animated mb-8"></div>
    <details class="rm-biblio-details">
      <summary class="rm-biblio-toggle">Bibliografía y fuentes</summary>
      <div class="rm-biblio">
        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Libros principales</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>James Hoffmann</strong> — <em
                >The World Atlas of Coffee</em
              >, 2a ed. (2018). Fundamento para las fases 1, 3 y 4: orígenes,
              métodos de filtrado, variedades y la técnica de French press.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >The Professional Barista's Handbook</em
              > (2008). Base de las fases 2 y 3: ciencia de extracción, espresso,
              dial-in, diagnóstico de shots y principios de pour-over.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >The Coffee Roaster's Companion</em
              > (2014). Base de la fase 6: curvas de tueste, RoR, DTR, perfiles por
              origen y defectos de tueste.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >Espresso Extraction: Measurement and Mastery</em
              > (2013). Base de la fase 7: refractómetro, TDS, pressure profiling,
              turbo shots y ratios extendidos.
            </li>
            <li>
              <strong>David Schomer</strong> — <em
                >Espresso Coffee: Professional Techniques</em
              >, 4a ed. (2010). Referencia para la fase 2: presión, temperatura,
              estabilidad térmica, pre-infusión y mantenimiento.
            </li>
            <li>
              <strong>Dhan Tamang</strong> — <em
                >Coffee Art: Creative Coffee Designs for the Home Barista</em
              > (2017). Base de la fase 5: patrones básicos y avanzados de latte art,
              técnica de vertido y etching.
            </li>
            <li>
              <strong>Jonathan Gagné</strong> — <em
                >The Physics of Filter Coffee</em
              > (2021). Base de la fase 8: ley de Darcy, percolación, distribución
              de partículas, geometría de drippers y migración de finos.
            </li>
            <li>
              <strong>Jonathan Gagné</strong> — <em>The Physics of Espresso</em> (2023).
              Base de la fase 8: dinámica del puck, pressure/flow profiling, ciencia
              de la extracción bajo presión.
            </li>
            <li>
              <strong>Britta Folmer (ed.)</strong> — <em
                >The Craft and Science of Coffee</em
              > (2017, Elsevier). Referencia académica: química del tueste a nivel
              molecular, descafeinado, crema, sostenibilidad.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em>Everything But Espresso</em> (2010).
              Métodos de filtrado con rigor técnico: percolación, inmersión, bypass
              y variables de control.
            </li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">
            Publicaciones SCA y World Coffee Research
          </h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>SCA</strong> — <em>Coffee Sensory & Cupping Handbook</em>.
              Protocolo de catación, formulario de evaluación y estándares de
              puntaje (fase 4).
            </li>
            <li>
              <strong>SCA</strong> — <em>Water Quality Handbook</em>. Estándares
              de agua para preparación: TDS, pH, dureza y composición mineral
              (fase 1).
            </li>
            <li>
              <strong>SCA &amp; WCR</strong> — <em
                >Coffee Taster's Flavor Wheel</em
              > (2016). Rueda de sabores, descriptores y familias sensoriales (fase
              4).
            </li>
            <li>
              <strong>SCA</strong> — <em>Coffee Skills Program</em>. Estructura
              modular Foundation → Intermediate → Professional como referencia
              del roadmap.
            </li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Libros complementarios</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>Maxwell Colonna-Dashwood</strong> — <em
                >Water for Coffee</em
              > (2015). Química del agua, mineralización y su impacto en la extracción
              (fase 1).
            </li>
            <li>
              <strong>Rob Hoos</strong> — <em
                >Modulating the Flavor Profile of Coffee</em
              > (2015). Relación entre decisiones de tueste y perfil de sabor (fase
              6).
            </li>
            <li>
              <strong>Christopher H. Hendon et al.</strong> — <em
                >Water for Coffee</em
              > (2015). Investigación científica sobre el rol del agua en la extracción.
            </li>
            <li>
              <strong>Andrea Illy &amp; Rinantonio Viani</strong> — <em
                >Espresso Coffee: The Science of Quality</em
              >, 2a ed. (2005). Fundamentos científicos del espresso (fase 2).
            </li>
            <li>
              <strong>Morten Münchow et al.</strong> — Investigaciones sobre extracción,
              TDS y rendimiento publicadas en <em>Journal of Food Science</em>.
            </li>
          </ul>
