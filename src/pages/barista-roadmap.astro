---
import PageLayout from '@/layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

const allCafePosts = await getCollection('cafe')
const roadmapLessons = allCafePosts
  .filter((post) => post.data.phase !== undefined && !post.data.draft)
  .sort((a, b) => {
    const phaseA = a.data.phase ?? 0
    const phaseB = b.data.phase ?? 0
    if (phaseA !== phaseB) return phaseA - phaseB
    return (a.data.lessonOrder ?? 0) - (b.data.lessonOrder ?? 0)
  })

const lessonsByPhase: Record<number, typeof roadmapLessons> = {}
for (const lesson of roadmapLessons) {
  const phase = lesson.data.phase!
  if (!lessonsByPhase[phase]) lessonsByPhase[phase] = []
  lessonsByPhase[phase].push(lesson)
}

const phases = [
  {
    num: 1,
    title: 'Fundamentos del café',
    desc: 'Qué es el café de especialidad, variedades, procesamiento, extracción y agua.',
    totalLessons: 4
  },
  {
    num: 2,
    title: 'Espresso',
    desc: 'Anatomía del shot, dial-in, presión, temperatura, diagnóstico y mantenimiento.',
    totalLessons: 5
  },
  {
    num: 3,
    title: 'Métodos de filtrado',
    desc: 'Pour-over, Chemex, V60, Aeropress, French press, Clever y cold brew.',
    totalLessons: 5
  },
  {
    num: 4,
    title: 'Paladar y catación',
    desc: 'Fisiología del gusto, protocolo SCA, rueda de sabores y entrenamiento sensorial.',
    totalLessons: 4
  },
  {
    num: 5,
    title: 'Leche y latte art',
    desc: 'Ciencia de la leche, vaporizado, corazón, rosetta, tulipán y etching.',
    totalLessons: 4
  },
  {
    num: 6,
    title: 'Tueste y negocio',
    desc: 'Reacciones químicas, curvas de tueste, cadena de suministro y abrir tu cafetería.',
    totalLessons: 4
  },
  {
    num: 7,
    title: 'Profesional — Metodología Rao',
    desc: 'Grooming avanzado, pressure profiling, refractómetro, TDS, Rao Spin y turbo shots.',
    totalLessons: 4
  },
  {
    num: 8,
    title: 'Física de la extracción',
    desc: 'Distribución de partículas, ley de Darcy, geometría de drippers, dinámica del puck y flow profiling.',
    totalLessons: 4
  },
  {
    num: 9,
    title: 'Carrera profesional',
    desc: 'Gestión de cafetería, barismo competitivo, certificación Q Grader y marca personal.',
    totalLessons: 4
  }
]

const plannedLessons: Record<number, string[]> = {}

const totalLessons = phases.reduce((acc, p) => acc + p.totalLessons, 0)
const completedLessons = roadmapLessons.length
const progressPercent = Math.round((completedLessons / totalLessons) * 100)

function getPhaseState(phaseNum: number) {
  const lessons = lessonsByPhase[phaseNum] ?? []
  const total = phases.find((p) => p.num === phaseNum)!.totalLessons
  if (lessons.length >= total) return 'complete'
  if (lessons.length > 0) return 'active'
  if (lessons.length === 0 && phaseNum !== 1) return 'locked'
  const prevLessons = lessonsByPhase[phaseNum - 1] ?? []
  const prevTotal =
    phases.find((p) => p.num === phaseNum - 1)?.totalLessons ?? 0
  if (phaseNum === 1 || prevLessons.length >= prevTotal) return 'next'
  return 'locked'
}
---

<PageLayout
  frontmatter={{
    title: 'Roadmap Barista de Especialidad',
    description: `${totalLessons} lecciones en ${phases.length} fases: desde los fundamentos del café hasta la física de la extracción. Aprende a ser barista profesional con conocimiento de Scott Rao, Jonathan Gagné y la SCA.`,
    activeHeaderLink: 'Cafe'
  }}
>
  <!-- Header -->
  <div class="rm-header">
    <div class="rm-top-row">
      <span class="rm-label">Roadmap</span>
      <a
        href="/en/barista-roadmap"
        class="rm-lang-switch"
        aria-label="Switch to English"
        data-astro-reload>EN</a
      >
    </div>
    <h1 class="rm-title">Barista de Especialidad</h1>
    <p class="rm-desc">
      {totalLessons} lecciones de cero a profesional.
    </p>
    <div class="rm-progress">
      <div
        class="rm-progress-track"
        role="progressbar"
        aria-valuenow={completedLessons}
        aria-valuemin={0}
        aria-valuemax={totalLessons}
      >
        <div class="rm-progress-fill" style={`width: ${progressPercent}%`}>
        </div>
      </div>
      <span class="rm-progress-text">{completedLessons}/{totalLessons}</span>
    </div>
    <div class="rm-user-progress" data-user-progress style="display:none">
      <div
        class="rm-progress-track"
        role="progressbar"
        aria-label="Tu progreso de lectura"
      >
        <div class="rm-user-progress-fill" data-user-progress-fill></div>
      </div>
      <span class="rm-progress-text" data-user-progress-text></span>
    </div>
  </div>

  <!-- Intro -->
  <div class="rm-intro">
    <p class="rm-intro-text">
      No soy barista profesional — soy un developer que se toma el café muy en serio.
      Este roadmap lo armé a partir de libros de especialidad y el programa de la SCA.
      El contenido lo construyo con la ayuda de Claude, yo lo valido, lo estudio, lo practico,
      y cuando estoy seguro de que tiene sentido, lo publico.
    </p>
    <p class="rm-intro-text">
      El objetivo es abrir <strong>La Commune</strong>, mi propia cafetería de especialidad.
      Mientras ahorro para eso, estoy construyendo las herramientas
      (<a href="/projects">POS</a>, app de fidelidad, menú digital) y aprendiendo todo lo que puedo.
    </p>
    <a href="/cafe/2025-03-05-mi-camino-barista-especialidad" class="rm-intro-link">
      Leer la historia completa
      <span class="iconify tabler--arrow-right" aria-hidden="true"></span>
    </a>
  </div>

  <!-- Timeline -->
  <div class="timeline">
    {
      phases.map((phase, idx) => {
        const lessons = lessonsByPhase[phase.num] ?? []
        const state = getPhaseState(phase.num)
        const isComplete = state === 'complete'
        const isActive = state === 'active'
        const isLocked = state === 'locked'
        const planned = plannedLessons[phase.num] ?? []
        const hasContent = lessons.length > 0 || planned.length > 0
        const isLast = idx === phases.length - 1

        return (
          <div
            class={`tl-phase tl-${state}`}
            data-phase={phase.num}
            data-state={state}
          >
            {/* Node + connector line */}
            <div class="tl-track">
              <span class="tl-node" data-phase-node>
                {/* User-complete check (hidden by default, shown via JS) */}
                <svg
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="tl-node-icon tl-node-check tl-node-user-check"
                >
                  <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                </svg>
                {/* Server-rendered state icons */}
                <span class="tl-node-default">
                  {isComplete ? (
                    <svg
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      class="tl-node-icon tl-node-check"
                    >
                      <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                    </svg>
                  ) : isActive ? (
                    <span class="tl-node-pulse">
                      <span class="tl-pulse-ring" />
                      <span class="tl-pulse-dot" />
                    </span>
                  ) : isLocked ? (
                    <svg
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      class="tl-node-icon tl-node-lock"
                    >
                      <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                    </svg>
                  ) : (
                    <span class="tl-node-empty" />
                  )}
                </span>
              </span>
              {!isLast && (
                <span
                  class={`tl-line ${isComplete ? 'tl-line-done' : ''}`}
                  data-phase-line
                />
              )}
            </div>

            {/* Content */}
            <div class="tl-content">
              <button
                type="button"
                data-phase-toggle
                class="tl-header"
                aria-expanded="false"
                aria-label={`Fase ${phase.num}: ${phase.title}`}
              >
                <div class="tl-title-group">
                  <span class="tl-title">{phase.title}</span>
                  <span class="tl-desc">{phase.desc}</span>
                </div>
                <span class="tl-meta">
                  <span class="tl-counter">
                    {lessons.length}/{phase.totalLessons}
                  </span>
                  {hasContent && (
                    <svg
                      class="tl-chevron"
                      data-chevron
                      viewBox="0 0 16 16"
                      fill="currentColor"
                    >
                      <path d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z" />
                    </svg>
                  )}
                </span>
              </button>

              {/* Expandable lesson list */}
              {hasContent && (
                <div class="tl-lessons hidden" data-lessons-panel>
                  {lessons.map((lesson) => (
                    <a
                      href={`/cafe/${lesson.slug}`}
                      class="tl-lesson tl-lesson-available"
                      data-lesson-slug={lesson.slug}
                    >
                      <span class="tl-lesson-status-icon">
                        <svg
                          viewBox="0 0 16 16"
                          fill="currentColor"
                          class="tl-lesson-icon tl-lesson-icon-check"
                          style="display:none"
                        >
                          <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                        </svg>
                        <span class="tl-lesson-icon-unread" />
                      </span>
                      <span>{lesson.data.title}</span>
                    </a>
                  ))}
                  {planned.slice(lessons.length).map((title) => (
                    <div class="tl-lesson tl-lesson-pending">
                      <span class="tl-lesson-dot" />
                      <span>{title}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        )
      })
    }
  </div>

  <!-- Sources -->
  <div class="rm-footer">
    <details>
      <summary class="rm-sources-toggle">Bibliografía y fuentes</summary>
      <div class="rm-biblio">
        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Libros principales</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>James Hoffmann</strong> — <em
                >The World Atlas of Coffee</em
              >, 2ª ed. (2018). Fundamento para las fases 1, 3 y 4: orígenes,
              métodos de filtrado, variedades y la técnica de French press.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >The Professional Barista's Handbook</em
              > (2008). Base de las fases 2 y 3: ciencia de extracción, espresso,
              dial-in, diagnóstico de shots y principios de pour-over.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >The Coffee Roaster's Companion</em
              > (2014). Base de la fase 6: curvas de tueste, RoR, DTR, perfiles por
              origen y defectos de tueste.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >Espresso Extraction: Measurement and Mastery</em
              > (2013). Base de la fase 7: refractómetro, TDS, pressure profiling,
              turbo shots y ratios extendidos.
            </li>
            <li>
              <strong>David Schomer</strong> — <em
                >Espresso Coffee: Professional Techniques</em
              >, 4ª ed. (2010). Referencia para la fase 2: presión, temperatura,
              estabilidad térmica, pre-infusión y mantenimiento.
            </li>
            <li>
              <strong>Dhan Tamang</strong> — <em
                >Coffee Art: Creative Coffee Designs for the Home Barista</em
              > (2017). Base de la fase 5: patrones básicos y avanzados de latte art,
              técnica de vertido y etching.
            </li>
            <li>
              <strong>Jonathan Gagné</strong> — <em
                >The Physics of Filter Coffee</em
              > (2021). Base de la fase 8: ley de Darcy, percolación, distribución
              de partículas, geometría de drippers y migración de finos.
            </li>
            <li>
              <strong>Jonathan Gagné</strong> — <em>The Physics of Espresso</em> (2023).
              Base de la fase 8: dinámica del puck, pressure/flow profiling, ciencia
              de la extracción bajo presión.
            </li>
            <li>
              <strong>Britta Folmer (ed.)</strong> — <em
                >The Craft and Science of Coffee</em
              > (2017, Elsevier). Referencia académica: química del tueste a nivel
              molecular, descafeinado, crema, sostenibilidad.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em>Everything But Espresso</em> (2010).
              Métodos de filtrado con rigor técnico: percolación, inmersión, bypass
              y variables de control.
            </li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">
            Publicaciones SCA y World Coffee Research
          </h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>SCA</strong> — <em>Coffee Sensory & Cupping Handbook</em>.
              Protocolo de catación, formulario de evaluación y estándares de
              puntaje (fase 4).
            </li>
            <li>
              <strong>SCA</strong> — <em>Water Quality Handbook</em>. Estándares
              de agua para preparación: TDS, pH, dureza y composición mineral
              (fase 1).
            </li>
            <li>
              <strong>SCA &amp; WCR</strong> — <em
                >Coffee Taster's Flavor Wheel</em
              > (2016). Rueda de sabores, descriptores y familias sensoriales (fase
              4).
            </li>
            <li>
              <strong>SCA</strong> — <em>Coffee Skills Program</em>. Estructura
              modular Foundation → Intermediate → Professional como referencia
              del roadmap.
            </li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Libros complementarios</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>Maxwell Colonna-Dashwood</strong> — <em
                >Water for Coffee</em
              > (2015). Química del agua, mineralización y su impacto en la extracción
              (fase 1).
            </li>
            <li>
              <strong>Rob Hoos</strong> — <em
                >Modulating the Flavor Profile of Coffee</em
              > (2015). Relación entre decisiones de tueste y perfil de sabor (fase
              6).
            </li>
            <li>
              <strong>Christopher H. Hendon et al.</strong> — <em
                >Water for Coffee</em
              > (2015). Investigación científica sobre el rol del agua en la extracción.
            </li>
            <li>
              <strong>Andrea Illy &amp; Rinantonio Viani</strong> — <em
                >Espresso Coffee: The Science of Quality</em
              >, 2ª ed. (2005). Fundamentos científicos del espresso (fase 2).
            </li>
            <li>
              <strong>Morten Münchow et al.</strong> — Investigaciones sobre extracción,
              TDS y rendimiento publicadas en <em>Journal of Food Science</em>.
            </li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Recursos en línea</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>James Hoffmann</strong> — Canal de YouTube. Técnicas de V60
              (método Hoffmann), French press, Aeropress, y reviews de equipo.
            </li>
            <li>
              <strong>Tetsu Kasuya</strong> — Método 4:6 para V60, documentado en
              World Brewers Cup 2016.
            </li>
            <li>
              <strong>Barista Hustle</strong> — Artículos técnicos sobre extracción,
              percolación y ciencia del café.
            </li>
            <li>
              <strong>World Aeropress Championship</strong> — Archivo público de recetas
              ganadoras por año.
            </li>
            <li>
              <strong>Specialty Coffee Association (sca.coffee)</strong> — Estándares,
              protocolos y recursos educativos.
            </li>
            <li>
              <strong>Perfect Daily Grind</strong> — Artículos sobre cadena de suministro,
              comercio directo y sostenibilidad (fase 6).
            </li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Referencia por fase</h4>
          <div class="rm-phase-refs">
            <p>
              <strong>Fase 1</strong> (Fundamentos): Hoffmann, Rao (Barista's Handbook),
              Colonna-Dashwood, SCA Water Quality Handbook
            </p>
            <p>
              <strong>Fase 2</strong> (Espresso): Schomer, Rao (Barista's Handbook),
              Illy &amp; Viani
            </p>
            <p>
              <strong>Fase 3</strong> (Filtrado): Hoffmann, Rao (Barista's Handbook),
              Kasuya 4:6, World Aeropress Championship
            </p>
            <p>
              <strong>Fase 4</strong> (Paladar): SCA Cupping Handbook, SCA/WCR Flavor
              Wheel, Barista Hustle
            </p>
            <p>
              <strong>Fase 5</strong> (Latte art): Tamang, Schomer, Hoffmann (YouTube)
            </p>
            <p>
              <strong>Fase 6</strong> (Tueste y negocio): Rao (Roaster's Companion),
              Hoos, SCA, Perfect Daily Grind
            </p>
            <p>
              <strong>Fase 7</strong> (Metodología Rao): Rao (Barista's Handbook,
              Espresso Extraction), Münchow et al., SCA Brewing Control Chart
            </p>
            <p>
              <strong>Fase 8</strong> (Física de la extracción): Gagné (Physics of
              Filter Coffee, Physics of Espresso), Folmer (Craft &amp; Science of
              Coffee), Rao (Everything But Espresso)
            </p>
            <p>
              <strong>Fase 9</strong> (Carrera profesional): SCA Coffee Skills Program,
              CQI Q Grader, World Barista Championship, Rao (Barista's Handbook)
            </p>
          </div>
        </div>
      </div>
    </details>
  </div>
</PageLayout>

<style>
  /* ── Header ── */
  .rm-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rm-lang-switch {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: inherit;
    text-decoration: none;
    opacity: 0.35;
    transition:
      opacity 0.15s,
      border-color 0.15s;
  }
  .rm-lang-switch:hover {
    opacity: 0.7;
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  .rm-header {
    margin-bottom: 2.5rem;
    animation: rm-fade-in 0.6s ease-out;
  }
  .rm-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.25;
    margin-bottom: 0.375rem;
  }
  .rm-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }
  .rm-desc {
    font-size: 0.8125rem;
    opacity: 0.4;
    margin-bottom: 0;
  }
  .rm-progress {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 1rem;
    max-width: 16rem;
  }
  .rm-progress-track {
    flex: 1;
    height: 3px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    overflow: hidden;
  }
  .rm-progress-fill {
    height: 100%;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 55%, transparent);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .rm-progress-text {
    font-size: 0.6875rem;
    font-weight: 500;
    opacity: 0.3;
    font-variant-numeric: tabular-nums;
  }

  @keyframes rm-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Intro ── */
  .rm-intro {
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    border: 1.5px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
  }
  .rm-intro-text {
    font-size: 0.85rem;
    line-height: 1.7;
    opacity: 0.6;
    margin: 0 0 0.6rem;
  }
  .rm-intro-text:last-of-type {
    margin-bottom: 0.85rem;
  }
  .rm-intro-text strong {
    opacity: 1;
    color: var(--color-accent);
    font-weight: 600;
  }
  .rm-intro-text a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    transition: border-color 0.2s ease;
  }
  .rm-intro-text a:hover {
    border-color: var(--color-accent);
  }
  .rm-intro-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 0.2s ease;
  }
  .rm-intro-link:hover {
    opacity: 1;
  }
  .rm-intro-link .iconify {
    font-size: 0.85rem;
    transition: transform 0.2s ease;
  }
  .rm-intro-link:hover .iconify {
    transform: translateX(3px);
  }

  /* ── Timeline layout ── */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .tl-phase {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0 1rem;
    min-height: 0;
    animation: rm-phase-in 0.5s ease-out both;
  }
  .tl-phase:nth-child(1) {
    animation-delay: 0.08s;
  }
  .tl-phase:nth-child(2) {
    animation-delay: 0.14s;
  }
  .tl-phase:nth-child(3) {
    animation-delay: 0.2s;
  }
  .tl-phase:nth-child(4) {
    animation-delay: 0.26s;
  }
  .tl-phase:nth-child(5) {
    animation-delay: 0.32s;
  }
  .tl-phase:nth-child(6) {
    animation-delay: 0.38s;
  }
  .tl-phase:nth-child(7) {
    animation-delay: 0.44s;
  }
  .tl-phase:nth-child(8) {
    animation-delay: 0.5s;
  }
  .tl-phase:nth-child(9) {
    animation-delay: 0.56s;
  }

  @keyframes rm-phase-in {
    from {
      opacity: 0;
      transform: translateX(-6px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Track: node + vertical line ── */
  .tl-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .tl-node {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition:
      transform 0.2s ease,
