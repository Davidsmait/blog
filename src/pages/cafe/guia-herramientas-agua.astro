---
import Footer from '@/components/layout/Footer.astro'
import Header from '@/components/layout/Header.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import ScrollProgressPlugin from '@/plugins/ScrollProgressPlugin.astro'

const frontmatter = {
  title: 'Guía interactiva: Herramientas para medir tu agua',
  description:
    'Aprende a usar tu medidor digital de pH/TDS/EC y tu kit API GH & KH para optimizar el agua de tu café de especialidad.'
}
---

<BaseLayout frontmatter={frontmatter}>
  <div id="page-wrapper" class="noise-overlay">
    <div class="px-5 sm:px-6 lg:px-0">
      <Header activeHeaderLink="Café" />

      <main class="guide-main mt-8 sm:mt-14">
        <!-- Breadcrumb -->
        <div class="reveal mb-8 sm:mb-12">
          <div
            class="flex flex-wrap items-center gap-3 text-[11px] font-medium uppercase tracking-[0.15em] opacity-20"
          >
            <a
              href="/barista-roadmap"
              class="no-underline opacity-70 transition-opacity duration-300 hover:opacity-100"
              >Roadmap</a
            >
            <span class="h-[1px] w-4 bg-accent/10"></span>
            <span>Fase 1: Fundamentos</span>
            <span class="h-[1px] w-4 bg-accent/10"></span>
            <span>Guía práctica</span>
          </div>
        </div>

        <!-- Title -->
        <div class="reveal mb-4">
          <h1
            class="m-0 font-display text-[clamp(1.8rem,5vw,3rem)] font-bold leading-[1.1] tracking-tighter-brand text-accent sm:text-[clamp(2rem,4vw,3.5rem)]"
          >
            Herramientas para medir tu agua
          </h1>
        </div>

        <!-- Subtitle -->
        <div class="reveal mb-6">
          <p
            class="m-0 max-w-xl text-[15px] leading-[1.7] opacity-35 sm:text-base"
          >
            Guía paso a paso para el medidor digital pH/TDS/EC y el kit API GH &
            KH. Complemento práctico de la Lección 1.4: El agua.
          </p>
        </div>

        <!-- Unlock gate (hidden via JS if lessons complete) -->
        <div class="reveal mb-8" id="unlock-gate">
          <div class="gate-card">
            <div class="gate-icon">
              <svg
                viewBox="0 0 16 16"
                fill="currentColor"
                width="28"
                height="28"
                style="opacity:0.3"
              >
                <path
                  d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z"
                ></path>
              </svg>
            </div>
            <p class="gate-title">Contenido bonus bloqueado</p>
            <p class="gate-text">
              Esta guía se desbloquea al completar las 4 lecciones de la Fase 1:
              Fundamentos del café.
            </p>
            <div class="gate-progress">
              <div class="gate-lessons" id="gate-lessons-list"></div>
            </div>
            <a href="/barista-roadmap" class="gate-btn" data-cursor-hover
              >Ir al roadmap →</a
            >
          </div>
        </div>

        <!-- Guide content (hidden until unlocked) -->
        <div id="guide-content" style="display:none">
          <!-- Quick context -->
          <div class="reveal mb-8">
            <div class="context-card">
              <div class="context-icon">💧</div>
              <div>
                <p class="context-title">¿Por qué medir tu agua?</p>
                <p class="context-text">
                  Tu café es 98% agua. Su composición mineral determina cómo se
                  extraen los sabores. El medidor digital te dice <strong
                    >cuántos</strong
                  > minerales hay; el kit API te dice <strong>cuáles</strong> son.
                  Juntos te dan el panorama completo.
                </p>
              </div>
            </div>
          </div>

          <div class="hr-animated mb-8 sm:mb-12"></div>

          <!-- ═══ TAB NAVIGATION ═══ -->
          <div class="reveal" id="tool-tabs">
            <div
              class="tab-nav"
              role="tablist"
              aria-label="Selección de herramienta"
            >
              <button
                role="tab"
                aria-selected="true"
                aria-controls="panel-digital"
                id="tab-digital"
                class="tab-btn active"
                data-tab="digital"
              >
                <span class="tab-icon">📱</span>
                <span class="tab-label">Medidor Digital</span>
                <span class="tab-sub">pH / TDS / EC</span>
              </button>
              <button
                role="tab"
                aria-selected="false"
                aria-controls="panel-api"
                id="tab-api"
                class="tab-btn"
                data-tab="api"
              >
                <span class="tab-icon">🧪</span>
                <span class="tab-label">Kit API</span>
                <span class="tab-sub">GH & KH</span>
              </button>
              <button
                role="tab"
                aria-selected="false"
                aria-controls="panel-strips"
                id="tab-strips"
                class="tab-btn"
                data-tab="strips"
              >
                <span class="tab-icon">📄</span>
                <span class="tab-label">Tiritas pH</span>
                <span class="tab-sub">Papel indicador</span>
              </button>
            </div>

            <!-- ═══ PANEL: Medidor Digital ═══ -->
            <div
              role="tabpanel"
              id="panel-digital"
              aria-labelledby="tab-digital"
              class="tab-panel active"
            >
              <!-- What it measures -->
              <div class="info-grid">
                <div class="info-card">
                  <div class="info-badge">TDS</div>
                  <p class="info-label">Sólidos Disueltos Totales</p>
                  <p class="info-desc">
                    Cuántos minerales tiene tu agua en ppm. <strong
                      >Es la medición más importante para café.</strong
                    >
                  </p>
                  <div class="range-visual">
                    <div class="range-bar">
                      <div class="range-zone range-low" style="width:30%">
                        <span class="range-text">&lt;75</span>
                      </div>
                      <div class="range-zone range-ideal" style="width:30%">
                        <span class="range-text">75-150</span>
                      </div>
                      <div class="range-zone range-ok" style="width:20%">
                        <span class="range-text">150-250</span>
                      </div>
                      <div class="range-zone range-high" style="width:20%">
                        <span class="range-text">&gt;250</span>
                      </div>
                    </div>
                    <div class="range-labels">
                      <span>Muy blanda</span>
                      <span class="range-ideal-label">Ideal ✓</span>
                      <span>Aceptable</span>
                      <span>Dura</span>
                    </div>
                  </div>
                </div>
                <div class="info-card">
                  <div class="info-badge">pH</div>
                  <p class="info-label">Acidez / Alcalinidad</p>
                  <p class="info-desc">
                    La SCA recomienda agua entre <strong>6.5 y 7.5</strong> para café.
                  </p>
                  <div class="ph-scale">
                    <div class="ph-gradient"></div>
                    <div class="ph-marker" style="left: 46.4%"></div>
                    <div class="ph-marker" style="left: 53.6%"></div>
                    <div class="ph-labels">
                      <span>0 Ácido</span>
                      <span>7 Neutro</span>
                      <span>14 Alcalino</span>
                    </div>
                    <div class="ph-ideal-label">6.5 — 7.5 ideal</div>
                  </div>
                </div>
                <div class="info-card">
                  <div class="info-badge">EC</div>
                  <p class="info-label">Conductividad Eléctrica</p>
                  <p class="info-desc">
                    Mide lo mismo que TDS pero en µS/cm. Para café, <strong
                      >enfócate en la lectura de TDS</strong
                    > directamente.
                  </p>
                </div>
              </div>

              <!-- Steps -->
              <h2 class="section-title">Calibración (solo la primera vez)</h2>
              <p class="section-note">
                Repite cada 2-3 semanas o si las lecturas parecen raras.
              </p>

              <div class="steps-timeline">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Prepara la solución buffer</h3>
                    <p>
                      Disuelve el sobre de polvo <strong>pH 6.86</strong> en un vaso
                      con agua destilada (~250ml). Revuelve hasta disolver completamente.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Sumerge el electrodo</h3>
                    <p>
                      Enciende el medidor, sumerge la punta en la solución
                      buffer. Espera unos segundos a que la lectura se
                      estabilice.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Presiona CAL</h3>
                    <p>
                      Mantén presionado el botón <strong>"CAL"</strong> durante 5
                      segundos. El número va a parpadear y luego se fija — eso significa
                      que calibró.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Repite con pH 4.01</h3>
                    <p>
                      Enjuaga la punta con agua destilada, luego repite el
                      proceso con el sobre de <strong>pH 4.01</strong>. Con dos
                      puntos de calibración tu medidor es preciso en todo el
                      rango.
                    </p>
                  </div>
                </div>
              </div>

              <h2 class="section-title">Cómo medir tu agua</h2>

              <div class="steps-timeline">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Sirve el agua en un vaso limpio</h3>
                    <p>
                      Usa el agua que quieras medir: grifo, garrafón,
                      embotellada. <strong>No uses el mismo vaso</strong> — enjuágalo
                      entre mediciones o usa vasos separados.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Enciende y sumerge</h3>
                    <p>
                      Enciende el medidor, sumerge la punta en el agua. Muévelo
                      suavemente en círculos 2-3 veces para eliminar burbujas de
                      aire.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Espera ~30 segundos</h3>
                    <p>
                      Deja que el número se estabilice. Cuando deje de moverse,
                      esa es tu lectura. Puedes presionar <strong>"HOLD"</strong
                      > para fijar el número en pantalla.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Anota en tu cuaderno</h3>
                    <p>
                      Registra: tipo de agua, TDS (ppm), pH, y fecha. Con el
                      tiempo vas a tener un historial que te ayuda a elegir tu
                      agua ideal.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">5</div>
                  <div class="step-content">
                    <h3>Enjuaga entre mediciones</h3>
                    <p>
                      Moja la punta con agua destilada antes de medir otra agua
                      diferente. Esto evita contaminar la lectura.
                    </p>
                  </div>
                </div>
              </div>

              <div class="tip-box">
                <span class="tip-label">Tip</span>
                <p>
                  El TDS <strong>no necesita calibración</strong> — viene calibrado
                  de fábrica. Solo el pH requiere calibrar con los polvos buffer.
                </p>
              </div>
            </div>

            <!-- ═══ PANEL: Kit API GH & KH ═══ -->
            <div
              role="tabpanel"
              id="panel-api"
              aria-labelledby="tab-api"
              class="tab-panel"
              hidden
            >
              <div class="info-grid two-col">
                <div class="info-card">
                  <div class="info-badge badge-gh">GH</div>
                  <p class="info-label">General Hardness (Dureza General)</p>
                  <p class="info-desc">
                    Mide el <strong>calcio + magnesio</strong> de tu agua. Son los
                    "extractores": los minerales que arrancan los compuestos de sabor
                    del café.
                  </p>
                  <p class="info-detail">
                    Más magnesio → café más brillante y ácido<br />Más calcio →
                    café más redondo y con cuerpo
                  </p>
                  <p class="info-target">
                    SCA recomienda: <strong>50-175 ppm</strong>
                  </p>
                </div>
                <div class="info-card">
                  <div class="info-badge badge-kh">KH</div>
                  <p class="info-label">Carbonate Hardness (Alcalinidad)</p>
                  <p class="info-desc">
                    Mide los <strong>bicarbonatos</strong> de tu agua. Funcionan como
                    un "control de volumen" para la acidez del café.
                  </p>
                  <p class="info-detail">
                    Poco KH → acidez agresiva<br />Mucho KH → café plano, sin
                    vida
                  </p>
                  <p class="info-target">
                    SCA recomienda: <strong>40-70 ppm</strong>
                  </p>
                </div>
              </div>

              <!-- Conversion callout -->
              <div class="conversion-card">
                <p class="conversion-title">Conversión</p>
                <p class="conversion-formula">
                  Cada gota = 1 dGH (o dKH) = <strong>17.9 ppm</strong>
                </p>
                <p class="conversion-example">
                  Ejemplo: 4 gotas × 17.9 = 71.6 ppm
                </p>
              </div>

              <!-- KH Test -->
              <h2 class="section-title">Test KH (Alcalinidad)</h2>
              <p class="section-note">Cambio de color: azul → amarillo</p>

              <div class="steps-timeline kh-steps">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Llena el tubo</h3>
                    <p>
                      Usa el tubo de vidrio del kit. Llénalo con <strong
                        >5 ml</strong
                      > de tu agua (hasta la línea marcada).
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Agrega 1 gota del reactivo KH</h3>
                    <p>
                      Sostén el frasco de reactivo KH en posición vertical y
                      agrega <strong>una sola gota</strong>.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Tapa e invierte</h3>
                    <p>
                      Pon la tapa al tubo e <strong
                        >inviértelo varias veces</strong
                      > para mezclar bien. Observa el color.
                    </p>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #4a90d9"></div>
                      <span>¿Sigue azul? → Agrega otra gota</span>
                    </div>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #d4c94a"></div>
                      <span>¿Cambió a amarillo? → ¡Para! Cuenta las gotas</span>
                    </div>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Repite gota a gota</h3>
                    <p>
                      Sigue agregando gotas de una en una, agitando después de
                      cada una, hasta que el agua cambie de <strong
                        >azul a amarillo</strong
                      >.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">5</div>
                  <div class="step-content">
                    <h3>Calcula tu resultado</h3>
                    <p>Número de gotas × 17.9 = tu KH en ppm</p>
                    <!-- Interactive calculator -->
                    <div class="calc-box" id="calc-kh">
                      <label class="calc-label" for="kh-drops"
                        >¿Cuántas gotas usaste?</label
                      >
                      <div class="calc-input-row">
                        <button
                          class="calc-btn minus"
                          data-calc="kh"
                          data-action="minus"
                          aria-label="Menos">−</button
                        >
                        <input
                          type="number"
                          id="kh-drops"
                          class="calc-input"
                          value="0"
                          min="0"
                          max="30"
                          readonly
                        />
                        <button
                          class="calc-btn plus"
                          data-calc="kh"
                          data-action="plus"
                          aria-label="Más">+</button
                        >
                      </div>
                      <div class="calc-result" id="kh-result">
                        <span class="calc-ppm">0 ppm</span>
                        <span class="calc-verdict" id="kh-verdict"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- GH Test -->
              <h2 class="section-title">Test GH (Dureza General)</h2>
              <p class="section-note">Cambio de color: naranja → verde</p>

              <div class="steps-timeline gh-steps">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Tubo limpio con agua fresca</h3>
                    <p>
                      Enjuaga el tubo y llénalo con <strong
                        >5 ml de agua fresca</strong
                      > (no reutilices el agua del test KH).
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Agrega 1 gota del reactivo GH</h3>
                    <p>
                      Usa el frasco de reactivo <strong>GH</strong> (diferente al
                      de KH). Agrega una gota.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Tapa, invierte, observa</h3>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #d98a4a"></div>
                      <span>¿Sigue naranja? → Agrega otra gota</span>
                    </div>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #5ab569"></div>
                      <span>¿Cambió a verde? → ¡Para! Cuenta las gotas</span>
                    </div>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Repite gota a gota hasta verde</h3>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">5</div>
                  <div class="step-content">
                    <h3>Calcula tu resultado</h3>
                    <p>Número de gotas × 17.9 = tu GH en ppm</p>
                    <div class="calc-box" id="calc-gh">
                      <label class="calc-label" for="gh-drops"
                        >¿Cuántas gotas usaste?</label
                      >
                      <div class="calc-input-row">
                        <button
                          class="calc-btn minus"
                          data-calc="gh"
                          data-action="minus"
                          aria-label="Menos">−</button
                        >
                        <input
                          type="number"
                          id="gh-drops"
                          class="calc-input"
                          value="0"
                          min="0"
                          max="30"
                          readonly
                        />
                        <button
                          class="calc-btn plus"
                          data-calc="gh"
                          data-action="plus"
                          aria-label="Más">+</button
                        >
                      </div>
                      <div class="calc-result" id="gh-result">
                        <span class="calc-ppm">0 ppm</span>
                        <span class="calc-verdict" id="gh-verdict"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="tip-box">
                <span class="tip-label">Ojo</span>
                <p>
                  Si la <strong>primera gota ya cambia el color</strong>, tu
                  agua tiene muy poca dureza. Esto es común en garrafones de
                  ósmosis inversa y significa que tu agua no tiene suficientes
                  minerales para extraer bien los sabores del café.
                </p>
              </div>
            </div>

            <!-- ═══ PANEL: Tiritas pH ═══ -->
            <div
              role="tabpanel"
              id="panel-strips"
              aria-labelledby="tab-strips"
              class="tab-panel"
              hidden
            >
              <div class="info-card single-card">
                <p class="info-label">¿Qué son?</p>
                <p class="info-desc">
                  Papel impregnado con indicadores químicos que cambian de color
                  según el pH del líquido. Es una forma rápida y analógica de
                  medir pH — menos precisa que el medidor digital (±0.5 vs
                  ±0.01), pero útil como verificación rápida.
                </p>
              </div>

              <h2 class="section-title">Cómo usarlas</h2>

              <div class="steps-timeline">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Arranca una tirita</h3>
                    <p>
                      Separa una tira del bloque de papel. Sostenla por un
                      extremo sin tocar la zona que vas a sumergir.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Sumerge brevemente</h3>
                    <p>
                      Mete la tirita en el líquido <strong
                        >solo un segundo</strong
                      > — no la dejes empapándose. Sácala inmediatamente.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Espera 15-30 segundos</h3>
                    <p>
                      Deja que el color se estabilice. No la toques mientras
                      cambia.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Compara con la escala</h3>
                    <p>
                      Pon la tirita junto a la escala de colores impresa en la
                      caja. <strong>Usa luz natural y fondo blanco</strong> — la luz
                      amarilla puede engañarte.
                    </p>
                  </div>
                </div>
              </div>

              <!-- pH color scale -->
              <h2 class="section-title">Escala de colores y significado</h2>

              <div class="ph-color-guide">
                <div class="ph-row" data-ph="acid">
                  <div
                    class="ph-color-strip"
                    style="background: linear-gradient(to right, #e53935, #ff8f00)"
                  >
                  </div>
                  <div class="ph-info">
                    <span class="ph-range">pH 1-4</span>
                    <span class="ph-name">Muy ácido</span>
                    <span class="ph-example"
                      >Limón, vinagre, Cloralex diluido</span
                    >
                  </div>
                </div>
                <div class="ph-row" data-ph="slight-acid">
                  <div
                    class="ph-color-strip"
                    style="background: linear-gradient(to right, #ff8f00, #c0ca33)"
                  >
                  </div>
                  <div class="ph-info">
                    <span class="ph-range">pH 5-6</span>
                    <span class="ph-name">Ligeramente ácido</span>
                    <span class="ph-example">Café preparado (~5), lluvia</span>
                  </div>
                </div>
                <div class="ph-row ideal" data-ph="ideal">
                  <div
                    class="ph-color-strip"
                    style="background: linear-gradient(to right, #c0ca33, #43a047)"
                  >
                  </div>
                  <div class="ph-info">
                    <span class="ph-range">pH 6.5-7.5</span>
                    <span class="ph-name">Ideal para café ✓</span>
