  <script>
    const PHASE_1_SLUGS = [
      'roadmap-1-1-que-es-cafe-especialidad',
      'roadmap-1-2-del-grano-a-la-taza',
      'roadmap-1-3-ciencia-extraccion',
      'roadmap-1-4-el-agua'
    ]
    const PHASE_1_TITLES = [
      '1.1 — ¿Qué es el café de especialidad?',
      '1.2 — Del grano a la taza',
      '1.3 — La ciencia de la extracción',
      '1.4 — El agua: el ingrediente invisible'
    ]
    const COOKIE_NAME = 'roadmap_read'

    function getReadLessons(): Set<string> {
      const match = document.cookie.match(
        new RegExp('(?:^|; )' + COOKIE_NAME + '=([^;]*)')
      )
      if (!match) return new Set()
      try {
        return new Set(JSON.parse(decodeURIComponent(match[1])))
      } catch {
        return new Set()
      }
    }

    function checkGate() {
      const read = getReadLessons()
      const allComplete = PHASE_1_SLUGS.every((s) => read.has(s))

      const gate = document.getElementById('unlock-gate')
      const content = document.getElementById('guide-content')

      if (allComplete) {
        if (gate) gate.style.display = 'none'
        if (content) content.style.display = 'block'
      } else {
        if (gate) gate.style.display = 'block'
        if (content) content.style.display = 'none'

        // Populate lessons checklist
        const list = document.getElementById('gate-lessons-list')
        if (list && list.children.length === 0) {
          PHASE_1_SLUGS.forEach((slug, i) => {
            const isRead = read.has(slug)
            const el = document.createElement('a')
            el.href = `/cafe/${slug}`
            el.className = `gate-lesson ${isRead ? 'gate-lesson--done' : ''}`
            el.innerHTML = `
              <span class="gate-check">${isRead ? '✓' : ''}</span>
              <span>${PHASE_1_TITLES[i]}</span>
            `
            list.appendChild(el)
          })
        }
      }
    }

    checkGate()
    document.addEventListener('astro:page-load', checkGate)
  </script>

  <!-- ═══ INTERACTIVITY ═══ -->
  <script>
    function initGuide() {
      // ── Tab switching ──
      const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
      const panels = document.querySelectorAll<HTMLDivElement>('.tab-panel')

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab
          tabs.forEach((t) => {
            t.classList.remove('active')
            t.setAttribute('aria-selected', 'false')
          })
          panels.forEach((p) => {
            p.classList.remove('active')
            p.hidden = true
          })
          tab.classList.add('active')
          tab.setAttribute('aria-selected', 'true')
          const panel = document.getElementById(`panel-${target}`)
          if (panel) {
            panel.classList.add('active')
            panel.hidden = false
          }
        })
      })

      // ── Drop calculators ──
      document
        .querySelectorAll<HTMLButtonElement>('.calc-btn')
        .forEach((btn) => {
          btn.addEventListener('click', () => {
            const calc = btn.dataset.calc! // 'kh' or 'gh'
            const action = btn.dataset.action! // 'plus' or 'minus'
            const input = document.getElementById(
              `${calc}-drops`
            ) as HTMLInputElement
            let val = parseInt(input.value) || 0
            if (action === 'plus') val++
            if (action === 'minus' && val > 0) val--
            input.value = String(val)

            const ppm = (val * 17.9).toFixed(1)
            const resultEl = document.getElementById(`${calc}-result`)!
            resultEl.querySelector('.calc-ppm')!.textContent = `${ppm} ppm`

            const verdictEl = document.getElementById(`${calc}-verdict`)!
            if (calc === 'kh') {
              const n = parseFloat(ppm)
              if (val === 0) verdictEl.textContent = ''
              else if (n < 40)
                verdictEl.textContent = '⚠️ Baja — acidez puede ser agresiva'
              else if (n <= 70) verdictEl.textContent = '✅ Rango ideal SCA'
              else verdictEl.textContent = '⚠️ Alta — puede aplastar la acidez'
              verdictEl.className =
                'calc-verdict' +
                (n >= 40 && n <= 70 && val > 0
                  ? ' verdict-good'
                  : val > 0
                    ? ' verdict-warn'
                    : '')
            } else {
              const n = parseFloat(ppm)
              if (val === 0) verdictEl.textContent = ''
              else if (n < 50)
                verdictEl.textContent = '⚠️ Baja — poca extracción de sabor'
              else if (n <= 175) verdictEl.textContent = '✅ Rango ideal SCA'
              else
                verdictEl.textContent =
                  '⚠️ Alta — riesgo de sobre-extracción y escala'
              verdictEl.className =
                'calc-verdict' +
                (n >= 50 && n <= 175 && val > 0
                  ? ' verdict-good'
                  : val > 0
                    ? ' verdict-warn'
                    : '')
            }
          })
        })

      // ── Reveal animations ──
      const reveals = document.querySelectorAll(
        '.reveal, .stagger-children, .hr-animated'
      )
      if (reveals.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add('revealed')
            })
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        )
        reveals.forEach((el) => observer.observe(el))
      }

      // ── Cursor hover ──
      const isTouchDevice =
        'ontouchstart' in window || navigator.maxTouchPoints > 0
      if (!isTouchDevice && window.matchMedia('(pointer: fine)').matches) {
        document.querySelectorAll('[data-cursor-hover]').forEach((el) => {
          el.addEventListener('mouseenter', () => {
            document.getElementById('custom-cursor')?.classList.add('hovering')
          })
          el.addEventListener('mouseleave', () => {
            document
              .getElementById('custom-cursor')
              ?.classList.remove('hovering')
          })
        })
      }
    }

    document.addEventListener('astro:page-load', initGuide)
  </script>
