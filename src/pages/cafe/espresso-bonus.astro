---
import PageLayout from '../../layouts/PageLayout.astro'
---

<PageLayout
  frontmatter={{
    title: 'Espresso — Bonus: Calculadora y Diagnóstico',
    description:
      'Herramientas prácticas para dominar espresso: calculadora de dosis y yield, diagnóstico interactivo de sabor con soluciones.',
    activeHeaderLink: 'Café'
  }}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'Espresso Bonus — Calculadora y Diagnóstico',
      description:
        'Herramientas para optimizar espresso: calcula yield, diagnostica sabor y obtén soluciones concretas.',
      url: 'https://davidsanluisaguirre.com/cafe/espresso-bonus',
      inLanguage: 'es',
      applicationCategory: 'UtilityApplication',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'MXN' },
      author: { '@id': 'https://davidsanluisaguirre.com/#person' }
    })}
  />

  <div class="bonus-page">

    <!-- ── Hero Header ── -->
    <div class="reveal bonus-hero">
      <span class="section-label bonus-eyebrow">Bonus — Fase 2: Espresso</span>
      <h1 class="bonus-title">
        <span class="gradient-text">Calculadora</span> y Diagnóstico
      </h1>
      <p class="bonus-sub">
        Dos herramientas para ajustar tu receta y resolver problemas de sabor
      </p>

      <!-- Tool pills -->
      <div class="tool-pills stagger-children reveal reveal-delay-1">
        <span class="tool-pill">
          <span class="tool-pill-dot"></span>
          Calculadora de yield
        </span>
        <span class="tool-pill">
          <span class="tool-pill-dot"></span>
          Diagnóstico de sabor
        </span>
      </div>
    </div>

    <div class="hr-animated mb-10 sm:mb-14"></div>

    <!-- ──── SECTION 1: CALCULATOR ──── -->
    <div class="bonus-section reveal" id="calculator-section">

      <div class="section-header">
        <span class="section-number counter-badge">01</span>
        <div>
          <h2 class="section-title">Calculadora de Dosis y Yield</h2>
          <p class="section-desc">
            Ingresa tu dosis y elige un ratio para calcular el yield objetivo de tu espresso
          </p>
        </div>
      </div>

      <!-- Two-col grid on desktop -->
      <div class="calc-grid stagger-children reveal">

        <!-- Dose card -->
        <div class="glass-card calc-card">
          <div class="calc-card-label">Dosis</div>
          <p class="calc-card-caption">Café seco en el portafiltro</p>

          <div class="calc-field-group">
            <label class="calc-label" for="dose-input">Gramos de café</label>
            <div class="calc-stepper">
              <button class="stepper-btn" id="dose-minus" aria-label="Menos">−</button>
              <div class="stepper-input-wrap">
                <input
                  type="number"
                  id="dose-input"
                  class="stepper-input"
                  value="18"
                  min="7"
                  max="30"
                />
                <span class="stepper-unit">g</span>
              </div>
              <button class="stepper-btn" id="dose-plus" aria-label="Más">+</button>
            </div>
            <p class="calc-hint">Rango habitual: 14–20g para portafiltro doble</p>
          </div>
        </div>

        <!-- Ratio card -->
        <div class="glass-card calc-card">
          <div class="calc-card-label">Ratio</div>
          <p class="calc-card-caption">Proporción café:bebida</p>

          <div class="calc-field-group">
            <label class="calc-label">Ratio objetivo</label>
            <div class="ratio-grid" id="ratio-buttons">
              <button class="ratio-btn" data-ratio="1.0" data-label="Ristretto">1:1</button>
              <button class="ratio-btn" data-ratio="1.5" data-label="Ristretto largo">1:1.5</button>
              <button class="ratio-btn ratio-btn--active" data-ratio="2.0" data-label="Estándar">1:2</button>
              <button class="ratio-btn" data-ratio="2.5" data-label="Lungo">1:2.5</button>
              <button class="ratio-btn" data-ratio="3.0" data-label="Lungo largo">1:3</button>
            </div>
            <p class="ratio-name" id="ratio-name">Estándar — punto de partida universal</p>
          </div>
        </div>

      </div>

      <!-- Result panel -->
      <div class="result-hero-card reveal reveal-delay-2 glow" id="result-card">
        <div class="result-hero-inner">
          <div class="result-hero-left">
            <span class="result-hero-label">Tu yield objetivo</span>
            <div class="result-hero-number">
              <span id="result-yield">36</span>
              <span class="result-hero-unit">g en taza</span>
            </div>
            <div class="result-hero-formula" id="result-formula">18g × 2.0 = 36g</div>
          </div>
          <div class="result-hero-right">
            <div class="result-meta-item">
              <span class="result-meta-label">Tiempo esperado</span>
              <span class="result-meta-value" id="result-time">25–35 seg</span>
            </div>
            <p class="result-note" id="result-note">
              Ajusta la molienda hasta llegar a este yield en el tiempo indicado.
            </p>
          </div>
        </div>
      </div>

      <!-- Ratio reference table -->
      <div class="ref-section reveal reveal-delay-3">
        <div class="ref-header">
          <h3 class="ref-title">Referencia de ratios</h3>
          <p class="ref-sub">Cómo varía el yield con 18g de dosis base</p>
        </div>

        <div class="ref-table">
          <div class="ref-row ref-row--head">
            <span>Ratio</span>
            <span>Nombre</span>
            <span>Yield (18g)</span>
            <span>Perfil</span>
          </div>
          <div class="ref-row">
            <strong>1:1</strong>
            <span>Ristretto</span>
            <span>18 g</span>
            <span class="ref-badge ref-badge--under">Intenso</span>
          </div>
          <div class="ref-row">
            <strong>1:1.5</strong>
            <span>Ristretto largo</span>
            <span>27 g</span>
            <span class="ref-badge ref-badge--under">Concentrado</span>
          </div>
          <div class="ref-row ref-row--highlight">
            <strong>1:2</strong>
            <span>Estándar</span>
            <span>36 g</span>
            <span class="ref-badge ref-badge--ideal">Balance ✦</span>
          </div>
          <div class="ref-row">
            <strong>1:2.5</strong>
            <span>Lungo</span>
            <span>45 g</span>
            <span class="ref-badge ref-badge--over">Más suave</span>
          </div>
          <div class="ref-row">
            <strong>1:3</strong>
            <span>Lungo largo</span>
            <span>54 g</span>
            <span class="ref-badge ref-badge--over">Ligero</span>
          </div>
        </div>
        <p class="ref-note">Tiempo ideal: 25–35 seg · Temperatura recomendada: 92–94°C</p>
      </div>

    </div>

    <!-- ── Section divider ── -->
    <div class="section-divider reveal"></div>

    <!-- ──── SECTION 2: FLAVOR DIAGNOSIS ──── -->
    <div class="bonus-section reveal" id="diagnosis-section">

      <div class="section-header">
        <span class="section-number counter-badge">02</span>
        <div>
          <h2 class="section-title">Diagnóstico de Sabor</h2>
          <p class="section-desc">
            Prueba tu shot, identifica qué sientes y obtén soluciones ordenadas por impacto
          </p>
        </div>
      </div>

      <!-- Step 1 -->
      <div id="step-1">
        <p class="step-label">Paso 1 — Prueba tu shot y elige lo que mejor describe</p>

        <div class="symptom-grid stagger-children reveal">

          <button class="symptom-card" data-symptom="under" data-cursor-hover>
            <div class="symptom-icon-wrap symptom-icon-wrap--under">
              <span class="symptom-arrow">↑</span>
            </div>
            <div class="symptom-body">
              <span class="symptom-name">Ácido / Agrio</span>
              <span class="symptom-desc">Retrogusto corto, sabor punzante, falta dulzura y cuerpo</span>
            </div>
            <span class="symptom-cta">Diagnósticar →</span>
          </button>

          <button class="symptom-card" data-symptom="over" data-cursor-hover>
            <div class="symptom-icon-wrap symptom-icon-wrap--over">
              <span class="symptom-arrow">↓</span>
            </div>
            <div class="symptom-body">
              <span class="symptom-name">Amargo / Áspero</span>
              <span class="symptom-desc">Sequedad, astringencia, sabor a ceniza, retrogusto desagradable</span>
            </div>
            <span class="symptom-cta">Diagnósticar →</span>
          </button>

          <button class="symptom-card" data-symptom="weak" data-cursor-hover>
            <div class="symptom-icon-wrap symptom-icon-wrap--weak">
              <span class="symptom-arrow">−</span>
            </div>
            <div class="symptom-body">
              <span class="symptom-name">Aguado / Sin cuerpo</span>
              <span class="symptom-desc">Falta intensidad, sabor delgado, parece café de filtro flojo</span>
            </div>
            <span class="symptom-cta">Diagnósticar →</span>
          </button>

          <button class="symptom-card symptom-card--balanced" data-symptom="balanced" data-cursor-hover>
            <div class="symptom-icon-wrap symptom-icon-wrap--balanced">
              <span class="symptom-arrow">✓</span>
            </div>
            <div class="symptom-body">
              <span class="symptom-name">Dulce y balanceado</span>
              <span class="symptom-desc">Acidez agradable, dulzura natural, cuerpo presente, retrogusto limpio</span>
            </div>
            <span class="symptom-cta">Ver detalles →</span>
          </button>

        </div>
      </div>

      <!-- Step 2 — Diagnosis results -->
      <div id="step-2" class="diag-results" style="display:none">

        <!-- Under-extracted -->
        <div id="result-under" class="diag-panel" style="display:none">
          <div class="diag-panel-header diag-panel-header--under">
            <div class="diag-panel-icon">↑</div>
            <div>
              <h3 class="diag-panel-title">Sub-extracción</h3>
              <p class="diag-panel-sub">El agua no extrajo suficientes compuestos del café</p>
            </div>
          </div>
          <div class="diag-panel-body">
            <p class="diag-explain">
              Los ácidos son los primeros compuestos en extraerse. Si paras demasiado pronto
              (o el agua pasa muy rápido), domina la acidez sin que llegue la dulzura ni el
              cuerpo. El resultado: un shot punzante, corto, sin balance.
            </p>
            <h4 class="diag-solutions-title">Soluciones — mayor a menor impacto</h4>
            <ol class="diag-solutions">
              <li class="diag-solution-item">
                <span class="diag-solution-num">1</span>
                <div>
                  <strong>Muele más fino</strong>
                  <span>Más resistencia = flujo más lento = más tiempo de contacto = más extracción. Ajusta 1-2 clics a la vez.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">2</span>
                <div>
                  <strong>Alarga tu ratio</strong>
                  <span>Cambia de 1:2 a 1:2.2 o 1:2.5 — más agua pasa por el café, extrae más sin cambiar molienda.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">3</span>
                <div>
                  <strong>Sube la temperatura</strong>
                  <span>+1°C puede marcar diferencia. El agua más caliente extrae más rápido. Prueba 93°C → 94°C si tienes PID.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">4</span>
                <div>
                  <strong>Revisa tu distribución</strong>
                  <span>Si hay canales (channeling), el agua se escapa sin extraer uniformemente. Usa WDT.</span>
                </div>
              </li>
            </ol>
            <div class="diag-tip">
              <span class="diag-tip-label">Inicio recomendado</span>
              <p>Empieza siempre por la molienda. Es la variable de mayor impacto y la más fácil de ajustar sin tocar receta.</p>
            </div>
          </div>
          <button class="reset-btn" id="reset-under">← Probar otro sabor</button>
        </div>

        <!-- Over-extracted -->
        <div id="result-over" class="diag-panel" style="display:none">
          <div class="diag-panel-header diag-panel-header--over">
            <div class="diag-panel-icon">↓</div>
            <div>
              <h3 class="diag-panel-title">Sobre-extracción</h3>
              <p class="diag-panel-sub">El agua extrajo demasiado — incluyendo compuestos amargos no deseados</p>
            </div>
          </div>
          <div class="diag-panel-body">
            <p class="diag-explain">
              Los compuestos amargos y astringentes son los últimos en extraerse. Si el agua
              contacta el café por demasiado tiempo (molienda muy fina o shot muy largo),
              estos dominan. El resultado: boca seca, retrogusto áspero, sabor a ceniza.
            </p>
            <h4 class="diag-solutions-title">Soluciones — mayor a menor impacto</h4>
            <ol class="diag-solutions">
              <li class="diag-solution-item">
                <span class="diag-solution-num">1</span>
                <div>
                  <strong>Muele más grueso</strong>
                  <span>Menos resistencia = flujo más rápido = menos tiempo de contacto = menos extracción.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">2</span>
                <div>
                  <strong>Acorta tu ratio</strong>
                  <span>Cambia de 1:2 a 1:1.8 o 1:1.5 — menos agua, menos extracción. El shot termina antes de que salgan los amargos.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">3</span>
                <div>
                  <strong>Baja la temperatura</strong>
                  <span>-1°C puede suavizar el amargor. Prueba 93°C → 92°C si tienes PID.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">4</span>
                <div>
                  <strong>Corta la cola del shot</strong>
                  <span>Los últimos segundos son los más amargos. Detén la extracción antes del final.</span>
                </div>
              </li>
            </ol>
            <div class="diag-tip">
              <span class="diag-tip-label">Inicio recomendado</span>
              <p>Si el shot tarda más de 40 segundos para llegar a tu yield, la molienda está muy fina. Empieza por ahí.</p>
            </div>
          </div>
          <button class="reset-btn" id="reset-over">← Probar otro sabor</button>
        </div>

        <!-- Weak -->
        <div id="result-weak" class="diag-panel" style="display:none">
          <div class="diag-panel-header diag-panel-header--weak">
            <div class="diag-panel-icon">−</div>
            <div>
              <h3 class="diag-panel-title">Shot débil o aguado</h3>
              <p class="diag-panel-sub">Falta concentración — ya sea por ratio o por dosis</p>
            </div>
          </div>
          <div class="diag-panel-body">
            <p class="diag-explain">
              Un shot "aguado" sin acidez ni amargor marcados pero tampoco dulzura ni cuerpo
              puede ser un problema de concentración (TDS bajo) más que de extracción.
              El sabor simplemente no llega.
            </p>
            <h4 class="diag-solutions-title">Soluciones — mayor a menor impacto</h4>
            <ol class="diag-solutions">
              <li class="diag-solution-item">
                <span class="diag-solution-num">1</span>
                <div>
                  <strong>Reduce el ratio</strong>
                  <span>Si usas 1:2.5 o más, intenta 1:2. Menos agua = más concentración = más presencia en boca.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">2</span>
                <div>
                  <strong>Aumenta la dosis</strong>
                  <span>Más café en el portafiltro (ej: 17g → 18g → 19g) produce un shot más intenso con el mismo ratio.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">3</span>
                <div>
                  <strong>Verifica el tiempo</strong>
                  <span>Si el shot termina en menos de 20 segundos, la molienda es muy gruesa. Muele más fino.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num">4</span>
                <div>
                  <strong>Revisa la presión</strong>
                  <span>Una máquina con presión baja (menos de 8 bares) no emulsiona bien los aceites. El shot saldrá delgado.</span>
                </div>
              </li>
            </ol>
            <div class="diag-tip">
              <span class="diag-tip-label">Inicio recomendado</span>
              <p>Prueba primero ajustando el ratio. Es rápido y no requiere resetear la máquina.</p>
            </div>
          </div>
          <button class="reset-btn" id="reset-weak">← Probar otro sabor</button>
        </div>

        <!-- Balanced -->
        <div id="result-balanced" class="diag-panel diag-panel--balanced" style="display:none">
          <div class="diag-panel-header diag-panel-header--balanced">
            <div class="diag-panel-icon diag-panel-icon--balanced">✓</div>
            <div>
              <h3 class="diag-panel-title">Shot balanceado</h3>
              <p class="diag-panel-sub">Tu extracción está en punto — mantén la consistencia</p>
            </div>
          </div>
          <div class="diag-panel-body">
            <p class="diag-explain">
              Un shot dulce y balanceado significa que tu molienda, dosis, temperatura y
              tiempo están trabajando juntos. Los ácidos agradan, el cuerpo es presencia,
              y el retrogusto es limpio. Este es el objetivo.
            </p>
            <h4 class="diag-solutions-title">Cómo mantener la consistencia</h4>
            <ul class="diag-solutions diag-solutions--maintain">
              <li class="diag-solution-item">
                <span class="diag-solution-num diag-solution-num--balanced">✦</span>
                <div>
                  <strong>Anota tu receta</strong>
                  <span>Dosis exacta, ratio, temperatura, tiempo. Vuelve a estos números.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num diag-solution-num--balanced">✦</span>
                <div>
                  <strong>Distribución consistente</strong>
                  <span>Si usas WDT, usa siempre la misma técnica y herramienta.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num diag-solution-num--balanced">✦</span>
                <div>
                  <strong>Presión de tamping uniforme</strong>
                  <span>13-15 kg (≈30 lbs), con nivel. Evita ángulos.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num diag-solution-num--balanced">✦</span>
                <div>
                  <strong>Limpieza regular</strong>
                  <span>La acumulación de aceites en el portafiltro y ducha afecta futuros shots.</span>
                </div>
              </li>
              <li class="diag-solution-item">
                <span class="diag-solution-num diag-solution-num--balanced">✦</span>
                <div>
                  <strong>Monitorea el envejecimiento</strong>
                  <span>A medida que envejece el café (1-3 semanas post-roast), puede necesitar ajustes menores.</span>
                </div>
              </li>
            </ul>
            <div class="diag-tip diag-tip--balanced">
              <span class="diag-tip-label">Próximo paso</span>
              <p>Ahora experimenta variando una sola variable a la vez (ratio, temperatura, café) para descubrir tus preferencias.</p>
            </div>
          </div>
          <button class="reset-btn reset-btn--balanced" id="reset-balanced">← Probar otro sabor</button>
        </div>

      </div>
    </div>

    <!-- ── Back link ── -->
    <div class="reveal mt-10">
      <a href="/barista-roadmap" class="bonus-back-link" data-cursor-hover>
        <span class="bonus-back-arrow">←</span>
        Volver al roadmap
      </a>
    </div>

  </div>
</PageLayout>

<style>
  /* ─────────────────────────────────────────── */
  /* PAGE WRAPPER                                */
  /* ─────────────────────────────────────────── */
  .bonus-page {
    max-width: 54rem;
    margin: 0 auto;
    padding: 1.5rem 0 5rem;
  }

  /* ─────────────────────────────────────────── */
  /* HERO HEADER                                 */
  /* ─────────────────────────────────────────── */
  .bonus-hero {
    margin-bottom: 2.5rem;
  }

  .bonus-eyebrow {
    display: block;
    margin-bottom: 1rem;
  }

  .bonus-title {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .bonus-sub {
    font-size: 0.9375rem;
    opacity: 0.5;
    margin: 0 0 1.75rem;
    max-width: 36rem;
    line-height: 1.6;
  }

  /* Tool pills */
  .tool-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .tool-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .tool-pill-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.6;
  }

  /* ─────────────────────────────────────────── */
  /* SECTION STRUCTURE                           */
  /* ─────────────────────────────────────────── */
  .bonus-section {
    margin-bottom: 3.5rem;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .section-number {
    margin-top: 0.35rem;
    flex-shrink: 0;
  }

  .section-title {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 0.4rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2.5rem;
    height: 1.5px;
    background: linear-gradient(to right, var(--color-accent), transparent);
    opacity: 0.35;
  }

  .section-desc {
    font-size: 0.875rem;
    opacity: 0.55;
    margin: 0;
    line-height: 1.55;
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--color-accent) 20%, transparent) 30%,
      color-mix(in srgb, var(--color-accent) 20%, transparent) 70%,
      transparent
    );
    margin: 3.5rem 0;
  }

  /* ─────────────────────────────────────────── */
  /* CALCULATOR GRID                             */
  /* ─────────────────────────────────────────── */
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 640px) {
    .calc-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Inheriting glass-card from global, adding overrides */
  .calc-card {
    padding: 1.5rem;
    border-radius: 16px !important;
  }

  .calc-card-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .calc-card-caption {
    font-size: 0.8rem;
    opacity: 0.4;
    margin: 0 0 1.5rem;
    letter-spacing: 0.02em;
  }

  .calc-field-group {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .calc-label {
    font-size: 0.8125rem;
    font-weight: 500;
    opacity: 0.8;
  }

  /* Stepper */
  .calc-stepper {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .stepper-btn {
    flex-shrink: 0;
    width: 2.375rem;
    height: 2.375rem;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    color: var(--color-accent);
    font-size: 1.125rem;
    font-weight: 300;
    cursor: pointer;
    transition: all 0.25s var(--ease-out-expo);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stepper-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
    transform: scale(1.05);
  }

  .stepper-btn:active {
    transform: scale(0.95);
  }

  .stepper-input-wrap {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
  }

  .stepper-input {
    width: 100%;
    padding: 0.625rem 2rem 0.625rem 0.875rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    color: inherit;
    font-size: 1.0625rem;
    font-weight: 500;
    font-family: inherit;
    text-align: center;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .stepper-input:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    background: color-mix(in srgb, var(--color-accent) 7%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .stepper-unit {
    position: absolute;
    right: 0.75rem;
    font-size: 0.8rem;
    opacity: 0.4;
    pointer-events: none;
    font-weight: 500;
  }

  .calc-hint {
    font-size: 0.75rem;
    opacity: 0.4;
    margin: 0;
    line-height: 1.4;
  }

  /* Ratio grid */
  .ratio-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
  }

  @media (max-width: 480px) {
    .ratio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ratio-btn {
    padding: 0.625rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);
    border-radius: 10px;
    background: transparent;
    color: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s var(--ease-out-expo);
    opacity: 0.6;
  }

  .ratio-btn:hover {
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    opacity: 1;
  }

  .ratio-btn--active {
    background: var(--color-accent);
    color: var(--color-accent-bg, #0a0a0a);
    border-color: var(--color-accent);
    opacity: 1;
    font-weight: 600;
  }

  .ratio-name {
    font-size: 0.775rem;
    opacity: 0.45;
    margin: 0;
    font-style: italic;
  }

  /* ─────────────────────────────────────────── */
  /* RESULT HERO CARD                            */
  /* ─────────────────────────────────────────── */
  .result-hero-card {
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 20px;
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    padding: 2rem 2.25rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }

  .result-hero-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(
      circle at top right,
      color-mix(in srgb, var(--color-accent) 10%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  .result-hero-inner {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
    position: relative;
  }

  @media (max-width: 560px) {
    .result-hero-inner {
      flex-direction: column;
      gap: 1.25rem;
    }
  }

  .result-hero-left {
    flex-shrink: 0;
  }

  .result-hero-right {
    flex: 1;
    padding-top: 0.25rem;
  }

  .result-hero-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.5;
    margin-bottom: 0.5rem;
  }

  .result-hero-number {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .result-hero-number > span:first-child {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: clamp(3rem, 7vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--color-accent);
  }

  .result-hero-unit {
    font-size: 0.9375rem;
    opacity: 0.5;
  }

  .result-hero-formula {
    font-size: 0.8125rem;
    opacity: 0.35;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.02em;
  }

  .result-meta-item {
    margin-bottom: 1rem;
  }

  .result-meta-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: 0.3rem;
  }

  .result-meta-value {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .result-note {
    font-size: 0.8125rem;
    opacity: 0.5;
    margin: 0;
    line-height: 1.55;
  }

  /* ─────────────────────────────────────────── */
  /* RATIO REFERENCE TABLE                       */
  /* ─────────────────────────────────────────── */
  .ref-section {
    margin-top: 0.5rem;
  }

  .ref-header {
    margin-bottom: 1.25rem;
  }

  .ref-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.3rem;
  }

  .ref-sub {
    font-size: 0.775rem;
    opacity: 0.4;
    margin: 0;
  }

  .ref-table {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .ref-row {
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr 1fr;
    gap: 0.5rem;
    padding: 0.875rem 1.25rem;
    font-size: 0.875rem;
    align-items: center;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    transition: background 0.2s ease;
  }

  .ref-row:last-child {
    border-bottom: none;
  }

  .ref-row:not(.ref-row--head):hover {
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
  }

  .ref-row--head {
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  .ref-row--highlight {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  .ref-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    font-size: 0.7125rem;
    font-weight: 600;
  }

  .ref-badge--ideal {
    background: color-mix(in srgb, var(--color-accent) 22%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    color: var(--color-accent);
  }

  .ref-badge--under {
    background: color-mix(in srgb, #d4a574 10%, transparent);
    border: 1px solid color-mix(in srgb, #d4a574 20%, transparent);
    color: #d4a574;
  }

  .ref-badge--over {
    background: color-mix(in srgb, #8b6f47 10%, transparent);
    border: 1px solid color-mix(in srgb, #8b6f47 18%, transparent);
    color: #b09070;
  }

  .ref-note {
    font-size: 0.725rem;
    opacity: 0.35;
    margin-top: 0.75rem;
  }

  /* ─────────────────────────────────────────── */
  /* SYMPTOM CARDS                               */
  /* ─────────────────────────────────────────── */
  .step-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    opacity: 0.7;
    margin-bottom: 1.5rem;
    display: block;
    letter-spacing: 0.02em;
  }

  .symptom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .symptom-grid {
      grid-template-columns: 1fr;
    }
  }

  .symptom-card {
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-radius: 16px;
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
    cursor: pointer;
    transition: all 0.4s var(--ease-out-expo);
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }

  .symptom-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--color-accent) 6%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-expo);
  }

  .symptom-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 28%, transparent);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .symptom-card:hover::after {
    opacity: 1;
  }

  .symptom-card--balanced {
    border-color: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .symptom-icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s var(--ease-out-expo);
    position: relative;
    z-index: 1;
  }

  .symptom-card:hover .symptom-icon-wrap {
    transform: scale(1.08);
  }

  .symptom-icon-wrap--under {
    background: color-mix(in srgb, #d4a574 12%, transparent);
    border: 1px solid color-mix(in srgb, #d4a574 25%, transparent);
  }

  .symptom-icon-wrap--over {
    background: color-mix(in srgb, #8b6f47 12%, transparent);
    border: 1px solid color-mix(in srgb, #8b6f47 25%, transparent);
  }

  .symptom-icon-wrap--weak {
    background: color-mix(in srgb, #a8956b 10%, transparent);
    border: 1px solid color-mix(in srgb, #a8956b 20%, transparent);
  }

  .symptom-icon-wrap--balanced {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .symptom-arrow {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1;
  }

  .symptom-icon-wrap--under .symptom-arrow { color: #d4a574; }
  .symptom-icon-wrap--over .symptom-arrow { color: #b09070; }
  .symptom-icon-wrap--weak .symptom-arrow { color: #a8956b; }
  .symptom-icon-wrap--balanced .symptom-arrow { color: var(--color-accent); }

  .symptom-body {
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .symptom-name {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }

  .symptom-desc {
    display: block;
    font-size: 0.8rem;
    opacity: 0.55;
    line-height: 1.5;
  }

  .symptom-cta {
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: opacity 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .symptom-card:hover .symptom-cta {
    opacity: 0.7;
  }

  /* ─────────────────────────────────────────── */
  /* DIAGNOSIS PANELS                            */
  /* ─────────────────────────────────────────── */
  .diag-results {
    margin-top: 1.5rem;
  }

  .diag-panel {
    border: 1px solid color-mix(in srgb, var(--color-accent) 16%, transparent);
    border-radius: 20px;
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
    overflow: hidden;
    animation: panelIn 0.5s var(--ease-out-expo) forwards;
  }

  .diag-panel--balanced {
    border-color: color-mix(in srgb, var(--color-accent) 22%, transparent);
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
  }

  @keyframes panelIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .diag-panel-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .diag-panel-header--under {
    background: color-mix(in srgb, #d4a574 6%, transparent);
    border-bottom-color: color-mix(in srgb, #d4a574 12%, transparent);
  }

  .diag-panel-header--over {
    background: color-mix(in srgb, #8b6f47 6%, transparent);
    border-bottom-color: color-mix(in srgb, #8b6f47 12%, transparent);
  }

  .diag-panel-header--weak {
    background: color-mix(in srgb, #a8956b 5%, transparent);
    border-bottom-color: color-mix(in srgb, #a8956b 10%, transparent);
  }

  .diag-panel-header--balanced {
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    border-bottom-color: color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .diag-panel-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 600;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    color: var(--color-accent);
  }

  .diag-panel-icon--balanced {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .diag-panel-header--under .diag-panel-icon {
    background: color-mix(in srgb, #d4a574 14%, transparent);
    border-color: color-mix(in srgb, #d4a574 25%, transparent);
    color: #d4a574;
  }

  .diag-panel-header--over .diag-panel-icon {
    background: color-mix(in srgb, #8b6f47 14%, transparent);
    border-color: color-mix(in srgb, #8b6f47 25%, transparent);
    color: #b09070;
  }

  .diag-panel-header--weak .diag-panel-icon {
    background: color-mix(in srgb, #a8956b 12%, transparent);
    border-color: color-mix(in srgb, #a8956b 22%, transparent);
    color: #a8956b;
  }

  .diag-panel-title {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: 1.375rem;
    font-weight: 400;
    margin: 0 0 0.2rem;
  }

  .diag-panel-sub {
    font-size: 0.8125rem;
    opacity: 0.55;
    margin: 0;
  }

  .diag-panel-body {
    padding: 2rem;
  }

  .diag-explain {
    font-size: 0.9375rem;
    line-height: 1.65;
    opacity: 0.8;
    margin-bottom: 2rem;
  }

  .diag-solutions-title {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-accent);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 1.25rem;
  }

  .diag-solutions {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .diag-solution-item {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    align-items: flex-start;
  }

  .diag-solution-item:last-child {
    border-bottom: none;
  }

  .diag-solution-num {
    flex-shrink: 0;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.6;
    margin-top: 0.1rem;
  }

  .diag-solution-num--balanced {
    border-color: color-mix(in srgb, var(--color-accent) 28%, transparent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    opacity: 0.8;
    font-size: 0.55rem;
  }

  .diag-solution-item > div {
    flex: 1;
  }

  .diag-solution-item strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--color-accent);
  }

  .diag-solution-item span {
    font-size: 0.8375rem;
    opacity: 0.65;
    line-height: 1.55;
  }

  /* Tip block */
  .diag-tip {
    margin-top: 1.5rem;
    padding: 1.125rem 1.375rem;
    border-radius: 12px;
    border-left: 3px solid var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  .diag-tip--balanced {
    border-left-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 7%, transparent);
  }

  .diag-tip-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    opacity: 0.6;
    margin-bottom: 0.4rem;
  }

  .diag-tip p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    opacity: 0.75;
  }

  /* Reset button */
  .reset-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 2rem 2rem;
    padding: 0.625rem 1.125rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);
    border-radius: 10px;
    background: transparent;
    color: var(--color-accent);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s var(--ease-out-expo);
    opacity: 0.65;
  }

  .reset-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    opacity: 1;
    transform: translateX(-3px);
  }

  .reset-btn--balanced {
    opacity: 0.7;
  }

  /* ─────────────────────────────────────────── */
  /* BACK LINK                                   */
  /* ─────────────────────────────────────────── */
  .bonus-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--color-accent);
    opacity: 0.45;
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: all 0.3s var(--ease-out-expo);
  }

  .bonus-back-link:hover {
    opacity: 0.9;
    transform: translateX(-4px);
  }

  .bonus-back-arrow {
    display: inline-block;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .bonus-back-link:hover .bonus-back-arrow {
    transform: translateX(-3px);
  }

  /* ─────────────────────────────────────────── */
  /* RESPONSIVE                                  */
  /* ─────────────────────────────────────────── */
  @media (max-width: 640px) {
    .bonus-page {
      padding: 1rem 0 3rem;
    }

    .section-header {
      gap: 0.875rem;
    }

    .diag-panel-header {
      padding: 1.25rem 1.25rem;
    }

    .diag-panel-body {
      padding: 1.5rem 1.25rem;
    }

    .reset-btn {
      margin: 0 1.25rem 1.5rem;
    }

    .result-hero-card {
      padding: 1.5rem;
    }

    .ref-row {
      grid-template-columns: 0.8fr 1.4fr 0.9fr 1fr;
      font-size: 0.8rem;
      padding: 0.75rem 0.875rem;
    }
  }

  @media (max-width: 420px) {
    .ref-row {
      grid-template-columns: 0.7fr 1.3fr 0.8fr 0.9fr;
      font-size: 0.75rem;
    }

    .bonus-title {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  // ──── CALCULATOR ────
  const doseInput = document.getElementById('dose-input') as HTMLInputElement
  const doseMinus = document.getElementById('dose-minus') as HTMLButtonElement
  const dosePlus = document.getElementById('dose-plus') as HTMLButtonElement
  const ratioButtons = document.querySelectorAll('.ratio-btn') as NodeListOf<HTMLButtonElement>
  const resultYield = document.getElementById('result-yield') as HTMLElement
  const resultFormula = document.getElementById('result-formula') as HTMLElement
  const resultTime = document.getElementById('result-time') as HTMLElement
  const ratioName = document.getElementById('ratio-name') as HTMLElement

  let currentRatio = 2.0

  const ratioLabels: Record<number, { label: string; desc: string }> = {
    1.0: { label: 'Ristretto', desc: 'Intenso, dulce' },
    1.5: { label: 'Ristretto largo', desc: 'Concentrado' },
    2.0: { label: 'Estándar', desc: 'punto de partida universal' },
    2.5: { label: 'Lungo', desc: 'Más suave' },
    3.0: { label: 'Lungo largo', desc: 'Ligero' }
  }

  const ratioTimeRanges: Record<number, string> = {
    1.0: '18–22 seg',
    1.5: '20–28 seg',
    2.0: '25–35 seg',
    2.5: '28–40 seg',
    3.0: '30–45 seg'
  }

  function updateCalculator() {
    const dose = Math.max(7, Math.min(30, parseFloat(doseInput.value) || 18))
    const yieldVal = Math.round(dose * currentRatio * 10) / 10
    resultYield.textContent = yieldVal.toString()
    resultFormula.textContent = `${dose}g × ${currentRatio} = ${yieldVal}g`

    const timeRange = ratioTimeRanges[currentRatio as keyof typeof ratioTimeRanges]
    resultTime.textContent = timeRange || '25–35 seg'
  }

  doseMinus.addEventListener('click', (e) => {
    e.preventDefault()
    const currentVal = parseFloat(doseInput.value) || 18
    const newVal = Math.max(7, currentVal - 1)
    doseInput.value = newVal.toString()
    updateCalculator()
  })

  dosePlus.addEventListener('click', (e) => {
    e.preventDefault()
    const currentVal = parseFloat(doseInput.value) || 18
    const newVal = Math.min(30, currentVal + 1)
    doseInput.value = newVal.toString()
    updateCalculator()
  })

  doseInput.addEventListener('input', () => {
    const val = parseFloat(doseInput.value)
    if (!isNaN(val)) {
      const clamped = Math.max(7, Math.min(30, val))
      if (clamped !== val) {
        doseInput.value = clamped.toString()
      }
    }
    updateCalculator()
  })

  ratioButtons.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault()
      ratioButtons.forEach((b) => b.classList.remove('ratio-btn--active'))
      btn.classList.add('ratio-btn--active')

      const ratioStr = btn.dataset.ratio || '2.0'
      currentRatio = parseFloat(ratioStr)

      const label = ratioLabels[currentRatio as keyof typeof ratioLabels]
      if (label) {
        ratioName.textContent = `${label.label} — ${label.desc}`
      }
      updateCalculator()
    })
  })

  // Inicializar con el valor por defecto
  updateCalculator()

  // ──── FLAVOR DIAGNOSIS ────
  const symptomCards = document.querySelectorAll('.symptom-card') as NodeListOf<HTMLButtonElement>
  const step1 = document.getElementById('step-1') as HTMLElement
  const step2 = document.getElementById('step-2') as HTMLElement
  const resultPanels: Record<string, HTMLElement | null> = {
    under: document.getElementById('result-under'),
    over: document.getElementById('result-over'),
    weak: document.getElementById('result-weak'),
    balanced: document.getElementById('result-balanced')
  }
  const resetButtons = document.querySelectorAll('.reset-btn') as NodeListOf<HTMLButtonElement>

  symptomCards.forEach((card) => {
    card.addEventListener('click', () => {
      const symptom = card.dataset.symptom
      step1.style.display = 'none'
      step2.style.display = 'block'
      Object.keys(resultPanels).forEach((key) => {
        if (resultPanels[key]) {
          resultPanels[key]!.style.display = key === symptom ? 'block' : 'none'
        }
      })
      // Scroll to panel
      setTimeout(() => {
        step2.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }, 50)
    })
  })

  resetButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      step1.style.display = 'block'
      step2.style.display = 'none'
      Object.keys(resultPanels).forEach((key) => {
        if (resultPanels[key]) {
          resultPanels[key]!.style.display = 'none'
        }
      })
    })
  })
</script>
