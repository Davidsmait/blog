<script>
  // ──── CALCULATOR ────
  const doseInput = document.getElementById('dose-input') as HTMLInputElement
  const doseMinus = document.getElementById('dose-minus') as HTMLButtonElement
  const dosePlus = document.getElementById('dose-plus') as HTMLButtonElement
  const ratioButtons = document.querySelectorAll(
    '.ratio-btn'
  ) as NodeListOf<HTMLButtonElement>
  const resultYield = document.getElementById('result-yield') as HTMLElement
  const resultFormula = document.getElementById('result-formula') as HTMLElement
  const resultTime = document.getElementById('result-time') as HTMLElement
  const ratioName = document.getElementById('ratio-name') as HTMLElement

  let currentRatio = 2.0

  const ratioLabels: Record<string, { label: string; desc: string }> = {
    '1.0': { label: 'Ristretto', desc: 'Intenso, dulce' },
    '1.5': { label: 'Ristretto largo', desc: 'Concentrado' },
    '2.0': { label: 'Estándar', desc: 'punto de partida universal' },
    '2.5': { label: 'Lungo', desc: 'Más suave' },
    '3.0': { label: 'Lungo largo', desc: 'Ligero' }
  }

  const ratioTimeRanges: Record<string, string> = {
    '1.0': '18–22 seg',
    '1.5': '20–28 seg',
    '2.0': '25–35 seg',
    '2.5': '28–40 seg',
    '3.0': '30–45 seg'
  }

  function updateCalculator() {
    const dose = parseFloat(doseInput.value) || 18
    const yield_ = Math.round(dose * currentRatio * 10) / 10
    resultYield.textContent = yield_.toString()
    resultFormula.textContent = `${dose}g × ${currentRatio} = ${yield_}g`
    resultTime.textContent =
      ratioTimeRanges[currentRatio.toString()] || '25–35 seg'
  }

  doseMinus.addEventListener('click', () => {
    const val = Math.max(7, parseFloat(doseInput.value) - 1)
    doseInput.value = val.toString()
    updateCalculator()
  })

  dosePlus.addEventListener('click', () => {
    const val = Math.min(30, parseFloat(doseInput.value) + 1)
    doseInput.value = val.toString()
    updateCalculator()
  })

  doseInput.addEventListener('input', updateCalculator)

  ratioButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      ratioButtons.forEach((b) => b.classList.remove('ratio-btn--active'))
      btn.classList.add('ratio-btn--active')
      currentRatio = parseFloat(btn.dataset.ratio || '2.0')
      const label = ratioLabels[currentRatio.toString()]
      ratioName.textContent = `${label.label} — ${label.desc}`
      updateCalculator()
    })
  })

  // ──── FLAVOR DIAGNOSIS ────
  const symptomCards = document.querySelectorAll(
    '.symptom-card'
  ) as NodeListOf<HTMLButtonElement>
  const step1 = document.getElementById('step-1') as HTMLElement
  const step2 = document.getElementById('step-2') as HTMLElement
  const resultPanels: Record<string, HTMLElement | null> = {
    under: document.getElementById('result-under'),
    over: document.getElementById('result-over'),
    weak: document.getElementById('result-weak'),
    balanced: document.getElementById('result-balanced')
  }
  const resetButtons = document.querySelectorAll(
    '.reset-btn'
  ) as NodeListOf<HTMLButtonElement>

  symptomCards.forEach((card) => {
    card.addEventListener('click', () => {
      const symptom = card.dataset.symptom
      step1.style.display = 'none'
      step2.style.display = 'block'

      Object.keys(resultPanels).forEach((key) => {
        if (resultPanels[key]) {
          resultPanels[key].style.display = key === symptom ? 'block' : 'none'
        }
      })
    })
  })

  resetButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      step1.style.display = 'block'
      step2.style.display = 'none'
      Object.keys(resultPanels).forEach((key) => {
        if (resultPanels[key]) {
          resultPanels[key].style.display = 'none'
        }
      })
    })
  })
</script>
