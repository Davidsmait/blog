---
import PageLayout from '../../layouts/PageLayout.astro'
---

<PageLayout
  frontmatter={{
    title: 'Espresso — Bonus: Calculadora y Diagnóstico',
    description:
      'Herramientas prácticas para dominar espresso: calculadora de dosis y yield, diagnóstico interactivo de sabor con soluciones.',
    activeHeaderLink: 'Café'
  }}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'Espresso Bonus — Calculadora y Diagnóstico',
      description:
        'Herramientas para optimizar espresso: calcula yield, diagnostica sabor y obtén soluciones concretas.',
      url: 'https://davidsanluisaguirre.com/cafe/espresso-bonus',
      inLanguage: 'es',
      applicationCategory: 'UtilityApplication',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'MXN' },
      author: { '@id': 'https://davidsanluisaguirre.com/#person' }
    })}
  />

  <div class="bonus-page">
    <!-- Header -->
    <div class="reveal">
      <div class="bonus-header">
        <span class="bonus-label">Bonus — Fase 2: Espresso</span>
        <h1 class="bonus-title">Calculadora y Diagnóstico</h1>
        <p class="bonus-sub">
          Dos herramientas para ajustar tu receta y resolver problemas de sabor
        </p>
      </div>
    </div>

    <div class="hr-animated mb-8 sm:mb-12"></div>

    <!-- ──── SECTION 1: CALCULATOR ──── -->
    <div class="bonus-section reveal" id="calculator-section">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">Calculadora de Dosis y Yield</h2>
        <p class="section-desc">
          Ingresa tu dosis y elige un ratio para calcular el yield objetivo de
          tu espresso
        </p>
      </div>

      <!-- Dose input -->
      <div class="calc-card">
        <div class="calc-card-header">
          <h3 class="calc-card-title">Dosis</h3>
          <span class="calc-card-subtitle">Café seco en el portafiltro</span>
        </div>

        <div class="calc-box">
          <label class="calc-label" for="dose-input">Gramos de café (g)</label>
          <div class="calc-input-row">
            <button class="calc-btn" id="dose-minus" aria-label="Menos"
              >−</button
            >
            <div class="calc-input-wrap">
              <input
                type="number"
                id="dose-input"
                class="calc-input"
                value="18"
                min="7"
                max="30"
              />
              <span class="calc-unit">g</span>
            </div>
            <button class="calc-btn" id="dose-plus" aria-label="Más">+</button>
          </div>
          <p class="calc-hint">Rango habitual: 14–20g para portafiltro doble</p>
        </div>
      </div>

      <!-- Ratio selector -->
      <div class="calc-card">
        <div class="calc-card-header">
          <h3 class="calc-card-title">Ratio</h3>
          <span class="calc-card-subtitle">Proporción café:bebida</span>
        </div>

        <div class="calc-box">
          <label class="calc-label">Selecciona tu ratio objetivo</label>
          <div class="ratio-buttons" id="ratio-buttons">
            <button class="ratio-btn" data-ratio="1.0" data-label="Ristretto"
              >1:1</button
            >
            <button
              class="ratio-btn"
              data-ratio="1.5"
              data-label="Ristretto largo">1:1.5</button
            >
            <button
              class="ratio-btn ratio-btn--active"
              data-ratio="2.0"
              data-label="Estándar">1:2</button
            >
            <button class="ratio-btn" data-ratio="2.5" data-label="Lungo"
              >1:2.5</button
            >
            <button class="ratio-btn" data-ratio="3.0" data-label="Lungo largo"
              >1:3</button
            >
          </div>
          <p class="ratio-name" id="ratio-name">
            Estándar — punto de partida universal
          </p>
        </div>
      </div>

      <!-- Result -->
      <div class="calc-result-card reveal" id="result-card">
        <span class="result-label">Tu yield objetivo</span>
        <div class="result-main">
          <span class="result-number" id="result-yield">36</span>
          <span class="result-unit">g en taza</span>
        </div>
        <div class="result-formula" id="result-formula">18g × 2.0 = 36g</div>
        <div class="result-time">
          <span class="result-time-label">Tiempo esperado:</span>
          <span class="result-time-value" id="result-time">25–35 seg</span>
        </div>
        <p class="result-note" id="result-note">
          Ajusta la molienda hasta llegar a este yield en el tiempo indicado.
        </p>
      </div>

      <!-- Ratio reference -->
      <div class="ref-table-wrap">
        <div class="ref-table-header">
          <h3 class="ref-title">Referencia de ratios</h3>
          <p class="ref-subtitle">Cómo varía el yield según tu ratio elegido</p>
        </div>
        <div class="ref-table">
          <div class="ref-row ref-row--header">
            <span>Ratio</span>
            <span>Nombre</span>
            <span>18g → yield</span>
            <span>Perfil</span>
          </div>
          <div class="ref-row">
            <strong>1:1</strong>
            <span>Ristretto</span>
            <span>18g</span>
            <span class="ref-tag ref-tag--under">Intenso, dulce</span>
          </div>
          <div class="ref-row">
            <strong>1:1.5</strong>
            <span>Ristretto largo</span>
            <span>27g</span>
            <span class="ref-tag ref-tag--under">Concentrado</span>
          </div>
          <div class="ref-row ref-row--highlight">
            <strong>1:2</strong>
            <span>Estándar</span>
            <span>36g</span>
            <span class="ref-tag ref-tag--ideal">Balance</span>
          </div>
          <div class="ref-row">
            <strong>1:2.5</strong>
            <span>Lungo</span>
            <span>45g</span>
            <span class="ref-tag ref-tag--over">Más suave</span>
          </div>
          <div class="ref-row">
            <strong>1:3</strong>
            <span>Lungo largo</span>
            <span>54g</span>
            <span class="ref-tag ref-tag--over">Ligero</span>
          </div>
        </div>
        <p class="ref-note">
          Todos los yields calculados con 18g de dosis base · Tiempo ideal:
          25–35 seg
        </p>
      </div>
    </div>

    <!-- Divider -->
    <div class="section-divider"></div>

    <!-- ──── SECTION 2: FLAVOR DIAGNOSIS ──── -->
    <div class="bonus-section reveal" id="diagnosis-section">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">Diagnóstico de Sabor</h2>
        <p class="section-desc">
          Prueba tu shot, identifica qué sientes y obtén soluciones ordenadas
          por impacto
        </p>
      </div>

      <!-- Step 1: What does it taste like? -->
      <div id="step-1">
        <p class="step-label">
          Paso 1 — Prueba tu shot y elige lo que mejor describe
        </p>

        <div class="symptom-grid">
          <button class="symptom-card" data-symptom="under">
            <span class="symptom-icon">↑</span>
            <span class="symptom-name">Ácido / Agrio</span>
            <span class="symptom-desc"
              >Retrogusto corto, sabor punzante, falta dulzura y cuerpo</span
            >
          </button>

          <button class="symptom-card" data-symptom="over">
            <span class="symptom-icon">↓</span>
            <span class="symptom-name">Amargo / Áspero</span>
            <span class="symptom-desc"
              >Sequedad en boca, astringencia, sabor a ceniza, retrogusto
              desagradable</span
            >
          </button>

          <button class="symptom-card" data-symptom="weak">
            <span class="symptom-icon">−</span>
            <span class="symptom-name">Aguado / Sin cuerpo</span>
            <span class="symptom-desc"
              >Falta intensidad, sabor delgado, parece café de filtro flojo</span
            >
          </button>

          <button class="symptom-card" data-symptom="balanced">
            <span class="symptom-icon">✓</span>
            <span class="symptom-name">Dulce y balanceado</span>
            <span class="symptom-desc"
              >Acidez agradable, dulzura natural, cuerpo presente, retrogusto
              limpio</span
            >
          </button>
        </div>
      </div>

      <!-- Step 2: Diagnosis -->
      <div id="step-2" class="diag-result" style="display:none">
        <!-- Under-extracted -->
        <div id="result-under" class="result-panel" style="display:none">
          <div class="result-header result-header--under">
            <div class="result-icon-box">↑</div>
            <div>
              <h3 class="result-title">Sub-extracción</h3>
              <p class="result-subtitle">
                El agua no extrajo suficientes compuestos del café
              </p>
            </div>
          </div>

          <div class="result-body">
            <p class="result-explain">
              Los ácidos son los primeros compuestos en extraerse. Si paras
              demasiado pronto (o el agua pasa muy rápido), domina la acidez sin
              que llegue la dulzura ni el cuerpo. El resultado: un shot
              punzante, corto, sin balance.
            </p>

            <h4 class="solutions-title">
              Soluciones — de mayor a menor impacto
            </h4>
            <ol class="solutions-list">
              <li>
                <strong>Muele más fino</strong>
                <span
                  >Más resistencia = flujo más lento = más tiempo de contacto =
                  más extracción. Hazlo en incrementos pequeños (1-2 clics).</span
                >
              </li>
              <li>
                <strong>Alarga tu ratio</strong>
                <span
                  >Cambia de 1:2 a 1:2.2 o 1:2.5 — más agua pasa por el café,
                  extrae más compuestos sin cambiar la molienda.</span
                >
              </li>
              <li>
                <strong>Sube la temperatura</strong>
                <span
                  >+1°C puede marcar diferencia. El agua más caliente extrae más
                  rápido. Prueba 93°C → 94°C si tienes PID.</span
                >
              </li>
              <li>
                <strong>Revisa tu distribución</strong>
                <span
                  >Si hay canales (channeling), el agua se escapa por un lado
                  sin extraer uniformemente. Usa WDT.</span
                >
              </li>
            </ol>

            <div class="diag-tip">
              <p>
                <strong>Inicio recomendado:</strong> Empieza siempre por la molienda.
                Es la variable que más impacto tiene y la más fácil de ajustar sin
                tocar receta.
              </p>
            </div>
          </div>

          <button class="reset-btn" id="reset-under">← Probar otro sabor</button
          >
        </div>

        <!-- Over-extracted -->
        <div id="result-over" class="result-panel" style="display:none">
          <div class="result-header result-header--over">
            <div class="result-icon-box">↓</div>
            <div>
              <h3 class="result-title">Sobre-extracción</h3>
              <p class="result-subtitle">
                El agua extrajo demasiado — incluyendo compuestos amargos no
                deseados
              </p>
            </div>
          </div>

          <div class="result-body">
            <p class="result-explain">
              Los compuestos amargos y astringentes son los últimos en
              extraerse. Si el agua contacta el café por demasiado tiempo
              (molienda muy fina o shot muy largo), estos dominan. El resultado:
              boca seca, retrogusto áspero, sabor a ceniza.
            </p>

            <h4 class="solutions-title">
              Soluciones — de mayor a menor impacto
            </h4>
            <ol class="solutions-list">
              <li>
                <strong>Muele más grueso</strong>
                <span
                  >Menos resistencia = flujo más rápido = menos tiempo de
                  contacto = menos extracción. Ajusta 1-2 clics a la vez.</span
                >
              </li>
              <li>
                <strong>Acorta tu ratio</strong>
                <span
                  >Cambia de 1:2 a 1:1.8 o 1:1.5 — menos agua, menos extracción.
                  El shot termina antes de que salgan los amargos.</span
                >
              </li>
              <li>
                <strong>Baja la temperatura</strong>
                <span
                  >-1°C puede suavizar el amargor. Prueba 93°C → 92°C si tienes
                  PID.</span
                >
              </li>
              <li>
                <strong>Revisa si tiras la cola</strong>
                <span
                  >Los últimos segundos del shot (la "cola") son los más
                  amargos. Detén la extracción antes del final para ver si
                  mejora.</span
                >
              </li>
            </ol>

            <div class="diag-tip">
              <p>
                <strong>Inicio recomendado:</strong> Si el shot tarda más de 40 segundos
                para llegar a tu yield, definitivamente la molienda está muy fina.
                Empieza por ahí.
              </p>
            </div>
          </div>

          <button class="reset-btn" id="reset-over">← Probar otro sabor</button>
        </div>

        <!-- Weak -->
        <div id="result-weak" class="result-panel" style="display:none">
          <div class="result-header result-header--weak">
            <div class="result-icon-box">−</div>
            <div>
              <h3 class="result-title">Shot débil o aguado</h3>
              <p class="result-subtitle">
                Falta concentración — ya sea por ratio o por dosis
              </p>
            </div>
          </div>

          <div class="result-body">
            <p class="result-explain">
              Un shot "aguado" que no tiene acidez ni amargor marcados pero
              tampoco dulzura ni cuerpo puede ser un problema de concentración
              (TDS bajo) más que de extracción. El sabor simplemente no llega.
            </p>

            <h4 class="solutions-title">
              Soluciones — de mayor a menor impacto
            </h4>
            <ol class="solutions-list">
              <li>
                <strong>Reduce el ratio</strong>
                <span
                  >Si usas 1:2.5 o más, intenta 1:2. Menos agua = más
                  concentración = más presencia en boca.</span
                >
              </li>
              <li>
                <strong>Aumenta la dosis</strong>
                <span
                  >Más café en el portafiltro (ej: 17g → 18g → 19g) produce un
                  shot más intenso con el mismo ratio.</span
                >
              </li>
              <li>
                <strong>Verifica el tiempo</strong>
                <span
                  >Si el shot termina en menos de 20 segundos, la molienda es
                  muy gruesa — el agua pasa antes de extraer. Muele más fino.</span
                >
              </li>
              <li>
                <strong>Revisa la presión de tu máquina</strong>
                <span
                  >Una máquina con presión baja (menos de 8 bares) no emulsiona
                  bien los aceites. El shot saldrá delgado sin importar la
                  receta.</span
                >
              </li>
            </ol>

            <div class="diag-tip">
              <p>
                <strong>Inicio recomendado:</strong> Prueba primero ajustando el ratio.
                Es rápido y no requiere resetear la máquina.
              </p>
            </div>
          </div>

          <button class="reset-btn" id="reset-weak">← Probar otro sabor</button>
        </div>

        <!-- Balanced -->
        <div id="result-balanced" class="result-panel" style="display:none">
          <div class="result-header result-header--balanced">
            <div class="result-icon-box">✓</div>
            <div>
              <h3 class="result-title">Shot balanceado</h3>
              <p class="result-subtitle">
                Tu extracción está en punto — mantén la consistencia
              </p>
            </div>
          </div>

          <div class="result-body">
            <p class="result-explain">
              Un shot dulce y balanceado significa que tu molienda, dosis,
              temperatura y tiempo están trabajando juntos. Los ácidos agradan,
              el cuerpo es presencia, y el retrogusto es limpio. Este es el
              objetivo.
            </p>

            <h4 class="maintainance-title">Cómo mantener la consistencia</h4>
            <ul class="maintain-list">
              <li>
                <strong>Anota tu receta.</strong> Dosis exacta, ratio, temperatura,
                tiempo. Vuelve a estos números.
              </li>
              <li>
                <strong>Distribución consistente.</strong> Si usas WDT, usa siempre
                la misma técnica y herramienta.
              </li>
              <li>
                <strong>Presión de tamping uniforme.</strong> 13-15 kg (≈30 lbs),
                con nivel. Evita ángulos.
              </li>
              <li>
                <strong>Limpieza regular.</strong> La acumulación de óleos en el portafiltro
                y ducha afecta futuros shots.
              </li>
              <li>
                <strong>Monitorea variables.</strong> A medida que envejece el café
                (1-3 semanas post-roast), puede necesitar ajustes menores de molienda.
              </li>
            </ul>

            <div class="diag-tip">
              <p>
                <strong>Próximo paso:</strong> Ahora experimenta variando una sola
                variable a la vez (ratio, temperatura, café) para descubrir tus preferencias
                personales.
              </p>
            </div>
          </div>

          <button class="reset-btn" id="reset-balanced"
            >← Probar otro sabor</button
          >
        </div>
      </div>
    </div>

    <!-- Back link -->
    <div class="reveal mt-8">
      <a href="/barista-roadmap" class="bonus-back-link">← Volver al roadmap</a>
    </div>
  </div>
</PageLayout>

<style>
  .bonus-page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  /* ── Header ── */
  .bonus-header {
    margin-bottom: 2rem;
  }
  .bonus-label {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.4;
    margin-bottom: 0.75rem;
  }
  .bonus-title {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.15;
    margin: 0;
  }
  .bonus-sub {
    font-size: 0.875rem;
    opacity: 0.4;
    margin-top: 0.5rem;
  }

  /* ── Sections ── */
  .bonus-section {
    margin-bottom: 3rem;
  }

  .section-header {
    margin-bottom: 2rem;
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .section-number {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.3;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .section-header > div {
    flex: 1;
  }

  .section-title {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .section-desc {
    font-size: 0.875rem;
    opacity: 0.6;
    margin: 0;
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      var(--color-accent),
      var(--color-accent) 30%,
      transparent 100%
    );
    opacity: 0.2;
    margin: 3rem 0;
  }

  /* ── Calculator ── */
  .calc-card {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
  }

  .calc-card-header {
    margin-bottom: 1.25rem;
  }
  .calc-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-accent);
  }
  .calc-card-subtitle {
    display: block;
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0.5;
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .calc-box {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .calc-label {
    font-size: 0.875rem;
    font-weight: 500;
    display: block;
  }

  .calc-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .calc-btn {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--color-accent);
    font-size: 1.25rem;
    font-weight: 300;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }
  .calc-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .calc-input-wrap {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
  }

  .calc-input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--color-accent);
    border-radius: 0.375rem;
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    color: inherit;
    font-size: 1rem;
    font-family: inherit;
  }
  .calc-input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .calc-unit {
    position: absolute;
    right: 0.75rem;
    font-size: 0.875rem;
    opacity: 0.5;
    pointer-events: none;
  }

  .calc-hint {
    font-size: 0.8rem;
    opacity: 0.5;
    margin: 0;
  }

  .ratio-buttons {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(6rem, 1fr));
    gap: 0.75rem;
  }

  .ratio-btn {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-accent);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }
  .ratio-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  .ratio-btn--active {
    background: var(--color-accent);
    color: var(--bg-primary);
    border-color: var(--color-accent);
  }

  .ratio-name {
    font-size: 0.8rem;
    opacity: 0.5;
    margin: 0.5rem 0 0;
  }

  .calc-result-card {
    margin-top: 2rem;
    padding: 2rem;
    border: 2px solid var(--color-accent);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .result-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .result-main {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .result-number {
