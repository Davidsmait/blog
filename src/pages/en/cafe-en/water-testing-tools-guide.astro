    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    flex-shrink: 0;
  }
  .gate-lesson--done .gate-check {
    background: color-mix(in srgb, #43a047 15%, transparent);
    border-color: color-mix(in srgb, #43a047 30%, transparent);
    color: #43a047;
  }
  .gate-btn {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.625rem 1.5rem;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    color: inherit;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .gate-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    transform: translateY(-1px);
  }

  /* ── Main container ── */
  .guide-main {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Context card ── */
  .context-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 8%, transparent);
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
  }
  .context-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .context-title {
    font-weight: 600;
    font-size: 0.9375rem;
    margin: 0 0 0.375rem;
    opacity: 0.8;
  }
  .context-text {
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0;
    opacity: 0.5;
  }
  .context-text strong {
    opacity: 1;
    font-weight: 600;
  }

  /* ── Section titles ── */
  .section-title {
    font-size: 1.375rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.25;
  }
  .section-note {
    font-size: 0.8125rem;
    opacity: 0.35;
    margin-bottom: 1.5rem;
  }

  /* ── Tab navigation ── */
  .tab-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .tab-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    border-radius: 0.75rem;
    background: transparent;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    color: inherit;
  }
  .tab-btn:hover {
    border-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
    transform: translateY(-2px);
  }
  .tab-btn.active {
    border-color: color-mix(in srgb, var(--color-accent) 25%, transparent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    box-shadow: 0 4px 20px
      color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .tab-icon {
    font-size: 1.25rem;
  }
  .tab-label {
    font-size: 0.8125rem;
    font-weight: 600;
    opacity: 0.7;
  }
  .tab-sub {
    font-size: 0.6875rem;
    opacity: 0.35;
  }
  .tab-btn.active .tab-label {
    opacity: 1;
  }
  .tab-btn.active .tab-sub {
    opacity: 0.55;
  }

  /* ── Tab panels ── */
  .tab-panel {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tab-panel:not(.active) {
    display: none;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Info grid ── */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .info-grid.two-col {
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 580px) {
    .info-grid.two-col {
      grid-template-columns: 1fr;
    }
  }

  .info-card {
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
  }
  .info-card.single-card {
    margin-bottom: 1.5rem;
  }
  .info-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }
  .badge-gh {
    background: color-mix(in srgb, #5ab569 20%, transparent);
    color: #5ab569;
  }
  .badge-kh {
    background: color-mix(in srgb, #4a90d9 20%, transparent);
    color: #4a90d9;
  }
  .info-label {
    font-weight: 600;
    font-size: 0.9375rem;
    margin: 0 0 0.375rem;
    opacity: 0.7;
  }
  .info-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    margin: 0;
    opacity: 0.5;
  }
  .info-desc strong {
    opacity: 1;
    font-weight: 600;
  }
  .info-detail {
    font-size: 0.8125rem;
    line-height: 1.7;
    margin: 0.5rem 0 0;
    opacity: 0.4;
  }
  .info-target {
    font-size: 0.8125rem;
    margin: 0.75rem 0 0;
    opacity: 0.55;
  }

  /* ── TDS Range visual ── */
  .range-visual {
    margin-top: 1rem;
  }
  .range-bar {
    display: flex;
    border-radius: 4px;
    overflow: hidden;
    height: 24px;
  }
  .range-zone {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .range-low {
    background: color-mix(in srgb, #e53935 15%, transparent);
  }
  .range-ideal {
    background: color-mix(in srgb, #43a047 15%, transparent);
  }
  .range-ok {
    background: color-mix(in srgb, #ff8f00 12%, transparent);
  }
  .range-high {
    background: color-mix(in srgb, #e53935 12%, transparent);
  }
  .range-text {
    opacity: 0.7;
  }
  .range-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.5625rem;
    opacity: 0.35;
    margin-top: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .range-ideal-label {
    color: #43a047;
    opacity: 0.7;
    font-weight: 600;
  }

  /* ── pH Scale ── */
  .ph-scale {
    margin-top: 1rem;
    position: relative;
  }
  .ph-gradient {
    height: 20px;
    border-radius: 4px;
    background: linear-gradient(
      to right,
      #e53935,
      #ff8f00,
      #c0ca33,
      #43a047,
      #1565c0,
      #7b1fa2
    );
  }
  .ph-marker {
    position: absolute;
    top: 0;
    width: 2px;
    height: 20px;
    background: var(--color-accent);
    opacity: 0.8;
  }
  .ph-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.5625rem;
    opacity: 0.35;
    margin-top: 0.375rem;
  }
  .ph-ideal-label {
    text-align: center;
    font-size: 0.625rem;
    font-weight: 600;
    opacity: 0.55;
    margin-top: 0.25rem;
  }

  /* ── Steps timeline ── */
  .steps-timeline {
    position: relative;
    padding-left: 2.5rem;
    margin-bottom: 1.5rem;
  }
  .steps-timeline::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    top: 0.25rem;
    bottom: 0.25rem;
    width: 1px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  .step-item {
    position: relative;
    margin-bottom: 1.75rem;
  }
  .step-item:last-child {
    margin-bottom: 0;
  }
  .step-number {
    position: absolute;
    left: -2.5rem;
    top: 0;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    color: inherit;
    opacity: 0.6;
  }
  .step-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
    line-height: 1.3;
    opacity: 0.8;
  }
  .step-content p {
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0 0 0.5rem;
    opacity: 0.5;
  }
  .step-content p strong {
    opacity: 1;
    font-weight: 600;
  }

  /* ── Color indicators ── */
  .color-indicator {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0.5rem 0;
    font-size: 0.8125rem;
    opacity: 0.6;
  }
  .color-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  /* ── Media placeholders ── */
  .media-placeholder {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    border: 1.5px dashed
      color-mix(in srgb, var(--color-accent) 10%, transparent);
    background: color-mix(in srgb, var(--color-accent) 1.5%, transparent);
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    opacity: 0.4;
    transition:
      opacity 0.3s ease,
      border-color 0.3s ease;
  }
  .media-placeholder:hover {
    opacity: 0.6;
    border-color: color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
  .placeholder-icon {
    font-size: 1.25rem;
  }

  /* ── Calculator ── */
  .calc-box {
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 8%, transparent);
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
    margin-top: 0.75rem;
  }
  .calc-label {
    font-size: 0.8125rem;
    font-weight: 500;
    opacity: 0.5;
    display: block;
    margin-bottom: 0.75rem;
  }
  .calc-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .calc-btn {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    cursor: pointer;
    font-size: 1.125rem;
    font-weight: 500;
    color: inherit;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .calc-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    transform: scale(1.1);
  }
  .calc-btn:active {
    transform: scale(0.95);
  }
  .calc-input {
    width: 3.5rem;
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    background: transparent;
    border: none;
    color: inherit;
    -moz-appearance: textfield;
  }
  .calc-input::-webkit-outer-spin-button,
  .calc-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .calc-result {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .calc-ppm {
    font-size: 1.25rem;
    font-weight: 700;
    opacity: 0.8;
  }
  .calc-verdict {
    font-size: 0.8125rem;
    opacity: 0.55;
    transition: color 0.3s ease;
  }
  .verdict-good {
    color: #43a047;
    opacity: 0.8;
  }
  .verdict-warn {
    color: #ff8f00;
    opacity: 0.8;
  }

  /* ── Conversion card ── */
  .conversion-card {
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 8%, transparent);
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
    margin-bottom: 2rem;
    text-align: center;
  }
  .conversion-title {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.35;
    margin: 0 0 0.375rem;
    font-weight: 600;
  }
  .conversion-formula {
    font-size: 1.125rem;
    margin: 0 0 0.25rem;
    opacity: 0.7;
  }
  .conversion-formula strong {
    opacity: 1;
    font-weight: 700;
  }
  .conversion-example {
    font-size: 0.8125rem;
    opacity: 0.35;
    margin: 0;
  }

  /* ── Tip box ── */
  .tip-box {
    padding: 1rem 1.25rem;
    border-left: 2px solid
      color-mix(in srgb, var(--color-accent) 15%, transparent);
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
    border-radius: 0 8px 8px 0;
    margin-top: 2rem;
  }
  .tip-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    opacity: 0.45;
    display: block;
    margin-bottom: 0.375rem;
  }
  .tip-box p {
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0;
    opacity: 0.5;
  }
  .tip-box p strong {
    opacity: 1;
    font-weight: 600;
  }

  /* ── pH color guide ── */
  .ph-color-guide {
    margin: 1.5rem 0 2rem;
  }
  .ph-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-accent) 4%, transparent);
  }
  .ph-row.ideal {
    background: color-mix(in srgb, #43a047 4%, transparent);
    border-radius: 6px;
    padding: 0.625rem 0.75rem;
    margin: 0.25rem -0.75rem;
  }
  .ph-color-strip {
    width: 3rem;
    height: 1.125rem;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .ph-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .ph-range {
    font-size: 0.75rem;
    font-weight: 700;
    opacity: 0.6;
  }
  .ph-name {
    font-size: 0.8125rem;
    font-weight: 500;
    opacity: 0.7;
  }
  .ph-example {
    font-size: 0.6875rem;
    opacity: 0.35;
  }

  /* ── Exercise ── */
  .exercise-steps {
    margin: 1.5rem 0;
  }
  .exercise-step {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .exercise-num {
    font-size: 0.75rem;
    font-weight: 700;
    opacity: 0.2;
    font-family: ui-monospace, monospace;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  .exercise-step h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
    opacity: 0.8;
  }
  .exercise-step p {
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0;
    opacity: 0.5;
  }
  .exercise-step p strong {
    opacity: 1;
    font-weight: 600;
  }

  /* ── Table ── */
  .table-wrapper {
    overflow-x: auto;
    margin: 1rem 0 2rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .water-table {
    width: 100%;
    font-size: 0.875rem;
    border-collapse: collapse;
  }
  .water-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    opacity: 0.4;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-accent) 6%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .water-table td {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-accent) 4%, transparent);
    opacity: 0.65;
  }
  .water-table td strong {
    opacity: 1;
    font-weight: 600;
  }
  .editable {
    min-width: 60px;
    cursor: text;
    transition: background 0.3s ease;
    border-radius: 4px;
  }
  .editable:focus {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    outline: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    outline-offset: -1px;
  }
  .editable:empty::before {
    content: attr(data-placeholder);
    opacity: 0.3;
  }

  /* ── Reference grid ── */
  .reference-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  @media (max-width: 580px) {
    .reference-grid {
      grid-template-columns: 1fr;
    }
  }
  .ref-card {
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
  }
  .ref-card h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    opacity: 0.5;
    margin: 0 0 0.75rem;
  }
  .ref-item {
    display: flex;
    justify-content: space-between;
    padding: 0.375rem 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-accent) 4%, transparent);
    font-size: 0.8125rem;
  }
  .ref-item:last-child {
    border-bottom: none;
  }
  .ref-item span {
    opacity: 0.45;
  }
  .ref-item strong {
    font-weight: 600;
    opacity: 0.7;
  }

  /* ── Navigation ── */
  .guide-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .guide-nav {
      grid-template-columns: 1fr;
    }
  }
  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    border-radius: 0.75rem;
    background: transparent;
    transition:
      border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover {
    border-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px
      color-mix(in srgb, var(--color-accent) 4%, transparent);
  }
  .nav-link--prev::before {
    content: '←';
    font-size: 0.75rem;
    opacity: 0.25;
  }
  .nav-link--next {
    text-align: right;
    align-items: flex-end;
  }
  .nav-link--next::after {
    content: '→';
    font-size: 0.75rem;
    opacity: 0.25;
  }
  .nav-direction {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.3;
  }
  .nav-title {
    font-size: 0.9375rem;
    font-weight: 500;
    opacity: 0.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .nav-link:hover .nav-title {
    opacity: 1;
    color: var(--color-accent);
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 2rem;
    gap: 1rem;
  }
  .lightbox--open {
    opacity: 1;
    pointer-events: all;
  }
  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 2rem;
    cursor: pointer;
    transition: color 0.2s ease;
    line-height: 1;
    padding: 0.25rem;
  }
  .lightbox-close:hover {
    color: rgba(255, 255, 255, 0.9);
  }
  .lightbox-img {
    max-width: min(90vw, 800px);
    max-height: 80vh;
    object-fit: contain;
    border-radius: 0.5rem;
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .lightbox--open .lightbox-img {
    transform: scale(1);
  }
  .lightbox-caption {
