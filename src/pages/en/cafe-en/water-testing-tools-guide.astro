---
import Footer from '@/components/layout/Footer.astro'
import Header from '@/components/layout/Header.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import ScrollProgressPlugin from '@/plugins/ScrollProgressPlugin.astro'

const frontmatter = {
  title: 'Interactive guide: Water testing tools',
  description:
    'Learn to use your digital pH/TDS/EC meter and API GH & KH kit to optimize your specialty coffee water.'
}
---

<BaseLayout frontmatter={frontmatter}>
  <div id="page-wrapper" class="noise-overlay">
    <div class="px-5 sm:px-6 lg:px-0">
      <Header activeHeaderLink="Coffee" />

      <main class="guide-main mt-8 sm:mt-14">
        <!-- Breadcrumb -->
        <div class="reveal mb-8 sm:mb-12">
          <div
            class="flex flex-wrap items-center gap-3 text-[11px] font-medium uppercase tracking-[0.15em] opacity-20"
          >
            <a
              href="/en/barista-roadmap"
              class="no-underline opacity-70 transition-opacity duration-300 hover:opacity-100"
              >Roadmap</a
            >
            <span class="h-[1px] w-4 bg-accent/10"></span>
            <span>Phase 1: Fundamentals</span>
            <span class="h-[1px] w-4 bg-accent/10"></span>
            <span>Practical guide</span>
          </div>
        </div>

        <!-- Title -->
        <div class="reveal mb-4">
          <h1
            class="m-0 font-display text-[clamp(1.8rem,5vw,3rem)] font-bold leading-[1.1] tracking-tighter-brand text-accent sm:text-[clamp(2rem,4vw,3.5rem)]"
          >
            Water testing tools
          </h1>
        </div>

        <!-- Subtitle -->
        <div class="reveal mb-6">
          <p
            class="m-0 max-w-xl text-[15px] leading-[1.7] opacity-35 sm:text-base"
          >
            Step-by-step guide for the digital pH/TDS/EC meter and the API GH &
            KH test kit. Practical companion to Lesson 1.4: Water.
          </p>
        </div>

        <!-- Unlock gate (hidden via JS if lessons complete) -->
        <div class="reveal mb-8" id="unlock-gate">
          <div class="gate-card">
            <div class="gate-icon">
              <svg
                viewBox="0 0 16 16"
                fill="currentColor"
                width="28"
                height="28"
                style="opacity:0.3"
              >
                <path
                  d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z"
                ></path>
              </svg>
            </div>
            <p class="gate-title">Bonus content locked</p>
            <p class="gate-text">
              This guide unlocks after completing all 4 lessons in Phase 1:
              Coffee Fundamentals.
            </p>
            <div class="gate-progress">
              <div class="gate-lessons" id="gate-lessons-list"></div>
            </div>
            <a href="/en/barista-roadmap" class="gate-btn" data-cursor-hover
              >Go to roadmap →</a
            >
          </div>
        </div>

        <!-- Guide content (hidden until unlocked) -->
        <div id="guide-content" style="display:none">
          <!-- Quick context -->
          <div class="reveal mb-8">
            <div class="context-card">
              <div class="context-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg></div>
              <div>
                <p class="context-title">Why test your water?</p>
                <p class="context-text">
                  Your coffee is 98% water. Its mineral composition determines
                  how flavors are extracted. The digital meter tells you how
                  many minerals are present; the API kit tells you which ones
                  they are. Together they give you the complete picture.
                </p>
              </div>
            </div>
          </div>

          <div class="hr-animated mb-8 sm:mb-12"></div>

          <!-- ═══ TAB NAVIGATION ═══ -->
          <div class="reveal" id="tool-tabs">
            <div class="tab-nav" role="tablist" aria-label="Tool selection">
              <button
                role="tab"
                aria-selected="true"
                aria-controls="panel-digital"
                id="tab-digital"
                class="tab-btn active"
                data-tab="digital"
              >
                <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></span>
                <span class="tab-label">Digital Meter</span>
                <span class="tab-sub">pH / TDS / EC</span>
              </button>
              <button
                role="tab"
                aria-selected="false"
                aria-controls="panel-api"
                id="tab-api"
                class="tab-btn"
                data-tab="api"
              >
                <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v8l4 7H5l4-7V3z"/><line x1="9" y1="3" x2="15" y2="3"/></svg></span>
                <span class="tab-label">Kit API</span>
                <span class="tab-sub">GH & KH</span>
              </button>
              <button
                role="tab"
                aria-selected="false"
                aria-controls="panel-strips"
                id="tab-strips"
                class="tab-btn"
                data-tab="strips"
              >
                <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></span>
                <span class="tab-label">pH Strips</span>
                <span class="tab-sub">Indicator paper</span>
              </button>
            </div>

            <!-- ═══ PANEL: Digital Meter ═══ -->
            <div
              role="tabpanel"
              id="panel-digital"
              aria-labelledby="tab-digital"
              class="tab-panel active"
            >
              <!-- What it measures -->
              <div class="info-grid">
                <div class="info-card">
                  <div class="info-badge">TDS</div>
                  <p class="info-label">Total Dissolved Solids</p>
                  <p class="info-desc">
                    How many minerals your water has in ppm. <strong
                      >This is the most important measurement for coffee.</strong>
                  </p>
                  <div class="range-visual">
                    <div class="range-bar">
                      <div class="range-zone range-low" style="width:30%">
                        <span class="range-text"><75</span>
                      </div>
                      <div class="range-zone range-ideal" style="width:30%">
                        <span class="range-text">75-150</span>
                      </div>
                      <div class="range-zone range-ok" style="width:20%">
                        <span class="range-text">150-250</span>
                      </div>
                      <div class="range-zone range-high" style="width:20%">
                        <span class="range-text">&gt;250</span>
                      </div>
                    </div>
                    <div class="range-labels">
                      <span>Too soft</span>
                      <span class="range-ideal-label">Ideal ✓</span>
                      <span>Acceptable</span>
                      <span>Hard</span>
                    </div>
                  </div>
                </div>
                <div class="info-card">
                  <div class="info-badge">pH</div>
                  <p class="info-label">Acidity / Alkalinity</p>
                  <p class="info-desc">
                    SCA recommends water between <strong>6.5 and 7.5</strong> for
                    coffee.
                  </p>
                  <div class="ph-scale">
                    <div class="ph-gradient"></div>
                    <div class="ph-marker" style="left: 46.4%"></div>
                    <div class="ph-marker" style="left: 53.6%"></div>
                    <div class="ph-labels">
                      <span>0 Acidic</span>
                      <span>7 Neutral</span>
                      <span>14 Alkaline</span>
                    </div>
                    <div class="ph-ideal-label">6.5 — 7.5 ideal</div>
                  </div>
                </div>
                <div class="info-card">
                  <div class="info-badge">EC</div>
                  <p class="info-label">Electrical Conductivity</p>
                  <p class="info-desc">
                    Measures the same as TDS but in µS/cm. For coffee, <strong
                      >focus on the TDS reading</strong
                    > directly.
                  </p>
                </div>
              </div>

              <!-- Steps -->
              <h2 class="section-title">Calibration (first time only)</h2>
              <p class="section-note">
                Repeat every 2-3 weeks or if readings seem off.
              </p>

              <div class="steps-timeline">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Prepare the buffer solution</h3>
                    <p>
                      Dissolve the <strong>pH 6.86</strong> powder packet in a glass
                      with distilled water (~250ml). Stir until completely dissolved.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Submerge the electrode</h3>
                    <p>
                      Turn on the meter, submerge the tip in the buffer
                      solution. Wait a few seconds for the reading to stabilize.
                    </p>
                    <figure class="step-photo">
                      <picture>
                        <source srcset="/images/water-guide/ph-calibration-686.webp" type="image/webp">
                        <img src="/images/water-guide/ph-calibration-686.jpg" alt="pH pen submerged in 6.86 buffer solution, showing reading on screen" loading="lazy" width="900" height="1200">
                      </picture>
                      <figcaption>Calibrating with pH 6.86 buffer solution — reference packet visible alongside</figcaption>
                    </figure>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Press CAL</h3>
                    <p>
                      Hold down the <strong>"CAL"</strong> button for 5 seconds. The
                      number will flash and then stabilize — that means it calibrated.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Repite con pH 4.01</h3>
                    <p>
                      Rinse the tip with distilled water, then repeat the
                      process with the <strong>pH 4.01</strong> packet. With two calibration
                      points your meter is accurate across the entire range.
                    </p>
                    <figure class="step-photo">
                      <picture>
                        <source srcset="/images/water-guide/ph-calibration-400.webp" type="image/webp">
                        <img src="/images/water-guide/ph-calibration-400.jpg" alt="pH pen calibrating in 4.00 buffer solution, green screen reading" loading="lazy" width="900" height="1200">
                      </picture>
                      <figcaption>Second calibration point: pH 4.00 buffer solution</figcaption>
                    </figure>
                  </div>
                </div>
              </div>

              <h2 class="section-title">How to measure your water</h2>

              <div class="steps-timeline">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Sirve el agua en un vaso limpio</h3>
                    <p>
                      Use the water you want to measure: tap, jug, bottled. <strong
                        >Don't use the same glass</strong
                      > — rinse it between mediciones o usa vasos separados.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Enciende y sumerge</h3>
                    <p>
                      Turn on the meter, submerge the tip in the water. Gently
                      move it in circles 2-3 times to remove air aire.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Espera ~30 segundos</h3>
                    <p>
                      Let the number stabilize. When it stops moving, that's
                      your reading. You can press <strong>"HOLD"</strong> to lock
                      the number on the screen.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Anota en tu cuaderno</h3>
                    <p>
                      Registra: tipo de agua, TDS (ppm), pH, y fecha. Con el
                      tiempo vas a tener un historial que te ayuda a elegir tu
                      agua ideal.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">5</div>
                  <div class="step-content">
                    <h3>Enjuaga entre mediciones</h3>
                    <p>
                      Moja la punta con agua destilada antes de medir otra agua
                      diferente. Esto evita contaminar la lectura.
                    </p>
                  </div>
                </div>
              </div>

              <div class="tip-box">
                <span class="tip-label">Tip</span>
                <p>
                  TDS <strong>doesn't require calibration</strong> — it comes factory
                  calibrated. Only pH requires calibration with thelvos buffer.
                </p>
              </div>
            </div>

            <!-- ═══ PANEL: API GH & KH Kit ═══ -->
            <div
              role="tabpanel"
              id="panel-api"
              aria-labelledby="tab-api"
              class="tab-panel"
              hidden
            >
              <div class="info-grid two-col">
                <div class="info-card">
                  <div class="info-badge badge-gh">GH</div>
                  <p class="info-label">General Hardness (General Hardness)</p>
                  <p class="info-desc">
                    Measures the <strong>calcium + magnesium</strong> in your water.
                    They're the "extractors": the minerals that unlock the coffee's
                    flavor compounds.
                  </p>
                  <p class="info-detail">
                    More magnesium → brighter, more acidic coffee<br />More
                    calcium → rounder, fuller-bodied coffee
                  </p>
                  <p class="info-target">
                    SCA recommends: <strong>50-175 ppm</strong>
                  </p>
                </div>
                <div class="info-card">
                  <div class="info-badge badge-kh">KH</div>
                  <p class="info-label">Carbonate Hardness (Alkalinity)</p>
                  <p class="info-desc">
                    Measures the <strong>bicarbonates</strong> in your water. They
                    work like a "volume control" for the coffee's acidity.
                  </p>
                  <p class="info-detail">
                    Low KH → aggressive acidity<br />High KH → flat, lifeless
                    coffee
                  </p>
                  <p class="info-target">
                    SCA recommends: <strong>40-70 ppm</strong>
                  </p>
                </div>
              </div>

              <figure class="step-photo step-photo--wide">
                <picture>
                  <source srcset="/images/water-guide/api-kit-overview.webp" type="image/webp">
                  <img src="/images/water-guide/api-kit-overview.jpg" alt="API GH & KH kit: KH reagent bottle and test tube, with SCA standards chalkboard in background" loading="lazy" width="900" height="1200">
                </picture>
                <figcaption>KH reagent bottle and test tube from the API kit, with SCA standards noted on the chalkboard</figcaption>
              </figure>

              <!-- Conversion callout -->
              <div class="conversion-card">
                <p class="conversion-title">Conversion</p>
                <p class="conversion-formula">
                  Cada gota = 1 dGH (o dKH) = <strong>17.9 ppm</strong>
                </p>
                <p class="conversion-example">
                  Ejemplo: 4 gotas × 17.9 = 71.6 ppm
                </p>
              </div>

              <!-- KH Test -->
              <h2 class="section-title">Test KH (Alkalinity)</h2>
              <p class="section-note">Cambio de color: blue → yellow</p>

              <div class="steps-timeline kh-steps">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Llena el tubo</h3>
                    <p>
                      Use the glass tube from the kit. Fill it with <strong
                        >5 ml</strong
                      > of your water (up to the marked line).
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Agrega 1 gota del reactivo KH</h3>
                    <p>
                      Hold the KH reagent bottle vertically and add <strong
                        >one drop only</strong
                      >.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Tapa e invierte</h3>
                    <p>
                      Cap the tube and <strong>flip it several times</strong> to mix
                      well. Observe the color.
                    </p>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #4a90d9"></div>
                      <span>Still blue? → Add another drop</span>
                    </div>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #d4c94a"></div>
                      <span>Turned yellow? → Stop! Count the drops</span>
                    </div>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Repite gota a gota</h3>
                    <p>
                      Keep adding drops one at a time, shaking after each one,
                      until the water changes from <strong
                        >blue to yellowo</strong
                      >.
                    </p>
                    <div class="photo-comparison">
                      <figure class="step-photo step-photo--half">
                        <picture>
                          <source srcset="/images/water-guide/kh-test-blue-start.webp" type="image/webp">
                          <img src="/images/water-guide/kh-test-blue-start.jpg" alt="KH test tube with blue water at start of test" loading="lazy" width="900" height="1200">
                        </picture>
                        <figcaption>Start: blue</figcaption>
                      </figure>
                      <figure class="step-photo step-photo--half">
                        <picture>
                          <source srcset="/images/water-guide/kh-test-yellow-end.webp" type="image/webp">
                          <img src="/images/water-guide/kh-test-yellow-end.jpg" alt="KH test tube with yellow water at end of test — 6 drops" loading="lazy" width="900" height="1200">
                        </picture>
                        <figcaption>Drop 6: yellow — done!</figcaption>
                      </figure>
                    </div>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">5</div>
                  <div class="step-content">
                    <h3>Calculate your result</h3>
                    <p>Number of drops × 17.9 = your KH in ppm</p>
                    <!-- Interactive calculator -->
                    <div class="calc-box" id="calc-kh">
                      <label class="calc-label" for="kh-drops"
                        >How many drops did you use?</label
                      >
                      <div class="calc-input-row">
                        <button
                          class="calc-btn minus"
                          data-calc="kh"
                          data-action="minus"
                          aria-label="Less">−</button
                        >
                        <input
                          type="number"
                          id="kh-drops"
                          class="calc-input"
                          value="0"
                          min="0"
                          max="30"
                          readonly
                        />
                        <button
                          class="calc-btn plus"
                          data-calc="kh"
                          data-action="plus"
                          aria-label="More">+</button
                        >
                      </div>
                      <div class="calc-result" id="kh-result">
                        <span class="calc-ppm">0 ppm</span>
                        <span class="calc-verdict" id="kh-verdict"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- GH Test -->
              <h2 class="section-title">Test GH (General Hardness)</h2>
              <p class="section-note">Cambio de color: orange → green</p>

              <div class="steps-timeline gh-steps">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Clean tube with fresh water</h3>
                    <p>
                      Rinse the tube and fill it with <strong
                        >5 ml of fresh water</strong
                      > (don't reuse water from the KH test).
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Agrega 1 gota del reactivo GH</h3>
                    <p>
                      Usa el frasco de reactivo <strong>GH</strong> (diferente al
                      de KH). Agrega una gota.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">3</div>
                  <div class="step-content">
                    <h3>Tapa, invierte, observa</h3>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #d98a4a"></div>
                      <span>Still orange? → Add another drop</span>
                    </div>
                    <div class="color-indicator">
                      <div class="color-dot" style="background: #5ab569"></div>
                      <span>Turned green? → Stop! Count the drops</span>
                    </div>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">4</div>
                  <div class="step-content">
                    <h3>Repite gota a gota hasta verde</h3>
                    <figure class="step-photo">
                      <picture>
                        <source srcset="/images/water-guide/gh-test-green-end.webp" type="image/webp">
                        <img src="/images/water-guide/gh-test-green-end.jpg" alt="GH test tube with green water at end of test — 7 drops" loading="lazy" width="900" height="1200">
                      </picture>
                      <figcaption>Drop 7: green — 7 × 17.9 = 125.3 ppm general hardness</figcaption>
                    </figure>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">5</div>
                  <div class="step-content">
                    <h3>Calculate your result</h3>
                    <p>Number of drops × 17.9 = your GH in ppm</p>
                    <div class="calc-box" id="calc-gh">
                      <label class="calc-label" for="gh-drops"
                        >How many drops did you use?</label
                      >
                      <div class="calc-input-row">
                        <button
                          class="calc-btn minus"
                          data-calc="gh"
                          data-action="minus"
                          aria-label="Less">−</button
                        >
                        <input
                          type="number"
                          id="gh-drops"
                          class="calc-input"
                          value="0"
                          min="0"
                          max="30"
                          readonly
                        />
                        <button
                          class="calc-btn plus"
                          data-calc="gh"
                          data-action="plus"
                          aria-label="More">+</button
                        >
                      </div>
                      <div class="calc-result" id="gh-result">
                        <span class="calc-ppm">0 ppm</span>
                        <span class="calc-verdict" id="gh-verdict"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="tip-box">
                <span class="tip-label">Ojo</span>
                <p>
                  If the <strong
                    >very first drop already changes the color</strong
                  >, your water has very low hardness. This is common in reverse
                  osmosis jugs and means your water lacks enough minerals to
                  properly extract the coffee's flavors.
                </p>
              </div>
            </div>

            <!-- ═══ PANEL: pH Strips ═══ -->
            <div
              role="tabpanel"
              id="panel-strips"
              aria-labelledby="tab-strips"
              class="tab-panel"
              hidden
            >
              <div class="info-card single-card">
                <p class="info-label">What are they?</p>
                <p class="info-desc">
                  Paper impregnated with chemical indicators that change color
                  based on the liquid's pH. It's a quick, analog way to measure
                  pH — less accurate than the digital meter (±0.5 vs ±0.01), but
                  useful as a quick check.
                </p>
              </div>

              <h2 class="section-title">How to use them</h2>

              <div class="steps-timeline">
                <div class="step-item">
                  <div class="step-number">1</div>
                  <div class="step-content">
                    <h3>Arranca una tirita</h3>
                    <p>
                      Separa una tira del bloque de papel. Sostenla por un
                      extremo sin tocar la zona que vas a sumergir.
                    </p>
                  </div>
                </div>
                <div class="step-item">
                  <div class="step-number">2</div>
                  <div class="step-content">
                    <h3>Sumerge brevemente</h3>
                    <p>
                      Dip the strip in the liquid <strong
