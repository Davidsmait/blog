---
import PageLayout from '@/layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

// Use Spanish collection as source of truth for draft/phase status
const allCafePostsEs = await getCollection('cafe')
const allCafePostsEn = await getCollection('cafe-en')
const publishedSlugs = new Set(
  allCafePostsEs
    .filter((post) => post.data.phase !== undefined && !post.data.draft)
    .map((post) => post.slug)
)
const roadmapLessons = allCafePostsEn
  .filter((post) => publishedSlugs.has(post.slug))
  .sort((a, b) => {
    const phaseA = a.data.phase ?? 0
    const phaseB = b.data.phase ?? 0
    if (phaseA !== phaseB) return phaseA - phaseB
    return (a.data.lessonOrder ?? 0) - (b.data.lessonOrder ?? 0)
  })

const lessonsByPhase: Record<number, typeof roadmapLessons> = {}
for (const lesson of roadmapLessons) {
  const phase = lesson.data.phase!
  if (!lessonsByPhase[phase]) lessonsByPhase[phase] = []
  lessonsByPhase[phase].push(lesson)
}

const phases = [
  {
    num: 1,
    title: 'Coffee fundamentals',
    desc: 'What specialty coffee is, varieties, processing, extraction and water.',
    totalLessons: 4
  },
  {
    num: 2,
    title: 'Espresso',
    desc: 'Shot anatomy, dial-in, pressure, temperature, diagnosis and maintenance.',
    totalLessons: 5,
    eta: 'Week of April 21'
  },
]

const plannedLessons: Record<number, string[]> = {}

// Phases that are not ready for public launch yet — force locked state
const lockedPhases = new Set([2])

const totalLessons = phases.filter(p => !lockedPhases.has(p.num)).reduce((acc, p) => acc + p.totalLessons, 0)
const completedLessons = roadmapLessons.filter(l => !lockedPhases.has(l.data.phase)).length
const progressPercent = Math.round((completedLessons / totalLessons) * 100)

function getPhaseState(phaseNum: number) {
  if (lockedPhases.has(phaseNum)) return 'locked'
  const lessons = lessonsByPhase[phaseNum] ?? []
  const total = phases.find((p) => p.num === phaseNum)!.totalLessons
  if (lessons.length >= total) return 'complete'
  if (lessons.length > 0) return 'active'
  if (lessons.length === 0 && phaseNum !== 1) return 'locked'
  const prevLessons = lessonsByPhase[phaseNum - 1] ?? []
  const prevTotal =
    phases.find((p) => p.num === phaseNum - 1)?.totalLessons ?? 0
  if (phaseNum === 1 || prevLessons.length >= prevTotal) return 'next'
  return 'locked'
}
---

<PageLayout
  frontmatter={{
    title: 'Specialty Barista Roadmap',
    description: `${totalLessons} lessons in ${phases.length} published phases (9 planned). Coffee fundamentals and espresso. Learn specialty barismo with Scott Rao, Gagné and the SCA.`,
    activeHeaderLink: 'Café'
  }}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Course',
      name: 'Specialty Barista Roadmap',
      description: `${totalLessons} lessons in ${phases.length} published phases (9 planned). Coffee fundamentals and espresso.`,
      url: 'https://davidsanluisaguirre.com/en/barista-roadmap',
      inLanguage: 'en',
      numberOfCredits: totalLessons,
      educationalLevel: 'Beginner to Expert',
      provider: { '@id': 'https://davidsanluisaguirre.com/#person' },
      isPartOf: { '@id': 'https://davidsanluisaguirre.com/#website' },
      hasCourseInstance: phases.map((p) => ({
        '@type': 'CourseInstance',
        name: `Phase ${p.num}: ${p.title}`,
        description: p.desc,
        courseMode: 'online'
      })),
      about: [
        { '@type': 'Thing', name: 'Specialty Coffee' },
        { '@type': 'Thing', name: 'Barista' },
        { '@type': 'Thing', name: 'Espresso' },
        { '@type': 'Thing', name: 'Latte Art' },
        { '@type': 'Thing', name: 'SCA' }
      ]
    })}
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'What is the Specialty Barista Roadmap?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `A free curriculum with ${phases.length} published phases (9 planned) and ${totalLessons} lessons, created by David San Luis Aguirre. Covers coffee fundamentals and espresso, based on methodologies by Scott Rao, the SCA, and Jonathan Gagné.`
          }
        },
        {
          '@type': 'Question',
          name: 'Is the barista roadmap free?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes, all lessons are completely free. The roadmap is available in both English and Spanish.'
          }
        },
        {
          '@type': 'Question',
          name: 'What topics does the specialty coffee roadmap cover?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The roadmap covers coffee fundamentals, espresso, filter methods, cupping and palate training, milk and latte art, roasting and business, advanced Rao methodology, extraction physics, and professional barista career.'
          }
        },
        {
          '@type': 'Question',
          name: 'Do I need prior experience to start?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Phase 1 starts from scratch with coffee fundamentals. The roadmap progresses from beginner to advanced professional topics.'
          }
        }
      ]
    })}
  />

  <!-- ── Editorial Header ── -->
  <div class="reveal mb-10 sm:mb-16">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4 sm:gap-6">
        <span class="font-serif text-[13px] italic opacity-20">(03)</span>
        <h1
          class="m-0 font-serif text-[clamp(2.5rem,6vw,4rem)] italic leading-[1] tracking-tight text-accent"
        >
          Cafe
        </h1>
      </div>
      <a
        href="/barista-roadmap"
        class="rm-lang-pill"
        aria-label="Cambiar a Espanol"
        data-astro-reload>ES</a
      >
    </div>
    <div class="hr-animated mt-3"></div>
  </div>

  <!-- ── Subtitle + Progress ── -->
  <div class="reveal reveal-delay-1 mb-12 sm:mb-16">
    <div
      class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <p
          class="m-0 font-display text-[clamp(1.1rem,2.5vw,1.4rem)] font-semibold leading-[1.3] tracking-tighter-brand text-accent sm:max-w-md"
        >
          Specialty Barista
        </p>
        <p class="mt-2 text-sm leading-relaxed opacity-50 sm:max-w-sm">
          {totalLessons} lessons from zero to professional. From bean fundamentals
          to the physics of extraction.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <div class="rm-progress-bar">
          <div
            class="rm-progress-fill"
            role="progressbar"
            aria-valuenow={completedLessons}
            aria-valuemin={0}
            aria-valuemax={totalLessons}
            style={`width: ${progressPercent}%`}
          >
          </div>
        </div>
        <span class="text-xs font-medium tabular-nums opacity-40"
          >{completedLessons}/{totalLessons}</span
        >
      </div>
    </div>
    <!-- User progress (shown via JS) -->
    <div class="rm-user-progress mt-2" data-user-progress style="display:none">
      <div class="flex items-center gap-3">
        <div class="rm-progress-bar rm-progress-bar--user">
          <div
            class="rm-progress-fill rm-progress-fill--user"
            data-user-progress-fill
          >
          </div>
        </div>
        <span
          class="text-xs font-medium tabular-nums opacity-40"
          data-user-progress-text></span>
      </div>
    </div>
  </div>

  <!-- ── Timeline — Editorial Phases ── -->
  <div class="rm-timeline stagger-children">
    {
      phases.map((phase, idx) => {
        const state = getPhaseState(phase.num)
        const isComplete = state === 'complete'
        const isActive = state === 'active'
        const isLocked = state === 'locked'
        // Hide lessons for force-locked phases
        const lessons = isLocked ? [] : (lessonsByPhase[phase.num] ?? [])
        const planned = isLocked ? [] : (plannedLessons[phase.num] ?? [])
        const hasContent = lessons.length > 0 || planned.length > 0
        const isLast = idx === phases.length - 1

        return (
          <div
            class={`rm-phase rm-phase--${state}`}
            data-phase={phase.num}
            data-state={state}
          >
            <div class="rm-phase-track">
              <span class="rm-phase-node" data-phase-node>
                <svg
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="rm-node-icon rm-node-check rm-node-user-check"
                >
                  <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                </svg>
                <span class="rm-node-default">
                  {isComplete ? (
                    <span class="rm-node-complete-dot" />
                  ) : isActive ? (
                    <span class="rm-node-pulse">
                      <span class="rm-pulse-ring" />
                      <span class="rm-pulse-dot" />
                    </span>
                  ) : isLocked ? (
                    <svg
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      class="rm-node-icon rm-node-lock"
                    >
                      <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                    </svg>
                  ) : (
                    <span class="rm-node-empty" />
                  )}
                </span>
              </span>
              {!isLast && (
                <span
                  class={`rm-phase-line ${isComplete ? 'rm-phase-line--done' : ''}`}
                  data-phase-line
                />
              )}
            </div>

            <div class="rm-phase-content">
              <button
                type="button"
                data-phase-toggle
                class="rm-phase-header"
                aria-expanded="false"
                aria-label={`Phase ${phase.num}: ${phase.title}`}
              >
                <div class="rm-phase-info">
                  <div class="flex items-center gap-3">
                    <span class="font-serif text-[13px] italic opacity-20">
                      ({String(phase.num).padStart(2, '0')})
                    </span>
                    <span class="rm-phase-title">{phase.title}</span>
                  </div>
                  <span class="rm-phase-desc">{phase.desc}</span>
                  {isLocked && phase.eta && (
                    <span class="rm-phase-eta">{phase.eta}</span>
                  )}
                </div>
                <span class="rm-phase-meta">
                  <span class="rm-phase-counter">
                    {lessons.length}/{phase.totalLessons}
                  </span>
                  {hasContent && (
                    <svg
                      class="rm-phase-chevron"
                      data-chevron
                      viewBox="0 0 16 16"
                      fill="currentColor"
                    >
                      <path d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z" />
                    </svg>
                  )}
                </span>
              </button>

              {hasContent && (
                <div class="rm-lessons hidden" data-lessons-panel>
                  {lessons.map((lesson) => (
                    <a
                      href={`/en/cafe-en/${lesson.slug}`}
                      class="rm-lesson rm-lesson--available"
                      data-lesson-slug={lesson.slug}
                    >
                      <span class="rm-lesson-status">
                        <svg
                          viewBox="0 0 16 16"
                          fill="currentColor"
                          class="rm-lesson-check"
                          style="display:none"
                        >
                          <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
                        </svg>
                        <span class="rm-lesson-dot" />
                      </span>
                      <span class="rm-lesson-title">{lesson.data.title}</span>
                      <span class="rm-lesson-arrow">&nearr;</span>
                    </a>
                  ))}
                  {planned.slice(lessons.length).map((title) => (
                    <div class="rm-lesson rm-lesson--pending">
                      <span class="rm-lesson-status">
                        <span class="rm-lesson-dot rm-lesson-dot--pending" />
                      </span>
                      <span class="rm-lesson-title">{title}</span>
                    </div>
                  ))}

                  {/* ── Bonus content after phase lessons ── */}
                  {phase.num === 1 && (
                    <div class="rm-bonus" data-bonus-phase="1">
                      <div class="rm-bonus-divider">
                        <span class="rm-bonus-divider-line" />
                        <span class="rm-bonus-divider-label">Bonus</span>
                        <span class="rm-bonus-divider-line" />
                      </div>
                      <a
                        href="/en/cafe-en/water-testing-tools-guide"
                        class="rm-lesson rm-lesson--bonus rm-bonus-locked"
                        data-bonus-link
                        data-requires-phase="1"
                      >
                        <span class="rm-lesson-status">
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-lock-icon"
                          >
                            <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                          </svg>
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-star-icon"
                            style="display:none"
                          >
                            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                          </svg>
                        </span>
                        <span class="rm-lesson-title">
                          <span class="rm-bonus-title-text">
                            Guide: Water testing tools
                          </span>
                          <span class="rm-bonus-unlock-hint" data-bonus-hint>
                            Complete all 4 lessons to unlock
                          </span>
                        </span>
                        <span class="rm-lesson-arrow">&nearr;</span>
                      </a>
                      <a
                        href="/en/cafe-en/drop-calculator"
                        class="rm-lesson rm-lesson--bonus rm-bonus-locked"
                        data-bonus-link
                        data-requires-phase="1"
                      >
                        <span class="rm-lesson-status">
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-lock-icon"
                          >
                            <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z" />
                          </svg>
                          <svg
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="rm-bonus-star-icon"
                            style="display:none"
                          >
                            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                          </svg>
                        </span>
                        <span class="rm-lesson-title">
                          <span class="rm-bonus-title-text">
                            Drop Calculator — GH & KH
                          </span>
                          <span class="rm-bonus-unlock-hint" data-bonus-hint>
                            Complete all 4 lessons to unlock
                          </span>
                        </span>
                        <span class="rm-lesson-arrow">&nearr;</span>
                      </a>
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>
        )
      })
    }
  </div>

  <!-- ── Teaser: Upcoming phases ── -->
  <div class="reveal mt-12 sm:mt-16">
    <div class="rm-teaser">
      <div class="rm-teaser-line"></div>
      <div class="rm-teaser-content">
        <span class="rm-teaser-label">In development</span>
        <p class="rm-teaser-text">
          7 more phases on the way — filter methods, cupping, latte art, roasting, Rao methodology and more.
        </p>
      </div>
    </div>
  </div>

  <!-- ── Bibliography ── -->
  <div class="reveal mt-16 sm:mt-24">
    <div class="hr-animated mb-8"></div>
    <details class="rm-biblio-details">
      <summary class="rm-biblio-toggle">Bibliography and sources</summary>
      <div class="rm-biblio">
        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Primary books</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>James Hoffmann</strong> — <em
                >The World Atlas of Coffee</em
              >, 2nd ed. (2018). Foundation for phases 1, 3 and 4.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >The Professional Barista's Handbook</em
              > (2008). Basis for phases 2 and 3.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >The Coffee Roaster's Companion</em
              > (2014). Basis for phase 6.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em
                >Espresso Extraction: Measurement and Mastery</em
              > (2013). Basis for phase 7.
            </li>
            <li>
              <strong>David Schomer</strong> — <em
                >Espresso Coffee: Professional Techniques</em
              >, 4th ed. (2010). Reference for phase 2.
            </li>
            <li>
              <strong>Dhan Tamang</strong> — <em>Coffee Art</em> (2017). Basis for
              phase 5.
            </li>
            <li>
              <strong>Jonathan Gagne</strong> — <em
                >The Physics of Filter Coffee</em
              > (2021). Basis for phase 8.
            </li>
            <li>
              <strong>Jonathan Gagne</strong> — <em>The Physics of Espresso</em> (2023).
              Basis for phase 8.
            </li>
            <li>
              <strong>Britta Folmer (ed.)</strong> — <em
                >The Craft and Science of Coffee</em
              > (2017). Academic reference.
            </li>
            <li>
              <strong>Scott Rao</strong> — <em>Everything But Espresso</em> (2010).
              Filter methods with technical rigor.
            </li>
          </ul>
        </div>
        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">SCA and World Coffee Research</h4>
          <ul class="rm-biblio-list">
            <li>
              <strong>SCA</strong> — <em>Coffee Sensory & Cupping Handbook</em>.
              Cupping protocol (phase 4).
            </li>
            <li>
              <strong>SCA</strong> — <em>Water Quality Handbook</em>. Water
              standards (phase 1).
            </li>
            <li>
              <strong>SCA & WCR</strong> — <em>Coffee Taster's Flavor Wheel</em> (2016).
              Phase 4.
            </li>
            <li>
              <strong>SCA</strong> — <em>Coffee Skills Program</em>. Roadmap
              reference structure.
            </li>
          </ul>
        </div>
      </div>
    </details>
  </div>
</PageLayout>

<style>
  /* ── Language pill ── */
  .rm-lang-pill {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: inherit;
    text-decoration: none;
    opacity: 0.3;
    transition:
      opacity 0.4s ease,
      border-color 0.4s ease;
  }
  .rm-lang-pill:hover {
    opacity: 0.7;
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  /* ── Progress bar ── */
  .rm-progress-bar {
    width: 8rem;
    height: 2px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    overflow: hidden;
  }
  .rm-progress-fill {
    height: 100%;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .rm-progress-bar--user {
    width: 8rem;
  }
  .rm-progress-fill--user {
    background: color-mix(in srgb, #22c55e 45%, transparent);
  }

  /* ── Timeline ── */
  .rm-timeline {
    display: flex;
    flex-direction: column;
  }

  .rm-phase {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0 1.25rem;
    min-height: 0;
  }
  @media (max-width: 480px) {
    .rm-phase {
      grid-template-columns: 1.75rem 1fr;
      gap: 0 0.75rem;
    }
  }

  .rm-phase-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .rm-phase-node {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.5s ease;
  }
  @media (max-width: 480px) {
    .rm-phase-node {
      width: 1.5rem;
      height: 1.5rem;
    }
  }
  .rm-phase:hover .rm-phase-node {
    transform: scale(1.15);
  }

  .rm-phase--complete .rm-phase-node {
    background: color-mix(in srgb, #22c55e 10%, transparent);
  }
  .rm-phase--active .rm-phase-node {
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    box-shadow: 0 0 0 4px
      color-mix(in srgb, var(--color-accent) 4%, transparent);
  }
  .rm-phase--next .rm-phase-node,
  .rm-phase--locked .rm-phase-node {
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .rm-node-icon {
    width: 0.75rem;
    height: 0.75rem;
  }
  .rm-node-check {
    color: #22c55e;
  }
  .rm-node-lock {
    opacity: 0.25;
    width: 0.625rem;
    height: 0.625rem;
  }
  .rm-node-complete-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .rm-node-user-check {
    display: none;
  }
  .rm-phase.user-phase-complete .rm-node-user-check {
    display: block;
  }
  .rm-phase.user-phase-complete .rm-node-default {
    display: none;
  }
  .rm-phase.user-phase-complete .rm-phase-node {
    background: color-mix(in srgb, #22c55e 10%, transparent);
  }
