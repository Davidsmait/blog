---
import PageLayout from '@/layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

const allCafePosts = await getCollection('cafe-en')
const roadmapLessons = allCafePosts
  .filter(post => post.data.phase !== undefined && !post.data.draft)
  .sort((a, b) => {
    const phaseA = a.data.phase ?? 0
    const phaseB = b.data.phase ?? 0
    if (phaseA !== phaseB) return phaseA - phaseB
    return (a.data.lessonOrder ?? 0) - (b.data.lessonOrder ?? 0)
  })

const lessonsByPhase: Record<number, typeof roadmapLessons> = {}
for (const lesson of roadmapLessons) {
  const phase = lesson.data.phase!
  if (!lessonsByPhase[phase]) lessonsByPhase[phase] = []
  lessonsByPhase[phase].push(lesson)
}

const phases = [
  { num: 1, title: 'Coffee fundamentals', desc: 'What specialty coffee is, varieties, processing, extraction and water.', totalLessons: 4 },
  { num: 2, title: 'Espresso', desc: 'Shot anatomy, dial-in, pressure, temperature, diagnosis and maintenance.', totalLessons: 5 },
  { num: 3, title: 'Filter methods', desc: 'Pour-over, Chemex, V60, Aeropress, French press, Clever and cold brew.', totalLessons: 5 },
  { num: 4, title: 'Palate and cupping', desc: 'Taste physiology, SCA protocol, flavor wheel and sensory training.', totalLessons: 4 },
  { num: 5, title: 'Milk and latte art', desc: 'Milk science, steaming, heart, rosetta, tulip and etching.', totalLessons: 4 },
  { num: 6, title: 'Roasting and business', desc: 'Chemical reactions, roast curves, supply chain and opening your café.', totalLessons: 4 },
  { num: 7, title: 'Professional — Rao Methodology', desc: 'Advanced grooming, pressure profiling, refractometer, TDS, Rao Spin and turbo shots.', totalLessons: 4 },
  { num: 8, title: 'Physics of extraction', desc: 'Particle distribution, Darcy\'s law, dripper geometry, puck dynamics and flow profiling.', totalLessons: 4 },
  { num: 9, title: 'Professional career', desc: 'Café management, competitive barismo, Q Grader certification and personal branding.', totalLessons: 4 },
]

const plannedLessons: Record<number, string[]> = {}

const totalLessons = phases.reduce((acc, p) => acc + p.totalLessons, 0)
const completedLessons = roadmapLessons.length
const progressPercent = Math.round((completedLessons / totalLessons) * 100)

function getPhaseState(phaseNum: number) {
  const lessons = lessonsByPhase[phaseNum] ?? []
  const total = phases.find(p => p.num === phaseNum)!.totalLessons
  if (lessons.length >= total) return 'complete'
  if (lessons.length > 0) return 'active'
  const prevLessons = lessonsByPhase[phaseNum - 1] ?? []
  const prevTotal = phases.find(p => p.num === phaseNum - 1)?.totalLessons ?? 0
  if (phaseNum === 1 || prevLessons.length >= prevTotal) return 'next'
  return 'locked'
}
---

<PageLayout frontmatter={{
  title: 'Specialty Barista Roadmap',
  description: `${totalLessons} lessons in ${phases.length} phases: from coffee fundamentals to the physics of extraction. Learn to become a professional barista with knowledge from Scott Rao, Jonathan Gagné and the SCA.`,
  activeHeaderLink: 'Cafe'
}}>

  <!-- Header -->
  <div class="rm-header">
    <div class="rm-top-row">
      <span class="rm-label">Roadmap</span>
      <a href="/barista-roadmap" class="rm-lang-switch" aria-label="Cambiar a Español" data-astro-reload>ES</a>
    </div>
    <h1 class="rm-title">Specialty Barista</h1>
    <p class="rm-desc">
      {totalLessons} lessons from zero to professional.
    </p>
    <div class="rm-progress">
      <div class="rm-progress-track" role="progressbar" aria-valuenow={completedLessons} aria-valuemin={0} aria-valuemax={totalLessons}>
        <div class="rm-progress-fill" style={`width: ${progressPercent}%`}></div>
      </div>
      <span class="rm-progress-text">{completedLessons}/{totalLessons}</span>
    </div>
    <div class="rm-user-progress" data-user-progress style="display:none">
      <div class="rm-progress-track" role="progressbar" aria-label="Your reading progress">
        <div class="rm-user-progress-fill" data-user-progress-fill></div>
      </div>
      <span class="rm-progress-text" data-user-progress-text></span>
    </div>
  </div>

  <!-- Timeline -->
  <div class="timeline">
    {phases.map((phase, idx) => {
      const lessons = lessonsByPhase[phase.num] ?? []
      const state = getPhaseState(phase.num)
      const isComplete = state === 'complete'
      const isActive = state === 'active'
      const isLocked = state === 'locked'
      const planned = plannedLessons[phase.num] ?? []
      const hasContent = lessons.length > 0 || planned.length > 0
      const isLast = idx === phases.length - 1

      return (
        <div class={`tl-phase tl-${state}`} data-phase={phase.num} data-state={state}>
          {/* Node + connector line */}
          <div class="tl-track">
            <span class="tl-node" data-phase-node>
              {/* User-complete check (hidden by default, shown via JS) */}
              <svg viewBox="0 0 16 16" fill="currentColor" class="tl-node-icon tl-node-check tl-node-user-check">
                <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/>
              </svg>
              {/* Server-rendered state icons */}
              <span class="tl-node-default">
                {isComplete ? (
                  <svg viewBox="0 0 16 16" fill="currentColor" class="tl-node-icon tl-node-check">
                    <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/>
                  </svg>
                ) : isActive ? (
                  <span class="tl-node-pulse">
                    <span class="tl-pulse-ring"></span>
                    <span class="tl-pulse-dot"></span>
                  </span>
                ) : isLocked ? (
                  <svg viewBox="0 0 16 16" fill="currentColor" class="tl-node-icon tl-node-lock">
                    <path d="M8 1a4 4 0 0 0-4 4v3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1V5a4 4 0 0 0-4-4Zm2 7H6V5a2 2 0 1 1 4 0v3Z"/>
                  </svg>
                ) : (
                  <span class="tl-node-empty"></span>
                )}
              </span>
            </span>
            {!isLast && <span class={`tl-line ${isComplete ? 'tl-line-done' : ''}`} data-phase-line></span>}
          </div>

          {/* Content */}
          <div class="tl-content">
            <button
              type="button"
              data-phase-toggle
              class="tl-header"
              aria-expanded="false"
              aria-label={`Phase ${phase.num}: ${phase.title}`}
            >
              <div class="tl-title-group">
                <span class="tl-title">{phase.title}</span>
                <span class="tl-desc">{phase.desc}</span>
              </div>
              <span class="tl-meta">
                <span class="tl-counter">{lessons.length}/{phase.totalLessons}</span>
                {hasContent && (
                  <svg class="tl-chevron" data-chevron viewBox="0 0 16 16" fill="currentColor">
                    <path d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z"/>
                  </svg>
                )}
              </span>
            </button>

            {/* Expandable lesson list */}
            {hasContent && (
              <div class="tl-lessons hidden" data-lessons-panel>
                {lessons.map((lesson) => (
                  <a href={`/en/cafe-en/${lesson.slug}`} class="tl-lesson tl-lesson-available" data-lesson-slug={lesson.slug}>
                    <span class="tl-lesson-status-icon">
                      <svg viewBox="0 0 16 16" fill="currentColor" class="tl-lesson-icon tl-lesson-icon-check" style="display:none">
                        <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/>
                      </svg>
                      <span class="tl-lesson-icon-unread"></span>
                    </span>
                    <span>{lesson.data.title}</span>
                  </a>
                ))}
                {planned.slice(lessons.length).map((title) => (
                  <div class="tl-lesson tl-lesson-pending">
                    <span class="tl-lesson-dot"></span>
                    <span>{title}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      )
    })}
  </div>

  <!-- Sources -->
  <div class="rm-footer">
    <details>
      <summary class="rm-sources-toggle">Bibliography and sources</summary>
      <div class="rm-biblio">

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Primary books</h4>
          <ul class="rm-biblio-list">
            <li><strong>James Hoffmann</strong> — <em>The World Atlas of Coffee</em>, 2nd ed. (2018). Foundation for phases 1, 3 and 4: origins, filter methods, varieties and French press technique.</li>
            <li><strong>Scott Rao</strong> — <em>The Professional Barista's Handbook</em> (2008). Basis for phases 2 and 3: extraction science, espresso, dial-in, shot diagnosis and pour-over principles.</li>
            <li><strong>Scott Rao</strong> — <em>The Coffee Roaster's Companion</em> (2014). Basis for phase 6: roast curves, RoR, DTR, origin-specific profiles and roasting defects.</li>
            <li><strong>Scott Rao</strong> — <em>Espresso Extraction: Measurement and Mastery</em> (2013). Basis for phase 7: refractometer, TDS, pressure profiling, turbo shots and extended ratios.</li>
            <li><strong>David Schomer</strong> — <em>Espresso Coffee: Professional Techniques</em>, 4th ed. (2010). Reference for phase 2: pressure, temperature, thermal stability, pre-infusion and maintenance.</li>
            <li><strong>Dhan Tamang</strong> — <em>Coffee Art: Creative Coffee Designs for the Home Barista</em> (2017). Basis for phase 5: basic and advanced latte art patterns, pouring technique and etching.</li>
            <li><strong>Jonathan Gagné</strong> — <em>The Physics of Filter Coffee</em> (2021). Basis for phase 8: Darcy's law, percolation, particle distribution, dripper geometry and fines migration.</li>
            <li><strong>Jonathan Gagné</strong> — <em>The Physics of Espresso</em> (2023). Basis for phase 8: puck dynamics, pressure/flow profiling, extraction science under pressure.</li>
            <li><strong>Britta Folmer (ed.)</strong> — <em>The Craft and Science of Coffee</em> (2017, Elsevier). Academic reference: roasting chemistry at molecular level, decaffeination, crema, sustainability.</li>
            <li><strong>Scott Rao</strong> — <em>Everything But Espresso</em> (2010). Filter methods with technical rigor: percolation, immersion, bypass and control variables.</li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">SCA and World Coffee Research publications</h4>
          <ul class="rm-biblio-list">
            <li><strong>SCA</strong> — <em>Coffee Sensory & Cupping Handbook</em>. Cupping protocol, evaluation form and scoring standards (phase 4).</li>
            <li><strong>SCA</strong> — <em>Water Quality Handbook</em>. Water standards for brewing: TDS, pH, hardness and mineral composition (phase 1).</li>
            <li><strong>SCA & WCR</strong> — <em>Coffee Taster's Flavor Wheel</em> (2016). Flavor wheel, descriptors and sensory families (phase 4).</li>
            <li><strong>SCA</strong> — <em>Coffee Skills Program</em>. Modular structure Foundation → Intermediate → Professional as roadmap reference.</li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Complementary books</h4>
          <ul class="rm-biblio-list">
            <li><strong>Maxwell Colonna-Dashwood</strong> — <em>Water for Coffee</em> (2015). Water chemistry, mineralization and its impact on extraction (phase 1).</li>
            <li><strong>Rob Hoos</strong> — <em>Modulating the Flavor Profile of Coffee</em> (2015). Relationship between roasting decisions and flavor profile (phase 6).</li>
            <li><strong>Christopher H. Hendon et al.</strong> — <em>Water for Coffee</em> (2015). Scientific research on water's role in extraction.</li>
            <li><strong>Andrea Illy & Rinantonio Viani</strong> — <em>Espresso Coffee: The Science of Quality</em>, 2nd ed. (2005). Scientific foundations of espresso (phase 2).</li>
            <li><strong>Morten Münchow et al.</strong> — Research on extraction, TDS and performance published in <em>Journal of Food Science</em>.</li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Online resources</h4>
          <ul class="rm-biblio-list">
            <li><strong>James Hoffmann</strong> — YouTube channel. V60 techniques (Hoffmann method), French press, Aeropress, and equipment reviews.</li>
            <li><strong>Tetsu Kasuya</strong> — 4:6 method for V60, documented at World Brewers Cup 2016.</li>
            <li><strong>Barista Hustle</strong> — Technical articles on extraction, percolation and coffee science.</li>
            <li><strong>World Aeropress Championship</strong> — Public archive of winning recipes by year.</li>
            <li><strong>Specialty Coffee Association (sca.coffee)</strong> — Standards, protocols and educational resources.</li>
            <li><strong>Perfect Daily Grind</strong> — Articles on supply chain, direct trade and sustainability (phase 6).</li>
          </ul>
        </div>

        <div class="rm-biblio-section">
          <h4 class="rm-biblio-heading">Reference by phase</h4>
          <div class="rm-phase-refs">
            <p><strong>Phase 1</strong> (Fundamentals): Hoffmann, Rao (Barista's Handbook), Colonna-Dashwood, SCA Water Quality Handbook</p>
            <p><strong>Phase 2</strong> (Espresso): Schomer, Rao (Barista's Handbook), Illy & Viani</p>
            <p><strong>Phase 3</strong> (Filter methods): Hoffmann, Rao (Barista's Handbook), Kasuya 4:6, World Aeropress Championship</p>
            <p><strong>Phase 4</strong> (Palate): SCA Cupping Handbook, SCA/WCR Flavor Wheel, Barista Hustle</p>
            <p><strong>Phase 5</strong> (Latte art): Tamang, Schomer, Hoffmann (YouTube)</p>
            <p><strong>Phase 6</strong> (Roasting and business): Rao (Roaster's Companion), Hoos, SCA, Perfect Daily Grind</p>
            <p><strong>Phase 7</strong> (Rao Methodology): Rao (Barista's Handbook, Espresso Extraction), Münchow et al., SCA Brewing Control Chart</p>
            <p><strong>Phase 8</strong> (Physics of extraction): Gagné (Physics of Filter Coffee, Physics of Espresso), Folmer (Craft & Science of Coffee), Rao (Everything But Espresso)</p>
            <p><strong>Phase 9</strong> (Professional career): SCA Coffee Skills Program, CQI Q Grader, World Barista Championship, Rao (Barista's Handbook)</p>
          </div>
        </div>

      </div>
    </details>
  </div>

</PageLayout>

<style>
  /* ── Header ── */
  .rm-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rm-lang-switch {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: inherit;
    text-decoration: none;
    opacity: 0.35;
    transition: opacity 0.15s, border-color 0.15s;
  }
  .rm-lang-switch:hover {
    opacity: 0.7;
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  .rm-header {
    margin-bottom: 2.5rem;
    animation: rm-fade-in 0.6s ease-out;
  }
  .rm-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.25;
    margin-bottom: 0.375rem;
  }
  .rm-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }
  .rm-desc {
    font-size: 0.8125rem;
    opacity: 0.4;
    margin-bottom: 0;
  }
  .rm-progress {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 1rem;
    max-width: 16rem;
  }
  .rm-progress-track {
    flex: 1;
    height: 3px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    overflow: hidden;
  }
  .rm-progress-fill {
    height: 100%;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 55%, transparent);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .rm-progress-text {
    font-size: 0.6875rem;
    font-weight: 500;
    opacity: 0.3;
    font-variant-numeric: tabular-nums;
  }

  @keyframes rm-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Timeline layout ── */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .tl-phase {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0 1rem;
    min-height: 0;
    animation: rm-phase-in 0.5s ease-out both;
  }
  .tl-phase:nth-child(1) { animation-delay: 0.08s; }
  .tl-phase:nth-child(2) { animation-delay: 0.14s; }
  .tl-phase:nth-child(3) { animation-delay: 0.20s; }
  .tl-phase:nth-child(4) { animation-delay: 0.26s; }
  .tl-phase:nth-child(5) { animation-delay: 0.32s; }
  .tl-phase:nth-child(6) { animation-delay: 0.38s; }
  .tl-phase:nth-child(7) { animation-delay: 0.44s; }
  .tl-phase:nth-child(8) { animation-delay: 0.50s; }
  .tl-phase:nth-child(9) { animation-delay: 0.56s; }

  @keyframes rm-phase-in {
    from { opacity: 0; transform: translateX(-6px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ── Track: node + vertical line ── */
  .tl-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .tl-node {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .tl-phase:hover .tl-node {
    transform: scale(1.12);
  }

  /* Node states */
  .tl-complete .tl-node {
    background: color-mix(in srgb, #22c55e 12%, transparent);
  }
  .tl-active .tl-node {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .tl-next .tl-node,
  .tl-locked .tl-node {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  .tl-node-icon {
    width: 0.75rem;
    height: 0.75rem;
  }
  .tl-node-check { color: #22c55e; }
  .tl-node-lock { opacity: 0.3; width: 0.625rem; height: 0.625rem; }

  /* User-complete: hidden by default, shown when user reads all lessons in phase */
  .tl-node-user-check {
    display: none;
  }
  .tl-phase.user-phase-complete .tl-node-user-check {
    display: block;
  }
  .tl-phase.user-phase-complete .tl-node-default {
    display: none;
  }
  .tl-phase.user-phase-complete .tl-node {
    background: color-mix(in srgb, #22c55e 12%, transparent);
    transition: background 0.3s ease;
  }
  .tl-phase.user-phase-complete .tl-line {
    background: color-mix(in srgb, #22c55e 20%, transparent);
  }
  .tl-phase.user-phase-complete .tl-title {
    opacity: 0.55;
  }

  .tl-node-empty {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: 1.5px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .tl-node-pulse {
    position: relative;
    width: 0.5rem;
    height: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tl-pulse-ring {
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 30%, transparent);
    animation: tl-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  .tl-pulse-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    position: relative;
  }
  @keyframes tl-ping {
    0% { transform: scale(1); opacity: 0.6; }
    75%, 100% { transform: scale(2.5); opacity: 0; }
  }

  /* Connector line */
  .tl-line {
    width: 1.5px;
    flex: 1;
    min-height: 0;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    transition: background 0.3s ease;
  }
  .tl-line-done {
    background: color-mix(in srgb, #22c55e 20%, transparent);
  }

  /* ── Content column ── */
  .tl-content {
    padding-bottom: 1.75rem;
    min-width: 0;
  }

  .tl-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    width: 100%;
    border: none;
    background: none;
    padding: 0.375rem 0.5rem;
    margin: -0.375rem -0.5rem;
    border-radius: 0.5rem;
    cursor: pointer;
    font-family: inherit;
    color: inherit;
    text-align: left;
    min-height: 1.5rem;
    transition: background 0.15s ease;
  }
  .tl-header:hover {
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
  }
  .tl-header:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    outline-offset: 2px;
  }

  .tl-title-group {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .tl-title {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.2;
    transition: opacity 0.15s ease, color 0.15s ease;
  }
  .tl-complete .tl-title { opacity: 0.55; }
  .tl-active .tl-title { color: var(--color-accent); }
  .tl-next .tl-title { opacity: 0.5; }
  .tl-locked .tl-title { opacity: 0.3; }
  .tl-header:hover .tl-title { opacity: 0.85; }
  .tl-active .tl-header:hover .tl-title { opacity: 1; }

  .tl-desc {
    font-size: 0.6875rem;
    line-height: 1.4;
    opacity: 0.25;
    display: none;
  }
  .tl-header[aria-expanded="true"] .tl-desc,
  .tl-active .tl-desc {
    display: block;
  }

  .tl-meta {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .tl-counter {
    font-size: 0.6875rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    opacity: 0.3;
  }
  .tl-complete .tl-counter { color: #22c55e; opacity: 0.5; }
  .tl-active .tl-counter { color: var(--color-accent); opacity: 0.5; }

  .tl-chevron {
    width: 0.75rem;
    height: 0.75rem;
    opacity: 0.2;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.15s ease;
  }
  .tl-header:hover .tl-chevron { opacity: 0.4; }

  /* ── Lessons (animated expand/collapse) ── */
  .tl-lessons {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    gap: 1px;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
  }
  .tl-lessons.hidden {
    max-height: 0 !important;
    opacity: 0;
    margin-top: 0;
  }
  .tl-lessons:not(.hidden) {
    opacity: 1;
  }

  .tl-lesson {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem;
    margin: 0 -0.5rem;
    font-size: 0.8125rem;
    text-decoration: none;
    color: inherit;
    border-radius: 0.375rem;
    transition: background 0.12s ease;
  }
  a.tl-lesson:hover {
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  /* Lesson status icons */
  .tl-lesson-status-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }
  .tl-lesson-icon-check {
    width: 0.75rem;
    height: 0.75rem;
    color: color-mix(in srgb, #22c55e 55%, transparent);
  }
  .tl-lesson-icon-unread {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
  .tl-lesson-available.is-read .tl-lesson-icon-check { display: block !important; }
  .tl-lesson-available.is-read .tl-lesson-icon-unread { display: none; }
  .tl-lesson-available.is-read span:last-child {
    opacity: 0.55;
  }
  .tl-lesson-available:not(.is-read) span:last-child {
    opacity: 0.75;
  }
  .tl-lesson-available {
    transition: background 0.12s ease, opacity 0.12s ease;
  }
  a.tl-lesson-available:hover span:last-child {
    opacity: 1;
    color: var(--color-accent);
  }
  a.tl-lesson-available:hover .tl-lesson-icon-check {
    color: var(--color-accent);
  }
  a.tl-lesson-available:hover .tl-lesson-icon-unread {
    background: var(--color-accent);
  }

  /* User progress bar */
  .rm-user-progress {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 0.375rem;
    max-width: 16rem;
  }
  .rm-user-progress-fill {
    height: 100%;
    border-radius: 9999px;
    background: color-mix(in srgb, #22c55e 50%, transparent);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tl-lesson-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    flex-shrink: 0;
    margin: 0 0.125rem;
  }
  .tl-lesson-pending span {
    opacity: 0.22;
  }

  /* ── Footer ── */
  .rm-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-accent) 5%, transparent);
  }
  .rm-sources-toggle {
    cursor: pointer;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.2;
    transition: opacity 0.12s;
    list-style: none;
  }
  .rm-sources-toggle::-webkit-details-marker { display: none; }
  .rm-sources-toggle::marker { display: none; content: ''; }
  .rm-sources-toggle:hover { opacity: 0.4; }

  /* ── Bibliography ── */
  .rm-biblio {
    margin-top: 1rem;
    animation: rm-fade-in 0.3s ease-out;
  }
  .rm-biblio-section {
    margin-bottom: 1.25rem;
  }
  .rm-biblio-heading {
    font-size: 0.75rem;
    font-weight: 600;
    opacity: 0.35;
    margin-bottom: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rm-biblio-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .rm-biblio-list li {
    font-size: 0.8125rem;
    line-height: 1.5;
    opacity: 0.45;
  }
  .rm-biblio-list li strong {
    opacity: 1;
    font-weight: 600;
  }
  .rm-biblio-list li em {
    font-style: italic;
  }
  .rm-phase-refs {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .rm-phase-refs p {
    font-size: 0.8125rem;
    line-height: 1.5;
    opacity: 0.4;
    margin: 0;
  }
  .rm-phase-refs p strong {
    opacity: 1;
    color: var(--color-accent);
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .tl-phase {
      grid-template-columns: 1.5rem 1fr;
      gap: 0 0.625rem;
    }
    .tl-node {
      width: 1.25rem;
      height: 1.25rem;
    }
    .tl-title {
      font-size: 0.8125rem;
    }
    .tl-lesson {
      font-size: 0.75rem;
      padding: 0.25rem 0.375rem;
      margin: 0 -0.375rem;
    }
    .rm-title {
      font-size: 1.25rem;
    }
    .rm-biblio-list li {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  // ── Cookie helpers ──
  const COOKIE_NAME = 'roadmap_read'
  const COOKIE_DAYS = 365

  function getReadLessons(): Set<string> {
    const match = document.cookie.match(new RegExp('(?:^|; )' + COOKIE_NAME + '=([^;]*)'))
    if (!match) return new Set()
    try {
      return new Set(JSON.parse(decodeURIComponent(match[1])))
    } catch {
      return new Set()
    }
  }

  function saveReadLessons(slugs: Set<string>) {
    const expires = new Date(Date.now() + COOKIE_DAYS * 864e5).toUTCString()
    const value = encodeURIComponent(JSON.stringify([...slugs]))
    document.cookie = `${COOKIE_NAME}=${value}; expires=${expires}; path=/; SameSite=Lax`
  }

  function markLessonRead(slug: string) {
    const read = getReadLessons()
    if (!read.has(slug)) {
      read.add(slug)
      saveReadLessons(read)
    }
  }

  // ── UI update ──
  function updateProgressUI() {
    const read = getReadLessons()
    const allLessons = document.querySelectorAll<HTMLElement>('[data-lesson-slug]')
    let totalAvailable = 0
    let totalRead = 0

    allLessons.forEach(el => {
      const slug = el.dataset.lessonSlug!
      totalAvailable++
      if (read.has(slug)) {
        el.classList.add('is-read')
        totalRead++
      } else {
        el.classList.remove('is-read')
      }
    })

    const userProgressEl = document.querySelector('[data-user-progress]') as HTMLElement | null
    const userFill = document.querySelector('[data-user-progress-fill]') as HTMLElement | null
    const userText = document.querySelector('[data-user-progress-text]') as HTMLElement | null

    if (userProgressEl && userFill && userText && totalAvailable > 0) {
      userProgressEl.style.display = 'flex'
      const pct = Math.round((totalRead / totalAvailable) * 100)
      userFill.style.width = pct + '%'
      userText.textContent = `${totalRead}/${totalAvailable} read`
    }

    document.querySelectorAll<HTMLElement>('[data-phase]').forEach(phaseEl => {
      const lessons = phaseEl.querySelectorAll<HTMLElement>('[data-lesson-slug]')
      const readInPhase = [...lessons].filter(l => read.has(l.dataset.lessonSlug!)).length
      const counterEl = phaseEl.querySelector('.tl-counter')
      if (counterEl && lessons.length > 0) {
        const total = counterEl.textContent?.split('/')[1] ?? String(lessons.length)
        counterEl.textContent = `${readInPhase}/${total}`
      }

      // Show green check on phase node when all lessons are read
      if (lessons.length > 0 && readInPhase === lessons.length) {
        phaseEl.classList.add('user-phase-complete')
      } else {
        phaseEl.classList.remove('user-phase-complete')
      }
    })
  }

  function attachLessonTracking() {
    document.querySelectorAll<HTMLElement>('[data-lesson-slug]').forEach(el => {
      el.addEventListener('click', () => {
        markLessonRead(el.dataset.lessonSlug!)
      })
    })
  }

  // ── Expand/collapse ──
  function initRoadmap() {
    document.querySelectorAll('[data-phase-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        const phase = btn.closest('[data-phase]');
        const panel = phase?.querySelector('[data-lessons-panel]') as HTMLElement | null;
        const chevron = btn.querySelector('[data-chevron]') as HTMLElement | null;
        if (!panel) return;

        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        if (isOpen) {
          panel.style.maxHeight = panel.scrollHeight + 'px';
          requestAnimationFrame(() => {
            panel.classList.add('hidden');
            panel.style.maxHeight = '0';
          });
        } else {
          panel.classList.remove('hidden');
          panel.style.maxHeight = panel.scrollHeight + 'px';
          const onEnd = () => {
            panel.style.maxHeight = '';
            panel.removeEventListener('transitionend', onEnd);
          };
          panel.addEventListener('transitionend', onEnd);
        }

        btn.setAttribute('aria-expanded', String(!isOpen));

        if (chevron) {
          chevron.style.transform = isOpen ? '' : 'rotate(90deg)';
        }
      });
    });

    const active = document.querySelector('[data-state="active"] [data-phase-toggle]') as HTMLElement | null;
    const firstComplete = document.querySelector('[data-state="complete"] [data-phase-toggle]') as HTMLElement | null;
    if (active) active.click();
    else if (firstComplete) firstComplete.click();

    const fill = document.querySelector('.rm-progress-fill') as HTMLElement | null;
    if (fill) {
      const target = fill.style.width;
      fill.style.width = '0%';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          fill.style.width = target;
        });
      });
    }

    updateProgressUI()
    attachLessonTracking()
  }

  initRoadmap();
  document.addEventListener('astro:after-swap', initRoadmap);
</script>
