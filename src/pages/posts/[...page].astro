---
import Pagination from '@/components/Pagination.astro'
import PostsList from '@/components/PostsList.astro'
import PageLayout, {
  type Props as PageLayoutProps
} from '@/layouts/PageLayout.astro'
import config from '@/theme.config'
import { getPosts } from '@/util/posts'
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro'

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPosts()

  return paginate(posts, { pageSize: config.postsPerPage })
}) satisfies GetStaticPaths

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { page } = Astro.props

const frontmatter: PageLayoutProps['frontmatter'] = {
  title: 'Blog — Desarrollo Web, TypeScript y Café de Especialidad',
  description:
    'Artículos de David San Luis Aguirre sobre desarrollo fullstack, Angular, NestJS, TypeScript, AWS y café de especialidad.',
  activeHeaderLink: 'Blog',
  canonicalURL: new URL('/posts/1', Astro.site).toString()
}

const collectionPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog — David San Luis Aguirre',
  description: frontmatter.description,
  url: new URL('/posts', Astro.site).href,
  isPartOf: { '@id': 'https://davidsanluisaguirre.com/#website' },
  author: { '@id': 'https://davidsanluisaguirre.com/#person' },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: page.data.length,
    itemListElement: page.data.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(`/posts/${post.slug}`, Astro.site).href,
      name: post.data.title
    }))
  }
})
---

<PageLayout {frontmatter}>
  <script type="application/ld+json" set:html={collectionPageSchema} />
  <div class="reveal mb-10 sm:mb-16">
    <div class="flex items-center gap-4 sm:gap-6">
      <span class="font-serif text-[13px] italic opacity-20">(01)</span>
      <h1
        class="m-0 font-serif text-[clamp(2.5rem,6vw,4rem)] italic leading-[1] tracking-tight text-accent"
      >
        Blog
      </h1>
    </div>
    <div class="hr-animated mt-3"></div>
  </div>

  <PostsList posts={page.data} />

  {/* Link sutil hacia /ensayos — solo en la última página de paginación */}
  {
    page.lastPage === page.currentPage && (
      <div class="reveal mt-16 border-t border-accent/[0.08] pt-8 sm:mt-20 sm:pt-12">
        <a
          href="/ensayos"
          class="group flex items-baseline gap-3 no-underline opacity-50 transition-opacity duration-500 hover:opacity-100"
          data-astro-prefetch
          data-cursor-hover
        >
          <span class="font-serif text-[13px] italic opacity-60">
            ¿Buscas algo menos técnico?
          </span>
          <span class="font-serif text-[13px] italic text-accent">Ensayos</span>
          <span class="text-sm opacity-40 transition-transform duration-500 group-hover:translate-x-1">
            &rarr;
          </span>
        </a>
        <p class="m-0 mt-2 max-w-[50ch] text-[12px] leading-relaxed opacity-30">
          Espacio personal donde escribo sobre filosofía, ideología y
          experiencias. Sin SEO ni métricas — solo lo que me hace pensar.
        </p>
      </div>
    )
  }

  <Pagination slot="bottom" page={page} />
</PageLayout>
