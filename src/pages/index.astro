              <span>Espresso</span><span>&bull;</span>
              <span>Latte Art</span><span>&bull;</span>
              <span>V60</span><span>&bull;</span>
              <span>Firebase</span><span>&bull;</span>
              <span>Ionic</span><span>&bull;</span>
              <span>Open Source</span><span>&bull;</span>
              <span>Specialty Coffee</span><span>&bull;</span>
