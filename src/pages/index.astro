  <!-- SCRIPTS -->
  <script>
    function initAwwwardsInteractions() {
      const isTouchDevice =
        'ontouchstart' in window || navigator.maxTouchPoints > 0
      const isFineCursor = window.matchMedia('(pointer: fine)').matches

      // ── Custom cursor — only on fine pointer devices ──
      const cursor = document.getElementById('custom-cursor')
      if (cursor && isFineCursor && !isTouchDevice) {
        let mouseX = 0,
          mouseY = 0
        let cursorX = 0,
          cursorY = 0

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX
          mouseY = e.clientY
          cursor.classList.add('visible')
        })

        document.addEventListener('mouseleave', () => {
          cursor.classList.remove('visible')
        })

        function animateCursor() {
          cursorX += (mouseX - cursorX) * 0.12
          cursorY += (mouseY - cursorY) * 0.12
          cursor.style.left = cursorX + 'px'
          cursor.style.top = cursorY + 'px'
          requestAnimationFrame(animateCursor)
        }
        animateCursor()

        const hoverTargets = document.querySelectorAll(
          'a, button, [data-cursor-hover]'
        )
        hoverTargets.forEach((el) => {
          el.addEventListener('mouseenter', () =>
            cursor.classList.add('hovering')
          )
          el.addEventListener('mouseleave', () =>
            cursor.classList.remove('hovering')
          )
        })
      }

      // ── Auto-fit hero role text to full-bleed container ──
      const heroRole = document.getElementById('hero-role')
      const heroContainer = document.getElementById('hero-role-container')
      if (heroRole && heroContainer) {
        const fitText = () => {
          const containerW = heroContainer.clientWidth
          let size = Math.min(containerW * 0.2, 260)
          heroRole.style.fontSize = size + 'px'
          while (heroRole.scrollWidth > containerW && size > 20) {
            size -= 2
            heroRole.style.fontSize = size + 'px'
          }
        }
        fitText()
        window.addEventListener('resize', fitText)
      }

      // ── "BASED IN MÉXICO" — match width to title on both mobile & desktop ──
      const fitBasedInMexico = () => {
        // Mobile: match to Developer line
        const devMobile = document.getElementById('hero-developer-mobile')
        const basedMobile = document.getElementById('based-in-mexico')
        if (devMobile && basedMobile) {
          const w = devMobile.offsetWidth
          if (w > 0) basedMobile.style.width = w + 'px'
        }
      }
      setTimeout(fitBasedInMexico, 100)
      window.addEventListener('resize', fitBasedInMexico)

      // ── Hero entrance animation — staggered like Olha ──
      const heroTitleLines = document.querySelectorAll('.hero-title-line')
      heroTitleLines.forEach((line) => {
        const delay = parseInt((line as HTMLElement).dataset.heroDelay || '0')
        setTimeout(() => line.classList.add('revealed'), delay)
      })

      const heroFades = document.querySelectorAll('.hero-fade')
      heroFades.forEach((el) => {
        const delay = parseInt((el as HTMLElement).dataset.heroDelay || '0')
        setTimeout(() => el.classList.add('revealed'), delay)
      })

      // ── Hero letter stagger ──
      const heroLetters = document.querySelectorAll('.hero-letter')
      heroLetters.forEach((letter, i) => {
        const el = letter as HTMLElement
        el.style.transitionDelay = `${600 + i * 40}ms`
        setTimeout(() => el.classList.add('revealed'), 300 + i * 40)
      })

      // ── Scroll reveals ──
      const reveals = document.querySelectorAll(
        '.reveal, .stagger-children, .hr-animated'
      )
      if (reveals.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add('revealed')
            })
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        )
        reveals.forEach((el) => observer.observe(el))
      }

      // ── Text split reveal ──
      const splitLines = document.querySelectorAll('.text-split-line')
      if (splitLines.length) {
        const splitObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const delay = parseInt(entry.target.dataset.splitDelay || '0')
                setTimeout(() => entry.target.classList.add('revealed'), delay)
              }
            })
          },
          { threshold: 0.3 }
        )
        splitLines.forEach((el) => splitObserver.observe(el))
      }

      // ── Explore rows: horizontal slide on hover (desktop only) ──
      if (!isTouchDevice) {
        const exploreRows = document.querySelectorAll('.explore-row')
        exploreRows.forEach((row) => {
          row.addEventListener('mouseenter', () => {
            const title = row.querySelector('h3')
            if (title)
              (title as HTMLElement).style.transform = 'translateX(12px)'
          })
          row.addEventListener('mouseleave', () => {
            const title = row.querySelector('h3')
            if (title) (title as HTMLElement).style.transform = 'translateX(0)'
          })
        })
      }

      // ── Contact links: indent on hover (desktop only) ──
      if (!isTouchDevice) {
        const contactLinks = document.querySelectorAll('.contact-link')
        contactLinks.forEach((link) => {
          const el = link as HTMLElement
          el.addEventListener('mouseenter', () => {
            el.style.paddingLeft = '16px'
          })
          el.addEventListener('mouseleave', () => {
            el.style.paddingLeft = '0'
          })
        })
      }

      // ── Hero photo parallax on scroll ──
      const heroPhoto = document.querySelector(
        '.hero-photo'
      ) as HTMLElement | null
      if (heroPhoto) {
        let ticking = false
        const parallaxRate = isTouchDevice ? 0.04 : 0.08

        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              requestAnimationFrame(() => {
                const scrollY = window.scrollY
                const rate = scrollY * parallaxRate
                heroPhoto.style.transform = `scale(1.05) translateY(${rate}px)`
                ticking = false
              })
              ticking = true
            }
          },
          { passive: true }
        )
      }

      // ── Hero photo hover zoom (desktop only) ──
      const heroPhotoWrap = document.querySelector(
        '.hero-photo-wrap'
      ) as HTMLElement | null
      if (heroPhotoWrap && heroPhoto && !isTouchDevice) {
        heroPhotoWrap.addEventListener('mouseenter', () => {
          heroPhoto.style.transform = `scale(1.08)`
        })
        heroPhotoWrap.addEventListener('mouseleave', () => {
          heroPhoto.style.transform = `scale(1.05)`
        })
      }

      document.documentElement.style.scrollBehavior = 'smooth'
    }

    // ── Preloader — Counter + split curtain ──
    function initPreloader(onComplete: () => void) {
      const pl = document.getElementById('preloader')
      if (!pl) { onComplete(); return }

      const key = 'pl_shown'
      if (sessionStorage.getItem(key)) {
        pl.classList.add('skip')
        onComplete()
        return
      }
      sessionStorage.setItem(key, '1')

      const counter = document.getElementById('pl-counter')
      document.body.style.overflow = 'hidden'

      // Counter 0 → 100
      const DURATION = 1400
      const start = performance.now()

      function ease(t: number) {
        return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2
      }

      function tick(now: number) {
        const t = Math.min((now - start) / DURATION, 1)
        if (counter) counter.textContent = String(Math.round(ease(t) * 100))

        if (t < 1) {
          requestAnimationFrame(tick)
        } else {
          // Counter hits 100 → brief hold → curtains split
          setTimeout(() => {
            pl.classList.add('done')
            document.body.style.overflow = ''
            setTimeout(onComplete, 500)
            setTimeout(() => pl.remove(), 1400)
          }, 300)
        }
      }

      requestAnimationFrame(tick)
    }

    function initPage() {
      initPreloader(() => {
        initAwwwardsInteractions()
      })
    }

    document.addEventListener('astro:page-load', initPage)
  </script>

  <!-- Inline styles for interactions -->
  <style>
    /* ── Hero bleed — break out of page-wrapper to full viewport ── */
    .hero-bleed {
      width: 100vw;
      position: relative;
      left: 50%;
      transform: translateX(-50%);
      padding: 0 5vw;
    }

    @media (min-width: 640px) {
      .hero-bleed {
        padding: 0 4vw;
      }
    }

    /* ── Hero title entrance — slide up from below ── */
    .hero-title-wrap {
      overflow: hidden;
    }

    .hero-title-line {
      transform: translateY(110%);
      transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .hero-title-line.revealed {
      transform: translateY(0);
    }

    /* ── Hero letter stagger — individual letter animation ── */
    .hero-letter {
      display: inline-block;
      transform: translateY(20%) rotateX(40deg);
      opacity: 0;
      transition:
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 0.6s ease;
      transform-origin: bottom center;
    }

    .hero-letter.revealed {
      transform: translateY(0) rotateX(0deg);
      opacity: 1;
    }

    .hero-letter-wrap {
      perspective: 800px;
      display: inline;
    }

    /* ── Hero fade elements ── */
    .hero-fade {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .hero-fade.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Restore original opacity for elements that had opacity classes */
    .hero-fade.revealed[class*='opacity-'] {
      /* Let Tailwind opacity classes take precedence */
    }

    /* ── Explore rows ── */
    .explore-row h3 {
      transition:
        transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
        letter-spacing 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .contact-link {
      transition:
        padding-left 0.5s cubic-bezier(0.16, 1, 0.3, 1),
        background 0.5s ease;
    }

    .contact-link:hover {
      background: rgba(var(--accent), 0.015);
    }

    /* ── Mobile active states ── */
    @media (hover: none) {
      .explore-row:active {
        background: rgba(var(--accent), 0.02);
      }

      .explore-row:active h3 {
        transform: translateX(6px);
      }

      .contact-link:active {
        background: rgba(var(--accent), 0.03);
      }

      .reveal {
        transform: translateY(24px);
      }
    }

    /* ═══════════════════════════════════════════════ */
    /* PRELOADER — Cinematic counter + split curtain  */
    /* ═══════════════════════════════════════════════ */
    .pl {
      position: fixed;
      inset: 0;
      z-index: 100000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgb(var(--accent-bg));
      overflow: hidden;
    }

    /* Override root overflow clipping during preloader */
    html:has(.pl:not(.skip):not(.done)) {
      overflow: hidden !important;
      scrollbar-gutter: auto;
    }

    .pl.skip { display: none; }

    .pl.done { pointer-events: none; }

    /* Noise layer */
    .pl-noise {
      position: absolute;
      inset: 0;
      opacity: 0.025;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* ── Split curtains ── */
    .pl-curtain {
      position: absolute;
      left: 0;
      right: 0;
      height: 50%;
      background: rgb(var(--accent-bg));
      z-index: 2;
      transition: transform 1s cubic-bezier(0.83, 0, 0.17, 1);
    }

    .pl-curtain--top { top: 0; transform-origin: top; }
    .pl-curtain--bottom { bottom: 0; transform-origin: bottom; }

    .pl.done .pl-curtain--top { transform: translateY(-100%); }
    .pl.done .pl-curtain--bottom { transform: translateY(100%); }

    /* ── Center content ── */
    .pl-center {
      position: relative;
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      width: 100%;
      max-width: 100vw;
      overflow: visible;
    }

    /* Counter — giant serif italic */
    .pl-counter-wrap {
      overflow: visible;
      perspective: 600px;
    }

    .pl-counter {
      display: block;
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: clamp(4.5rem, 15vw, 10rem);
      line-height: 1;
      letter-spacing: -0.04em;
      color: rgb(var(--accent));
      font-variant-numeric: tabular-nums;
      opacity: 0.9;
    }

    /* Exit: counter shrinks as curtains part */
    .pl.done .pl-center {
      opacity: 0;
      transform: scale(0.92);
      transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.83, 0, 0.17, 1);
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      .hero-title-line,
      .hero-letter,
      .hero-fade {
        transition-duration: 0.01ms !important;
        transform: none !important;
        opacity: 1 !important;
      }

      .preloader {
        display: none;
      }
    }
  </style>
