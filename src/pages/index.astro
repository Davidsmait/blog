---
import PostsList from '@/components/PostsList.astro'
import FooterItem from '@/components/layout/FooterItem.astro'
import ModeToggle from '@/components/mode/ModeToggle.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import config from '@/theme.config'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('posts')
const recentPosts = allPosts
  .sort(
    (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
  )
  .slice(0, 4)
---

<BaseLayout
  frontmatter={{ title: config.title, description: config.description }}
>
  <!-- Custom cursor — hidden on touch devices -->
  <div class="custom-cursor hidden sm:block" id="custom-cursor"></div>

  <div id="page-wrapper" class="noise-overlay">
    <div class="px-5 sm:px-6 lg:px-0">
      <main>
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- HERO — Photo-driven, stacked on mobile, overlapping grid   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <section
          class="relative min-h-[100svh] sm:min-h-[100vh]"
          id="hero-section"
        >
          <!-- Top micro-bar -->
          <div
            class="relative z-30 flex items-center justify-between pt-6 sm:pt-10"
          >
            <div class="reveal flex items-center gap-3">
              <span class="relative flex h-[5px] w-[5px]">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-[5px] w-[5px] rounded-full bg-green-500"
                ></span>
              </span>
              <span class="section-label">Disponible</span>
            </div>
            <div
              class="reveal flex items-center gap-5 text-[10px] font-medium uppercase tracking-[0.25em] opacity-25 sm:gap-6"
            >
              <a
                href="https://github.com/Davidsmait"
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline transition-opacity duration-300 hover:opacity-100"
                >Gh</a
              >
              <a
                href="https://www.linkedin.com/in/davidsanluisaguirre"
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline transition-opacity duration-300 hover:opacity-100"
                >Li</a
              >
              <a
                href="https://www.instagram.com/davidsanluisaguirre/"
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline transition-opacity duration-300 hover:opacity-100"
                >Ig</a
              >
            </div>
          </div>

          <!-- ── THE GRID: Stacked on mobile, overlapping on desktop ── -->
          <div
            class="relative z-10 flex min-h-[80svh] flex-col justify-center gap-6 sm:grid sm:min-h-[85vh] sm:grid-cols-[1fr_1fr] sm:items-center sm:gap-0"
          >
            <!-- LEFT: Visual block — photo -->
            <div class="reveal relative order-2 sm:order-1">
              <!-- Photo container -->
              <div
                class="hero-photo-wrap relative mx-auto aspect-[3/4] w-[65%] max-w-[280px] overflow-hidden rounded-[20px] sm:mx-0 sm:w-full sm:max-w-[400px] sm:rounded-[24px]"
              >
                <img
                  src="/me/me5-hero.jpeg"
                  alt="David San Luis Aguirre"
                  width="400"
                  height="533"
                  loading="eager"
                  class="hero-photo h-full w-full object-cover transition-transform duration-[1.5s]"
                  style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
                />
                <!-- Gradient overlay at bottom -->
                <div
                  class="pointer-events-none absolute inset-0"
                  style="background: linear-gradient(to top, rgb(var(--accent-bg)) 0%, transparent 40%);"
                >
                </div>
                <!-- Grain texture on photo -->
                <div
                  class="pointer-events-none absolute inset-0 opacity-[0.06] mix-blend-overlay"
                  style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E&quot;);"
                >
                </div>
              </div>

              <!-- Floating tag -->
              <div
                class="reveal reveal-delay-3 absolute -bottom-3 left-1/2 -translate-x-1/2 sm:bottom-4 sm:left-auto sm:right-[-20px] sm:translate-x-0"
              >
                <div
                  class="flex items-center gap-2 rounded-full border border-accent/[0.06] bg-accent-bg/90 px-3 py-1.5 backdrop-blur-sm sm:px-4 sm:py-2"
                >
                  <span
                    class="iconify text-[10px] text-accent opacity-50 tabler--coffee sm:text-xs"
                    aria-hidden="true"></span>
                  <span
                    class="text-[9px] font-medium uppercase tracking-[0.12em] opacity-40 sm:text-[10px] sm:tracking-[0.15em]"
                    >Barista &amp; Dev</span
                  >
                </div>
              </div>
            </div>

            <!-- RIGHT: Text block — name overlaps photo on desktop -->
            <div
              class="relative z-20 order-1 text-center sm:order-2 sm:-ml-[15%] sm:text-left"
            >
              <!-- "David" -->
              <div class="text-split-line" data-split-delay="200">
                <span
                  class="inline-block font-display text-[clamp(3rem,14vw,9rem)] font-bold leading-[0.85] tracking-[-0.06em] text-accent sm:text-[clamp(3.5rem,12vw,9rem)]"
                >
                  David
                </span>
              </div>

              <!-- "San Luis" — serif italic -->
              <div class="text-split-line" data-split-delay="350">
                <span
                  class="inline-block font-serif text-[clamp(2.5rem,11vw,7.5rem)] leading-[0.88] tracking-[-0.02em] text-accent opacity-65 sm:text-[clamp(3rem,10vw,7.5rem)]"
                >
                  San Luis
                </span>
              </div>

              <!-- Subtitle + micro-bio -->
              <div
                class="reveal reveal-delay-4 mx-auto mt-6 max-w-[280px] sm:mx-0 sm:mt-12 sm:max-w-[300px]"
              >
                <p
                  class="text-[12px] leading-[1.7] opacity-30 sm:text-[13px] sm:leading-[1.8]"
                >
                  Construyo experiencias digitales con tecnologías modernas y
                  exploro el café de especialidad como barista.
                </p>
                <p
                  class="mt-2 font-serif text-[12px] italic opacity-20 sm:mt-3 sm:text-[13px]"
                >
                  &mdash; Desde México
