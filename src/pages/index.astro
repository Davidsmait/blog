  <script>
    // ── Scroll-triggered sticky header ──
    function initScrollHeader() {
      const heroSection = document.getElementById('hero-section')
      const scrollHeader = document.getElementById('scroll-header')
      if (!heroSection || !scrollHeader) return

      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            // Hero visible → hide header
            scrollHeader.style.opacity = '0'
            scrollHeader.style.transform = 'translateY(-100%)'
            scrollHeader.classList.add('pointer-events-none')
          } else {
            // Hero gone → show header
            scrollHeader.style.opacity = '1'
            scrollHeader.style.transform = 'translateY(0)'
            scrollHeader.classList.remove('pointer-events-none')
          }
        },
        { threshold: 0.05 }
      )

      observer.observe(heroSection)
    }

    function initAwwwardsInteractions() {
      const isTouchDevice =
        'ontouchstart' in window || navigator.maxTouchPoints > 0
      const isFineCursor = window.matchMedia('(pointer: fine)').matches

      // ── Custom cursor — only on fine pointer devices ──
      const cursor = document.getElementById('custom-cursor')
      if (cursor && isFineCursor && !isTouchDevice) {
        let mouseX = 0,
          mouseY = 0
        let cursorX = 0,
          cursorY = 0

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX
          mouseY = e.clientY
          cursor.classList.add('visible')
        })

        document.addEventListener('mouseleave', () => {
          cursor.classList.remove('visible')
        })

        function animateCursor() {
          cursorX += (mouseX - cursorX) * 0.12
          cursorY += (mouseY - cursorY) * 0.12
          cursor.style.left = cursorX + 'px'
          cursor.style.top = cursorY + 'px'
          requestAnimationFrame(animateCursor)
        }
        animateCursor()

        const hoverTargets = document.querySelectorAll(
          'a, button, [data-cursor-hover]'
        )
        hoverTargets.forEach((el) => {
          el.addEventListener('mouseenter', () =>
            cursor.classList.add('hovering')
          )
          el.addEventListener('mouseleave', () =>
            cursor.classList.remove('hovering')
          )
        })
      }

      // ── Auto-fit hero role text — two lines, each fills container ──
      const heroContainer = document.getElementById('hero-role-container')
      const heroLines = heroContainer?.querySelectorAll('.hero-role-line')
      if (heroContainer && heroLines?.length) {
        const fitText = () => {
          const containerW = heroContainer.clientWidth
          heroLines.forEach((line) => {
            const el = line as HTMLElement
            let size = Math.round(containerW * 0.2)
            el.style.fontSize = size + 'px'
            while (el.scrollWidth > containerW && size > 20) {
              size -= 2
              el.style.fontSize = size + 'px'
            }
          })

          // Sync "BASED IN MÉXICO" width to the last line's rendered width
          const lastLine = heroLines[heroLines.length - 1] as HTMLElement
          const basedDesktop = document.getElementById('based-in-desktop')
          if (basedDesktop && lastLine) {
            basedDesktop.style.width = lastLine.scrollWidth + 'px'
          }
        }
        fitText()
        window.addEventListener('resize', fitText)
      }

      // ── "BASED IN MÉXICO" — match width to title on both mobile & desktop ──
      const fitBasedInMexico = () => {
        // Mobile: match to Developer line
        const devMobile = document.getElementById('hero-developer-mobile')
        const basedMobile = document.getElementById('based-in-mexico')
        if (devMobile && basedMobile) {
          const w = devMobile.offsetWidth
          if (w > 0) basedMobile.style.width = w + 'px'
        }
      }
      setTimeout(fitBasedInMexico, 100)
      window.addEventListener('resize', fitBasedInMexico)

      // ── Hero entrance animation — staggered like Olha ──
      const heroTitleLines = document.querySelectorAll('.hero-title-line')
      heroTitleLines.forEach((line) => {
        const delay = parseInt((line as HTMLElement).dataset.heroDelay || '0')
        setTimeout(() => line.classList.add('revealed'), delay)
      })

      const heroFades = document.querySelectorAll('.hero-fade')
      heroFades.forEach((el) => {
        const delay = parseInt((el as HTMLElement).dataset.heroDelay || '0')
        setTimeout(() => el.classList.add('revealed'), delay)
      })

      // ── Hero letter stagger ──
      const heroLetters = document.querySelectorAll('.hero-letter')
      heroLetters.forEach((letter, i) => {
        const el = letter as HTMLElement
        el.style.transitionDelay = `${600 + i * 40}ms`
        setTimeout(() => el.classList.add('revealed'), 300 + i * 40)
      })

      // ── Scroll reveals ──
      const reveals = document.querySelectorAll(
        '.reveal, .stagger-children, .hr-animated'
      )
      if (reveals.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add('revealed')
            })
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        )
        reveals.forEach((el) => observer.observe(el))
      }

      // ── Text split reveal ──
      const splitLines = document.querySelectorAll('.text-split-line')
      if (splitLines.length) {
        const splitObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const delay = parseInt(entry.target.dataset.splitDelay || '0')
                setTimeout(() => entry.target.classList.add('revealed'), delay)
              }
            })
          },
          { threshold: 0.3 }
        )
        splitLines.forEach((el) => splitObserver.observe(el))
      }

      // ── Explore rows: horizontal slide on hover (desktop only) ──
      if (!isTouchDevice) {
        const exploreRows = document.querySelectorAll('.explore-row')
        exploreRows.forEach((row) => {
          row.addEventListener('mouseenter', () => {
            const title = row.querySelector('h3')
            if (title)
              (title as HTMLElement).style.transform = 'translateX(12px)'
          })
          row.addEventListener('mouseleave', () => {
            const title = row.querySelector('h3')
            if (title) (title as HTMLElement).style.transform = 'translateX(0)'
          })
        })
      }

      // ── Contact links: indent on hover (desktop only) ──
      if (!isTouchDevice) {
        const contactLinks = document.querySelectorAll('.contact-link')
        contactLinks.forEach((link) => {
          const el = link as HTMLElement
          el.addEventListener('mouseenter', () => {
            el.style.paddingLeft = '16px'
          })
          el.addEventListener('mouseleave', () => {
            el.style.paddingLeft = '0'
          })
        })
      }

      // ── Scroll cue — hide on scroll ──
      const heroSection = document.getElementById('hero-section')
      if (heroSection) {
        let scrollCueHidden = false
        window.addEventListener(
          'scroll',
          () => {
            if (!scrollCueHidden && window.scrollY > 50) {
              heroSection.closest('.hero-bleed')?.classList.add('scrolled')
              scrollCueHidden = true
            }
          },
          { passive: true }
        )
      }

      // ── Based-in text — tracking expand ──
      document.querySelectorAll('.based-in-text').forEach((el) => {
        setTimeout(() => el.classList.add('revealed'), 1200)
      })

      // ── Hero title parallax on scroll (desktop) ──
      const heroTitle = document.getElementById('hero-role-container')
      if (heroTitle && !isTouchDevice) {
        let titleTicking = false
        window.addEventListener(
          'scroll',
          () => {
            if (!titleTicking) {
              requestAnimationFrame(() => {
                const rate = window.scrollY * 0.03
                heroTitle.style.transform = `translateY(${rate}px)`
                titleTicking = false
              })
              titleTicking = true
            }
          },
          { passive: true }
        )
      }

      // ── Hero photo parallax on scroll ──
      const heroPhoto = document.querySelector(
        '.hero-photo'
      ) as HTMLElement | null
      if (heroPhoto) {
        let ticking = false
        const parallaxRate = isTouchDevice ? 0.04 : 0.08

        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              requestAnimationFrame(() => {
                const scrollY = window.scrollY
                const rate = scrollY * parallaxRate
                heroPhoto.style.transform = `scale(1.05) translateY(${rate}px)`
                ticking = false
              })
              ticking = true
            }
          },
          { passive: true }
        )
      }

      // ── Hero photo hover zoom (desktop only) ──
      const heroPhotoWrap = document.querySelector(
        '.hero-photo-wrap'
      ) as HTMLElement | null
      if (heroPhotoWrap && heroPhoto && !isTouchDevice) {
        heroPhotoWrap.addEventListener('mouseenter', () => {
          heroPhoto.style.transform = `scale(1.08)`
        })
        heroPhotoWrap.addEventListener('mouseleave', () => {
          heroPhoto.style.transform = `scale(1.05)`
        })
      }

      document.documentElement.style.scrollBehavior = 'smooth'
    }

    function initPage() {
      initScrollHeader()
      initAwwwardsInteractions()
    }

    document.addEventListener('astro:page-load', initPage)
  </script>

  <!-- Inline styles for interactions -->
  <style>
    /* ── Hero bleed — break out of page-wrapper to full viewport ── */
    .hero-bleed {
      width: 100vw;
      max-width: 100vw;
      position: relative;
      left: 50%;
      transform: translateX(-50%);
      padding: 0 5vw;
      box-sizing: border-box;
    }

    @media (min-width: 640px) {
      .hero-bleed {
        padding: 0 4vw;
      }
    }

    /* ── Hero title entrance — slide up from below ── */
    .hero-title-wrap {
      overflow: hidden;
    }

    .hero-title-line {
      transform: translateY(110%);
      transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .hero-title-line.revealed {
      transform: translateY(0);
    }

    /* ── Hero letter stagger — individual letter animation ── */
    .hero-letter {
      display: inline-block;
      transform: translateY(20%) rotateX(40deg);
      opacity: 0;
      transition:
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 0.6s ease;
      transform-origin: bottom center;
    }

    .hero-letter.revealed {
      transform: translateY(0) rotateX(0deg);
      opacity: 1;
    }

    .hero-letter-wrap {
      perspective: 800px;
      display: inline;
    }

    /* ── Hero fade elements ── */
    .hero-fade {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .hero-fade.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Restore original opacity for elements that had opacity classes */
    .hero-fade.revealed[class*='opacity-'] {
      /* Let Tailwind opacity classes take precedence */
    }

    /* ── Scroll cue — breathing line ── */
    .scroll-cue-line {
      animation: scroll-cue-pulse 2s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
    @keyframes scroll-cue-pulse {
      0%,
      100% {
        transform: scaleY(1);
        opacity: 0.2;
      }
      50% {
        transform: scaleY(0.4);
        opacity: 0.5;
      }
    }

    /* Mobile scroll chevron — gentle bounce */
    .scroll-cue-chevron {
      animation: scroll-cue-bounce 2s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
    @keyframes scroll-cue-bounce {
      0%,
      100% {
        transform: translateY(0);
        opacity: 0.25;
      }
      50% {
        transform: translateY(3px);
        opacity: 0.45;
      }
    }

    /* Hide scroll cue once user scrolls */
    .hero-bleed.scrolled .scroll-cue-line,
    .hero-bleed.scrolled .scroll-cue-chevron {
      opacity: 0 !important;
      animation: none;
      transition: opacity 0.5s ease;
    }

    /* ── Hero letter hover — interactive on desktop ── */
    @media (hover: hover) {
      .hero-letter {
        transition:
          transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
          opacity 0.6s ease,
          color 0.3s ease;
      }
      .hero-letter.revealed:hover {
        transform: translateY(-6%) scale(1.05);
        color: rgb(var(--accent-glow, var(--accent)));
      }
    }

    /* ── Hero ambient gradient glow ── */
    .hero-bleed::before {
      content: '';
      position: absolute;
      bottom: 10%;
      left: 50%;
      transform: translateX(-50%);
      width: 60%;
      height: 40%;
      background: radial-gradient(
        ellipse,
        rgba(var(--accent-glow, var(--accent)), 0.03) 0%,
        transparent 70%
      );
      pointer-events: none;
      z-index: 0;
      animation: hero-glow-breathe 6s ease-in-out infinite;
    }
    @keyframes hero-glow-breathe {
      0%,
      100% {
        opacity: 0.5;
        transform: translateX(-50%) scale(1);
      }
      50% {
        opacity: 1;
        transform: translateX(-50%) scale(1.1);
      }
    }

    /* ── BASED IN — tracking expand on reveal ── */
    .based-in-text {
