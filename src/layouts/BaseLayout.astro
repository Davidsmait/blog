---
import '@/style/main.css'
import '@fontsource/ibm-plex-sans/latin.css'
import '@fontsource/instrument-serif/latin.css'

import ModeManager from '@/components/mode/ModeManager.astro'
import CopyCodeButtonsPlugin from '@/plugins/CopyCodeButtonsPlugin.astro'
import config from '@/theme.config'
import { resolveOgImageUrl } from '@/util'
import type { HTMLAttributes } from 'astro/types'
import { ViewTransitions } from 'astro:transitions'

export interface Props {
  frontmatter: Partial<{
    title: string
    author: string
    description: string
    canonicalURL: string
    openGraphImage: string | HTMLAttributes<'img'>
    publishedDate: Date
  }>
}

const {
  frontmatter: {
    title = config.title,
    author = config.author,
    description = config.description,
    canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
    openGraphImage = config.openGraphImage || '/ogImage.png',
    publishedDate
  }
} = Astro.props

let titleWithSuffix = title

if (
  String(title).toLowerCase() !== String(config.title).toLowerCase() &&
  !String(title).toLowerCase().includes(String(config.title).toLowerCase())
)
  titleWithSuffix += ` | ${config.title}`

const openGraphImageUrl = new URL(
  resolveOgImageUrl(openGraphImage) || '/ogImage.png',
  Astro.site
).href
---

<!doctype html>
<html
  lang={Astro.currentLocale || config.locale || 'es'}
  class={config.colorScheme || 'scheme-mono'}
>
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{titleWithSuffix}</title>
    <meta name="title" content={titleWithSuffix} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* hreflang for bilingual pages */}
    {
      Astro.url.pathname.startsWith('/en/') ? (
        <>
          <link rel="alternate" hreflang="en" href={canonicalURL} />
          <link
            rel="alternate"
            hreflang="es"
            href={
              new URL(
                Astro.url.pathname
                  .replace('/en/', '/')
                  .replace('cafe-en', 'cafe'),
                Astro.site
              ).href
            }
          />
          <link
            rel="alternate"
            hreflang="x-default"
            href={
              new URL(
                Astro.url.pathname
                  .replace('/en/', '/')
                  .replace('cafe-en', 'cafe'),
                Astro.site
              ).href
            }
          />
        </>
      ) : Astro.url.pathname === '/' ? (
        <>
          <link rel="alternate" hreflang="es" href={canonicalURL} />
          <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site).href} />
          <link rel="alternate" hreflang="x-default" href={canonicalURL} />
        </>
      ) : Astro.url.pathname.includes('/cafe/') ||
        Astro.url.pathname.includes('/barista-roadmap') ? (
        <>
          <link rel="alternate" hreflang="es" href={canonicalURL} />
          <link
            rel="alternate"
            hreflang="en"
            href={
              new URL(
                `/en${Astro.url.pathname}`.replace('/cafe/', '/cafe-en/'),
                Astro.site
              ).href
            }
          />
          <link rel="alternate" hreflang="x-default" href={canonicalURL} />
        </>
      ) : null
    }
    <link
      rel="alternate"
      type="application/rss+xml"
      title={title}
      href={new URL('feed.xml', Astro.site)}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Roadmap Barista de Especialidad"
      href={new URL('cafe/feed.xml', Astro.site)}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Specialty Coffee Barista Roadmap"
      href={new URL('en/feed.xml', Astro.site)}
    />

    <meta property="og:type" content={publishedDate ? 'article' : 'website'} />
    <meta property="og:site_name" content="David San Luis Aguirre" />
    <meta
      property="og:locale"
      content={Astro.currentLocale === 'en' ? 'en_US' : 'es_MX'}
    />
    <meta property="og:title" content={titleWithSuffix} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={openGraphImageUrl} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={titleWithSuffix} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={openGraphImageUrl} />

    {
      publishedDate && (
        <meta
          property="article:published_time"
          content={publishedDate.toISOString()}
        />
      )
    }
    <meta name="theme-color" content="#1a1a2e" />
    {
      publishedDate && (
        <>
          <meta
            property="article:author"
            content={new URL('/about/', Astro.site).href}
          />
        </>
      )
    }

    <slot name="head" />

    <ModeManager />
    <ViewTransitions />
    <script type="application/ld+json">
      [
        {
          "@context": "https://schema.org",
          "@type": "Person",
          "@id": "https://davidsanluisaguirre.com/#person",
          "name": "David San Luis Aguirre",
          "disambiguatingDescription": "Desarrollador Fullstack mexicano especializado en Angular, NestJS, TypeScript y AWS. Creador del Roadmap Barista de Especialidad. San Luis Aguirre es un apellido, no una referencia geográfica.",
          "alternateName": ["David San Luis", "David Aguirre", "Davidsmait"],
          "givenName": "David",
          "familyName": "San Luis Aguirre",
          "url": "https://davidsanluisaguirre.com",
          "mainEntityOfPage": "https://davidsanluisaguirre.com/about/",
          "image": "https://davidsanluisaguirre.com/me/me4.jpeg",
          "jobTitle": "Fullstack Developer",
          "worksFor": {
            "@type": "Organization",
            "name": "QRSof",
            "url": "https://qrsof.com"
          },
          "alumniOf": {
            "@type": "EducationalOrganization",
            "name": "Instituto Tecnológico de Pachuca"
          },
          "knowsAbout": [
            "Angular",
            "NestJS",
            "TypeScript",
            "AWS",
            "Ionic",
            "Scala",
            "React",
            "Next.js",
            "Astro",
            "LegalTech",
            "Specialty Coffee",
            "Café de Especialidad",
            "Barismo"
          ],
          "sameAs": [
            "https://www.wikidata.org/wiki/Q138853693",
            "https://www.instagram.com/davidsanluisaguirre/",
            "https://www.linkedin.com/in/davidsanluisaguirre",
            "https://github.com/Davidsmait"
          ],
          "nationality": {
            "@type": "Country",
            "name": "Mexico"
          },
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Pachuca de Soto",
            "addressRegion": "Hidalgo",
            "addressCountry": "MX"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "@id": "https://davidsanluisaguirre.com/#website",
          "name": "David San Luis Aguirre",
          "url": "https://davidsanluisaguirre.com",
          "description": "Blog personal de David San Luis Aguirre — desarrollo web, proyectos y café de especialidad.",
          "publisher": {
            "@id": "https://davidsanluisaguirre.com/#person"
          },
          "inLanguage": ["es", "en"]
        }
      ]
    </script>
  </head>
  <body>
    <slot />
    <CopyCodeButtonsPlugin />
  </body>
</html>
