---
import Footer from '@/components/layout/Footer.astro'
import Header from '@/components/layout/Header.astro'
import Quiz from '@/components/Quiz.astro'
import FlavorWheel from '@/components/diagrams/FlavorWheel.astro'
import RoastCurve from '@/components/diagrams/RoastCurve.astro'
import EspressoAnatomy from '@/components/diagrams/EspressoAnatomy.astro'
import ExtractionChart from '@/components/diagrams/ExtractionChart.astro'
import CoffeeBelt from '@/components/diagrams/CoffeeBelt.astro'
import BaseLayout, {
  type Props as BaseLayoutProps
} from '@/layouts/BaseLayout.astro'
import HeadingAnchorsPlugin from '@/plugins/HeadingAnchorsPlugin.astro'
import ScrollProgressPlugin from '@/plugins/ScrollProgressPlugin.astro'
import { quizzes } from '@/data/quizzes'
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

export interface Props {
  post: CollectionEntry<'cafe'> | CollectionEntry<'cafe-en'>
  collection?: 'cafe' | 'cafe-en'
}

const { post, collection: collectionProp } = Astro.props

// Detect language from URL or prop
const isEnglish =
  collectionProp === 'cafe-en' || Astro.url.pathname.startsWith('/en/')
const lessonBasePath = isEnglish ? '/en/cafe-en' : '/cafe'
const roadmapPath = isEnglish ? '/en/barista-roadmap' : '/barista-roadmap'
const lang = isEnglish ? 'en' : 'es'

const {
  Content,
  remarkPluginFrontmatter: { readingTime }
} = await post.render()

const frontmatter: BaseLayoutProps['frontmatter'] = {
  ...post.data,
  openGraphImage: post.data.openGraphImage || `/cafe/${post.slug}.png`
}

const allCafe = isEnglish
  ? await getCollection('cafe-en')
  : await getCollection('cafe')
const phase = post.data.phase
const totalInPhase = phase
  ? allCafe
      .filter((p) => p.data.phase === phase && !p.data.draft)
      .sort((a, b) => (a.data.lessonOrder ?? 0) - (b.data.lessonOrder ?? 0))
  : []

const currentIdx = totalInPhase.findIndex((p) => p.slug === post.slug)
const prev = currentIdx > 0 ? totalInPhase[currentIdx - 1] : null
const next =
  currentIdx < totalInPhase.length - 1 ? totalInPhase[currentIdx + 1] : null

const phaseNamesEs: Record<number, string> = {
  1: 'Fundamentos',
  2: 'Espresso',
  3: 'Filtrado',
  4: 'Catación',
  5: 'Latte art',
  6: 'Tueste',
  7: 'Metodología Rao',
  8: 'Física',
  9: 'Carrera profesional'
}
const phaseNamesEn: Record<number, string> = {
  1: 'Fundamentals',
  2: 'Espresso',
  3: 'Filter methods',
  4: 'Cupping',
  5: 'Latte art',
  6: 'Roasting',
  7: 'Rao Methodology',
  8: 'Physics',
  9: 'Professional career'
}
const phaseNames = isEnglish ? phaseNamesEn : phaseNamesEs
const phaseName = phase ? phaseNames[phase] : null
const lessonNum = post.data.lessonOrder ?? currentIdx + 1

// i18n labels
const labels = isEnglish
  ? {
      lesson: 'Lesson',
      of: 'of',
      prev: 'Previous',
      next: 'Next',
      phaseComplete: 'Phase complete',
      backToRoadmap: 'Back to roadmap'
    }
  : {
      lesson: 'Lección',
      of: 'de',
      prev: 'Anterior',
      next: 'Siguiente',
      phaseComplete: 'Fase completada',
      backToRoadmap: 'Volver al roadmap'
    }

const lessonUrl = new URL(`${lessonBasePath}/${post.slug}`, Astro.site).href
const roadmapUrl = new URL(roadmapPath, Astro.site).href

// Educational level based on phase
const educationalLevels: Record<number, string> = {
  1: 'Beginner',
  2: 'Beginner',
  3: 'Intermediate',
  4: 'Intermediate',
  5: 'Intermediate',
  6: 'Advanced',
  7: 'Advanced',
  8: 'Advanced',
  9: 'Expert'
}

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: frontmatter.title,
  description: post.data.description,
  url: lessonUrl,
  provider: {
    '@id': 'https://davidsanluisaguirre.com/#person'
  },
  courseCode: phase ? `BARISTA-${phase}.${lessonNum}` : undefined,
  inLanguage: lang,
  educationalLevel: phase ? educationalLevels[phase] : undefined,
  isPartOf: {
    '@type': 'Course',
    name: isEnglish
      ? `Phase ${phase}: ${phaseName}`
      : `Fase ${phase}: ${phaseName}`,
    url: roadmapUrl
  },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: readingTime
  },
  author: {
    '@id': 'https://davidsanluisaguirre.com/#person'
  },
  isPartOf: {
    '@id': 'https://davidsanluisaguirre.com/#website'
  }
})

// BreadcrumbList schema
const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Roadmap',
      item: roadmapUrl
    },
    ...(phase && phaseName
      ? [
          {
            '@type': 'ListItem',
            position: 2,
            name: isEnglish
              ? `Phase ${phase}: ${phaseName}`
              : `Fase ${phase}: ${phaseName}`,
            item: roadmapUrl
          }
        ]
      : []),
    {
      '@type': 'ListItem',
      position: phase ? 3 : 2,
      name: frontmatter.title,
      item: lessonUrl
    }
  ]
})

// Quiz data for this lesson
const quizData = quizzes[post.slug]
const quizQuestions = quizData ? (isEnglish ? quizData.en : quizData.es) : []

// Diagrams mapped to lesson slugs
const diagramMap: Record<string, string> = {
  'roadmap-4-3-rueda-sabores-descriptores': 'flavor-wheel',
  'roadmap-6-2-curva-tueste-ror': 'roast-curve',
  'roadmap-2-1-anatomia-espresso': 'espresso-anatomy',
  'roadmap-1-3-ciencia-extraccion': 'extraction-chart',
  'roadmap-7-3-refractometro-tds': 'extraction-chart',
  'roadmap-1-2-del-grano-a-la-taza': 'coffee-belt'
}
const diagram = diagramMap[post.slug] || null
---

<BaseLayout frontmatter={frontmatter}>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <script type="application/ld+json" set:html={breadcrumbLd} slot="head" />
  {
    prev && (
      <link rel="prev" href={`${lessonBasePath}/${prev.slug}`} slot="head" />
    )
  }
  {
    next && (
      <link rel="next" href={`${lessonBasePath}/${next.slug}`} slot="head" />
    )
  }

  <div id="page-wrapper" class="noise-overlay">
    <div class="px-5 sm:px-6 lg:px-0">
      <Header activeHeaderLink="Café" />

      <main class="lesson-main mt-8 sm:mt-14">
        <!-- ── Editorial breadcrumb ── -->
        <div class="reveal mb-8 sm:mb-12">
          <div
            class="flex flex-wrap items-center gap-3 text-[11px] font-medium uppercase tracking-[0.15em] opacity-20"
          >
            <a
              href={roadmapPath}
              class="no-underline opacity-70 transition-opacity duration-300 hover:opacity-100"
              >Roadmap</a
            >
            <span class="h-[1px] w-4 bg-accent/10"></span>
            {
              phaseName && (
                <>
                  <span>{isEnglish ? `Phase ${phase}` : `Fase ${phase}`}</span>
                  <span class="h-[1px] w-4 bg-accent/10" />
                </>
              )
            }
            <span
              >{labels.lesson}
              {lessonNum}
              {labels.of}
              {totalInPhase.length}</span
            >
            <span class="h-[1px] w-4 bg-accent/10"></span>
            <span>{readingTime}</span>
          </div>
        </div>

        <!-- ── Title ── -->
        <div class="reveal mb-6 sm:mb-8">
          <h1
            class="m-0 font-display text-[clamp(1.8rem,5vw,3rem)] font-bold leading-[1.1] tracking-tighter-brand text-accent sm:text-[clamp(2rem,4vw,3.5rem)]"
          >
            {frontmatter.title}
          </h1>
        </div>

        <!-- ── Description ── -->
        {
          post.data.description && (
            <div class="reveal mb-6 sm:mb-8">
              <p class="m-0 max-w-xl text-[15px] leading-[1.7] opacity-35 sm:text-base">
                {post.data.description}
              </p>
            </div>
          )
        }

        <!-- ── Progress steps ── -->
        {
          totalInPhase.length > 1 && (
            <div class="reveal mb-8 sm:mb-10">
              <div class="lesson-steps" aria-hidden="true">
                {totalInPhase.map((_, i) => (
                  <span
                    class:list={[
                      'step',
                      { done: i <= currentIdx, current: i === currentIdx }
                    ]}
                  />
                ))}
              </div>
            </div>
          )
        }

        <div class="hr-animated mb-8 sm:mb-12"></div>

        <!-- ── Content ── -->
        <article class="reveal reveal-delay-1 lesson-body">
          <Content />
        </article>

        {
          diagram === 'flavor-wheel' && (
            <FlavorWheel lang={lang as 'es' | 'en'} />
          )
        }
        {diagram === 'roast-curve' && <RoastCurve lang={lang as 'es' | 'en'} />}
        {
          diagram === 'espresso-anatomy' && (
            <EspressoAnatomy lang={lang as 'es' | 'en'} />
          )
        }
        {
          diagram === 'extraction-chart' && (
            <ExtractionChart lang={lang as 'es' | 'en'} />
          )
        }
        {diagram === 'coffee-belt' && <CoffeeBelt lang={lang as 'es' | 'en'} />}

        {
          quizQuestions.length > 0 && (
            <Quiz questions={quizQuestions} lang={lang as 'es' | 'en'} />
          )
        }

        <!-- ── Prev / Next navigation ── -->
        <div class="reveal mt-16 sm:mt-20">
          <div class="hr-animated mb-8"></div>
          <nav class="lesson-nav">
            {
              prev ? (
                <a
                  href={`${lessonBasePath}/${prev.slug}`}
                  class="nav-link nav-link--prev"
                  data-cursor-hover
                >
                  <span class="nav-direction">{labels.prev}</span>
                  <span class="nav-title">{prev.data.title}</span>
                </a>
              ) : (
                <div />
              )
            }
            {
              next ? (
                <a
                  href={`${lessonBasePath}/${next.slug}`}
                  class="nav-link nav-link--next"
                  data-cursor-hover
                >
                  <span class="nav-direction">{labels.next}</span>
                  <span class="nav-title">{next.data.title}</span>
                </a>
              ) : (
                <a
                  href={roadmapPath}
                  class="nav-link nav-link--next"
                  data-cursor-hover
                >
                  <span class="nav-direction">{labels.phaseComplete}</span>
                  <span class="nav-title">{labels.backToRoadmap}</span>
                </a>
              )
            }
          </nav>
        </div>
      </main>

      <Footer />
    </div>
  </div>

  <ScrollProgressPlugin />
  <HeadingAnchorsPlugin />

  <!-- Page animations -->
  <script>
    function initPageAnimations() {
      const reveals = document.querySelectorAll(
        '.reveal, .stagger-children, .hr-animated'
      )
      if (reveals.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add('revealed')
            })
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        )
        reveals.forEach((el) => observer.observe(el))
      }

      const isTouchDevice =
        'ontouchstart' in window || navigator.maxTouchPoints > 0
      if (!isTouchDevice && window.matchMedia('(pointer: fine)').matches) {
        const hoverTargets = document.querySelectorAll('[data-cursor-hover]')
        hoverTargets.forEach((el) => {
          el.addEventListener('mouseenter', () => {
            document.getElementById('custom-cursor')?.classList.add('hovering')
          })
          el.addEventListener('mouseleave', () => {
            document
              .getElementById('custom-cursor')
              ?.classList.remove('hovering')
          })
        })
      }
    }

    document.addEventListener('astro:page-load', initPageAnimations)

    /* ── Animated details/summary ── */
    function initDetailsAnimation() {
      document.querySelectorAll('.lesson-body details').forEach((details) => {
        // Wrap all non-summary children in animated containers
        const summary = details.querySelector('summary')
        if (!summary || details.querySelector('.details-content')) return

        const content = document.createElement('div')
        content.className = 'details-content'
        const inner = document.createElement('div')
        inner.className = 'details-inner'

        // Move all children except summary into the inner wrapper
        const children = Array.from(details.children).filter(
          (el) => el !== summary
        )
        children.forEach((child) => inner.appendChild(child))
        content.appendChild(inner)
        details.appendChild(content)

        // Animate open/close
        summary.addEventListener('click', (e) => {
          e.preventDefault()

          if (details.open) {
            // Closing: animate first, then remove open
            content.style.gridTemplateRows = '0fr'
            content.style.opacity = '0'
            const onEnd = () => {
              details.open = false
              content.removeEventListener('transitionend', onEnd)
            }
            content.addEventListener('transitionend', onEnd, { once: true })
            // Fallback in case transitionend doesn't fire
            setTimeout(() => { if (details.open) details.open = false }, 600)
          } else {
            // Opening: set open first, then animate in next frame
            details.open = true
            requestAnimationFrame(() => {
              content.style.gridTemplateRows = '1fr'
              content.style.opacity = '1'
            })
          }
        })

        // Ensure initial state is correct
        if (!details.open) {
          content.style.gridTemplateRows = '0fr'
          content.style.opacity = '0'
        } else {
          content.style.gridTemplateRows = '1fr'
          content.style.opacity = '1'
        }
      })
    }

    document.addEventListener('astro:page-load', initDetailsAnimation)
  </script>
</BaseLayout>

<style>
  /* ── Main ── */
  .lesson-main {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Progress steps ── */
  .lesson-steps {
    display: flex;
    gap: 4px;
  }
  .step {
    flex: 1;
    height: 2px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    max-width: 3.5rem;
  }
  .step.done {
    background: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
  .step.current {
    background: var(--color-accent);
  }

  /* ── Body prose ── */
  .lesson-body {
    font-size: 1.0625rem;
    line-height: 1.9;
    color: inherit;
  }
  @media (min-width: 640px) {
    .lesson-body {
      font-size: 1.125rem;
    }
  }

  .lesson-body :global(h2) {
    font-size: 1.375rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.25;
  }
  .lesson-body :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .lesson-body :global(p) {
    margin-bottom: 1.5rem;
    opacity: 0.75;
  }
  .lesson-body :global(strong) {
    font-weight: 600;
    opacity: 1;
  }
  .lesson-body :global(em) {
    font-style: italic;
  }
  .lesson-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(
      in srgb,
      var(--color-accent) 25%,
      transparent
    );
    text-underline-offset: 3px;
    transition: text-decoration-color 0.3s ease;
  }
  .lesson-body :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .lesson-body :global(ul),
  .lesson-body :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .lesson-body :global(li) {
    margin-bottom: 0.5rem;
    opacity: 0.75;
    line-height: 1.8;
  }
  .lesson-body :global(li strong) {
    opacity: 1;
  }
  .lesson-body :global(li::marker) {
    color: color-mix(in srgb, var(--color-accent) 35%, transparent);
  }

  .lesson-body :global(blockquote) {
    border-left: 2px solid
      color-mix(in srgb, var(--color-accent) 15%, transparent);
    padding: 0.75rem 0 0.75rem 1.25rem;
    margin: 2rem 0;
    background: color-mix(in srgb, var(--color-accent) 2%, transparent);
    border-radius: 0 8px 8px 0;
  }
  .lesson-body :global(blockquote p) {
    opacity: 0.55;
    margin-bottom: 0;
    font-style: italic;
  }

  .lesson-body :global(code) {
    font-size: 0.85em;
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 5px;
    font-family: ui-monospace, monospace;
  }
  .lesson-body :global(pre) {
    margin: 1.75rem 0;
    padding: 1.25rem;
    border-radius: 10px;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.7;
  }
  .lesson-body :global(pre code) {
    background: none;
    padding: 0;
  }

  .lesson-body :global(hr) {
    border: none;
    height: 1px;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    margin: 3rem auto;
    max-width: 4rem;
  }

  .lesson-body :global(img) {
    border-radius: 10px;
    margin: 2rem 0;
    max-width: 100%;
  }

  .lesson-body :global(table) {
    width: 100%;
    font-size: 0.9375rem;
    margin: 2rem 0;
    border-collapse: collapse;
  }
  .lesson-body :global(th),
  .lesson-body :global(td) {
    padding: 0.625rem 0.875rem;
    text-align: left;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .lesson-body :global(th) {
    font-weight: 600;
    font-size: 0.8125rem;
    opacity: 0.45;
  }
  .lesson-body :global(td) {
    opacity: 0.65;
  }

  /* ── Progressive Disclosure (details/summary) ── */
  .lesson-body :global(details) {
    margin: 1.5rem 0 2rem;
    padding: 0;
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
  }

  .lesson-body :global(details:hover) {
    border-color: color-mix(in srgb, var(--color-accent) 22%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .lesson-body :global(details[open]) {
    border-color: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .lesson-body :global(summary) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    cursor: pointer;
    font-weight: 550;
    font-size: 0.9375rem;
    opacity: 0.9;
    list-style: none;
    padding: 0.875rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    transition: opacity 0.2s ease, background 0.2s ease;
    user-select: none;
  }

  .lesson-body :global(summary:hover) {
    opacity: 1;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .lesson-body :global(details[open] > summary) {
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .lesson-body :global(summary::-webkit-details-marker) {
    display: none;
  }

  .lesson-body :global(summary::before) {
    content: none;
  }

  .lesson-body :global(summary::after) {
    content: '＋';
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    opacity: 0.5;
    transition: transform 0.5s var(--ease-out-expo), background 0.3s ease, opacity 0.3s ease;
  }

  .lesson-body :global(summary:hover::after) {
    opacity: 0.85;
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .lesson-body :global(details[open] > summary::after) {
    content: '−';
    transform: rotate(180deg);
  }

  /* ── Animated content wrapper (injected via JS) ── */
  .lesson-body :global(.details-content) {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.5s var(--ease-out-expo),
                opacity 0.4s ease;
  }

  .lesson-body :global(.details-content > .details-inner) {
    overflow: hidden;
  }

  .lesson-body :global(details[open] > .details-content) {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  /* Content padding */
  .lesson-body :global(.details-inner > h3),
  .lesson-body :global(.details-inner > p),
  .lesson-body :global(.details-inner > ul),
  .lesson-body :global(.details-inner > ol) {
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  .lesson-body :global(.details-inner > :first-child) {
    padding-top: 1.25rem;
  }

  .lesson-body :global(.details-inner > p:last-child) {
    margin-bottom: 0;
    padding-bottom: 1.25rem;
  }

  .lesson-body :global(.details-inner > ul:last-child),
  .lesson-body :global(.details-inner > ol:last-child) {
    padding-bottom: 0.75rem;
  }

  /* ── Navigation ── */
  .lesson-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .lesson-nav {
      grid-template-columns: 1fr;
    }
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
    border-radius: 0.75rem;
    background: transparent;
    transition:
      border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover {
    border-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
