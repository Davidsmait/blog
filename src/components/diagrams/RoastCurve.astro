---
interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    'Drying Phase': 'Drying Phase',
    'Maillard Reaction': 'Maillard Reaction',
    'First Crack': 'First Crack',
    'Development': 'Development',
    'Time (min)': 'Time (min)',
    'Temperature (°C)': 'Temperature (°C)',
  },
  es: {
    'Drying Phase': 'Fase de Secado',
    'Maillard Reaction': 'Reacción de Maillard',
    'First Crack': 'Primera Grieta',
    'Development': 'Desarrollo',
    'Time (min)': 'Tiempo (min)',
    'Temperature (°C)': 'Temperatura (°C)',
  }
};

const t = (key: string) => labels[lang][key as keyof typeof labels['en']] || key;

// Roast curve points
const points = [
  { time: 0, temp: 150 },
  { time: 2, temp: 160 },
  { time: 3.5, temp: 180 },
  { time: 5, temp: 200 },
  { time: 7, temp: 210 },
  { time: 8, temp: 212 },
  { time: 9, temp: 215 },
  { time: 11, temp: 225 },
  { time: 12, temp: 228 },
  { time: 14, temp: 230 },
];

const phases = [
  { name: 'Drying Phase', start: 0, end: 3.5, color: '#d4a574' },
  { name: 'Maillard Reaction', start: 3.5, end: 8, color: '#9d7548' },
  { name: 'First Crack', start: 8, end: 9, color: '#6b5437' },
  { name: 'Development', start: 9, end: 14, color: '#4a3728' },
];

const xScale = (time: number) => 30 + (time / 14) * 340;
const yScale = (temp: number) => 350 - ((temp - 150) / 80) * 300;
---

<div class="diagram-roast-curve" aria-label={`Roast Curve (${lang})`}>
  <svg viewBox="0 0 400 380" xmlns="http://www.w3.org/2000/svg" role="img">
    <!-- Phase backgrounds -->
    {phases.map((phase) => {
      const x1 = xScale(phase.start);
      const x2 = xScale(phase.end);
      return (
        <rect
          key={phase.name}
          x={x1}
          y="10"
          width={x2 - x1}
          height="330"
          fill={phase.color}
          opacity="0.1"
          class="phase-bg"
        />
      );
    })}

    <!-- Grid lines -->
    <defs>
      <pattern id="grid" width="50" height="50" patternUnits="userSpaceOnUse">
        <path d="M 50 0 L 0 0 0 50" fill="none" stroke="color-mix(in srgb, var(--color-accent) 5%, transparent)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect x="30" y="10" width="340" height="330" fill="url(#grid)"/>

    <!-- Axes -->
    <line x1="30" y1="10" x2="30" y2="350" stroke="color-mix(in srgb, var(--color-accent) 30%, transparent)" stroke-width="1.5"/>
    <line x1="30" y1="350" x2="370" y2="350" stroke="color-mix(in srgb, var(--color-accent) 30%, transparent)" stroke-width="1.5"/>

    <!-- Y-axis labels (Temperature) -->
    {[150, 170, 190, 210, 230].map((temp) => {
      const y = yScale(temp);
      return (
        <g key={`temp-${temp}`}>
          <line x1="25" y1={y} x2="30" y2={y} stroke="color-mix(in srgb, var(--color-accent) 20%, transparent)" stroke-width="1"/>
          <text x="20" y={y + 4} text-anchor="end" font-size="11" fill="color-mix(in srgb, var(--color-accent) 50%, transparent)">
            {temp}
          </text>
        </g>
      );
    })}

    <!-- X-axis labels (Time) -->
    {[0, 2, 4, 6, 8, 10, 12, 14].map((time) => {
      const x = xScale(time);
      return (
        <g key={`time-${time}`}>
          <line x1={x} y1="350" x2={x} y2="355" stroke="color-mix(in srgb, var(--color-accent) 20%, transparent)" stroke-width="1"/>
          <text x={x} y="370" text-anchor="middle" font-size="11" fill="color-mix(in srgb, var(--color-accent) 50%, transparent)">
            {time}
          </text>
        </g>
      );
    })}

    <!-- Axis labels -->
    <text x="15" y="30" font-size="11" font-weight="bold" fill="color-mix(in srgb, var(--color-accent) 60%, transparent)">
      °C
    </text>
    <text x="375" y="365" font-size="11" font-weight="bold" fill="color-mix(in srgb, var(--color-accent) 60%, transparent)">
      min
    </text>

    <!-- Roast curve line -->
    <polyline
      points={points.map(p => `${xScale(p.time)},${yScale(p.temp)}`).join(' ')}
      fill="none"
      stroke="color-mix(in srgb, var(--color-accent) 80%, transparent)"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="curve-line"
      pathLength="1"
      style={`stroke-dasharray: 1; stroke-dashoffset: 1; animation: drawCurve 3s ease-out forwards;`}
    />

    <!-- Phase markers -->
    {points.map((point, i) => {
      const phase = phases.find(p => point.time >= p.start && point.time < p.end);
      if (!phase) return null;

      return (
        <g key={`marker-${i}`} class="marker" data-phase={phase.name}>
          <circle
            cx={xScale(point.time)}
            cy={yScale(point.temp)}
            r="3.5"
            fill={phase.color}
            stroke="white"
            stroke-width="1.5"
            class="marker-dot"
          />
        </g>
      );
    })}

    <!-- Phase annotations -->
    {phases.map((phase) => {
      const midTime = (phase.start + phase.end) / 2;
      const x = xScale(midTime);
      return (
        <g key={`label-${phase.name}`} class="phase-label">
          <text x={x} y="25" text-anchor="middle" font-size="12" font-weight="600" fill={phase.color} opacity="0.8">
            {t(phase.name)}
          </text>
        </g>
      );
    })}
  </svg>

  <div class="tooltip" id="roast-tooltip"></div>
</div>

<style>
  :root {
    --color-accent: #8b6f47;
  }

  .diagram-roast-curve {
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    position: relative;
  }

  svg {
    width: 100%;
    height: auto;
    display: block;
    font-family: inherit;
  }

  .curve-line {
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.1));
  }

  .marker {
    cursor: pointer;
  }

  .marker-dot {
    transition: r 0.2s ease;
  }

  .marker:hover .marker-dot {
    r: 5;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
  }

  .phase-bg {
    transition: opacity 0.2s ease;
  }

  .phase-label text {
    user-select: none;
  }

  .tooltip {
    position: absolute;
    background: color-mix(in srgb, var(--color-accent) 90%, transparent);
    color: white;
    padding: 8px 12px;
    border-radius: 4px;
    font-size: 12px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 10;
  }

  .tooltip.visible {
    opacity: 1;
  }

  @keyframes drawCurve {
    from {
      stroke-dashoffset: 1;
    }
    to {
      stroke-dashoffset: 0;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const polyline = entry.target.querySelector('.curve-line') as SVGPolylineElement;
        if (polyline) {
          polyline.style.animation = 'drawCurve 3s ease-out forwards';
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  const diagram = document.querySelector('.diagram-roast-curve');
  if (diagram) observer.observe(diagram);

  const markers = document.querySelectorAll('.marker');
  const tooltip = document.getElementById('roast-tooltip');

  const phaseDetails = {
    'Drying Phase': 'Beans dry, initial color change (0-3.5 min, ~150-180°C)',
    'Maillard Reaction': 'Browning begins, complex flavor development (3.5-8 min)',
    'First Crack': 'Beans expand, audible crack, light roast point (~8 min)',
    'Development': 'Final browning, dark roast development (9-14 min)'
  };

  markers.forEach(marker => {
    marker.addEventListener('mouseenter', (e) => {
      const phase = marker.dataset.phase as keyof typeof phaseDetails;
      if (phase && tooltip) {
        tooltip.textContent = phaseDetails[phase] || phase;
        tooltip.classList.add('visible');
        const rect = (e.target as SVGElement).getBoundingClientRect();
        tooltip.style.left = rect.left + 'px';
        tooltip.style.top = (rect.top - 35) + 'px';
      }
    });

    marker.addEventListener('mouseleave', () => {
      tooltip?.classList.remove('visible');
    });
  });
</script>
