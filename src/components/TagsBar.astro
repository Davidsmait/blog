---
import type { ResolvedTag } from '@/types'

export interface Props {
  tags: ResolvedTag[]
  maxVisible?: number
}

const { tags, maxVisible = 0 } = Astro.props

const visibleTags = maxVisible > 0 ? tags.slice(0, maxVisible) : tags
const remainingCount = maxVisible > 0 ? tags.length - maxVisible : 0
---

<div class="flex flex-wrap items-center gap-1.5 text-xs">
  {
    visibleTags.map(({ tag, icon }) => (
      <a
        class="flex items-center gap-1 rounded-full bg-accent/8 px-2 py-0.5 no-underline opacity-60 transition-all duration-200 hover:bg-accent/15 hover:opacity-100"
        href={`/tags/${tag}`}
      >
        <span class={`iconify text-[0.7rem] ${icon}`} />
        <span class="font-medium">{tag}</span>
      </a>
    ))
  }
  {remainingCount > 0 && (
    <span class="rounded-full bg-accent/5 px-2 py-0.5 text-xs opacity-40">
      +{remainingCount}
    </span>
  )}
</div>
