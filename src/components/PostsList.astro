---
import TagsBar from '@/components/TagsBar.astro'
import { toDateString } from '@/util'
import { resolveTags } from '@/util/tags'
import type { CollectionEntry } from 'astro:content'

type PostEntry = CollectionEntry<'posts'> | CollectionEntry<'cafe'>

export interface Props {
  posts: PostEntry[]
  featured?: boolean
}

const { posts, featured = false } = Astro.props

const sortedPosts = [...posts].sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
---

<ul class="flex flex-col gap-0 p-0">
  {
    sortedPosts.map((post, index) => (
      <li class="reveal group list-none border-b border-accent/[0.08] last:border-0" style={`transition-delay: ${index * 0.08}s`}>
        <a
          class="flex flex-col gap-3 rounded-lg py-6 no-underline transition-all duration-500 hover:bg-accent/[0.03] sm:flex-row sm:items-start sm:gap-8 sm:px-4 sm:py-8"
          href={`/${post.collection === 'cafe' ? 'cafe' : 'posts'}/${post.slug}`}
          data-astro-prefetch
          data-cursor-hover
        >
          {/* Counter */}
          <span class="section-number shrink-0 pt-1 hidden sm:block">
            ({String(index + 1).padStart(2, '0')})
          </span>

          {/* Content */}
          <div class="flex-1">
            <div class="flex flex-col justify-between gap-2 sm:flex-row sm:items-start">
              <h3 class:list={[
                'm-0 font-display font-semibold tracking-tight-brand text-accent transition-opacity duration-500 group-hover:opacity-70',
                featured && index === 0 ? 'text-xl sm:text-2xl' : 'text-lg'
              ]}>
                {post.data.title}
              </h3>
              <time datetime={post.data.publishedDate.toISOString()} class="shrink-0 text-[11px] font-medium uppercase tracking-[0.15em] opacity-30">
                {toDateString(post.data.publishedDate)}
              </time>
            </div>
            <p class="m-0 mt-2 text-[13px] leading-relaxed opacity-40">
              {post.data.description}
            </p>
            <div class="mt-3 pointer-events-none">
              <TagsBar tags={resolveTags(post.data.tags)} maxVisible={3} />
            </div>
          </div>

          {/* Arrow — appears on hover */}
          <span class="hidden shrink-0 text-sm opacity-0 transition-all duration-500 group-hover:opacity-50 group-hover:translate-x-1 sm:block">
            &rarr;
          </span>
        </a>
      </li>
    ))
  }
</ul>
