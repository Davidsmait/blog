---
import TagsBar from '@/components/TagsBar.astro'
import { toMonthString } from '@/util'
import { sortProjects } from '@/util/projects'
import { resolveTags } from '@/util/tags'
import type { CollectionEntry } from 'astro:content'
import Separator from './layout/Separator.astro'

export interface Props {
  projects: CollectionEntry<'projects'>[]
}

const { projects } = Astro.props

const sortedProjects = [...projects].sort(sortProjects)

const isSpanish = !Astro.url.pathname.startsWith('/en/')
const nowLabel = isSpanish ? 'Ahora' : 'Now'

const renderedProjects = await Promise.all(
  sortedProjects.map(async (project) => {
    const { Content } = await project.render()

    return {
      ...project,
      Content
    }
  })
)
---

{renderedProjects.length === 0 && (
  <p class="text-sm opacity-40 py-8 text-center">{isSpanish ? 'No hay proyectos todavía.' : 'No projects yet.'}</p>
)}

<ul class="flex flex-col gap-0 p-0">
  {
    renderedProjects.map(({ data, Content }, index) => (
      <li class="reveal group list-none border-b border-accent/[0.08] last:border-0" style={`transition-delay: ${index * 0.1}s`}>
        <div class="rounded-lg py-6 transition-all duration-500 group-hover:bg-accent/[0.03] sm:px-4 sm:py-8" data-cursor-hover>
          <div class="flex flex-col justify-between gap-2 sm:flex-row sm:items-center">
            <div class="flex items-center gap-3 sm:gap-5">
              <span class="section-number shrink-0">({String(index + 1).padStart(2, '0')})</span>
              {data.url ? (
                <a
                  class="font-display text-lg font-semibold tracking-tight-brand text-accent no-underline transition-opacity duration-500 hover:opacity-70 sm:text-xl"
                  href={data.url}
                  target={!data.url.startsWith('/') ? '_blank' : '_self'}
                  rel={!data.url.startsWith('/') ? 'noopener noreferrer' : undefined}
                >
                  {data.title}
                  {!data.url.startsWith('/') && (
                    <span class="ml-1 text-[11px] opacity-30">&nearr;</span>
                  )}
                </a>
              ) : (
                <span class="font-display text-lg font-semibold tracking-tight-brand text-accent sm:text-xl">{data.title}</span>
              )}
            </div>
            <div class="ml-8 text-[11px] font-medium uppercase tracking-[0.15em] opacity-30 sm:ml-0">
              <time datetime={data.startDate.toISOString()}>{toMonthString(data.startDate)}</time> –
              {data.endDate ? <time datetime={data.endDate.toISOString()}>{toMonthString(data.endDate)}</time> : nowLabel}
            </div>
          </div>
          <div class="ml-8 mt-2 sm:ml-12">
            <div class="pointer-events-none">
              <TagsBar tags={resolveTags(data.tags)} maxVisible={3} />
            </div>
            <div class="mt-2 text-[13px] leading-relaxed opacity-40">
              <Content />
            </div>
          </div>
        </div>
      </li>
    ))
  }
</ul>
