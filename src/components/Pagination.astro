---
import type { Page } from 'astro'

export interface Props {
  page: Page
}

const { page } = Astro.props

const isSpanish = !Astro.url.pathname.startsWith('/en/')
const prevLabel = isSpanish ? 'Anterior' : 'Previous'
const nextLabel = isSpanish ? 'Siguiente' : 'Next'
---

{
  page.lastPage > 1 && (
    <nav class="mb-8 flex w-full grow items-end justify-center" aria-label={isSpanish ? 'Paginación' : 'Pagination'}>
      <div class="flex items-center gap-6 text-[12px] font-medium uppercase tracking-[0.15em]">
        {page.url.prev ? (
          <a class="no-underline text-accent opacity-40 transition-opacity duration-500 hover:opacity-80" href={page.url.prev}>
            &larr; {prevLabel}
          </a>
        ) : (
          <span class="cursor-default opacity-15" aria-disabled="true">
            &larr; {prevLabel}
          </span>
        )}
        <span class="font-serif text-[13px] italic opacity-25" aria-current="page">{page.currentPage} / {page.lastPage}</span>
        {page.url.next ? (
          <a class="no-underline text-accent opacity-40 transition-opacity duration-500 hover:opacity-80" href={page.url.next}>
            {nextLabel} &rarr;
          </a>
        ) : (
          <span class="cursor-default opacity-15" aria-disabled="true">
            {nextLabel} &rarr;
          </span>
        )}
      </div>
    </nav>
  )
}
