---
import logo from '../assets/logo.svg'
import { Image } from 'astro:assets'

export interface Props {
  frontmatter: Partial<{
    gradient: boolean
    background: boolean
    logo: boolean
  }>
}

const { gradient, background, logo: showLogo } = Astro.props.frontmatter
---

<div class="w-fit">
  <h1
    class:list={[
      'relative mb-1 w-fit pb-2 font-display text-4xl font-bold tracking-tighter-brand text-accent sm:mb-2 sm:text-7xl',
      {
        'gradient-text': gradient
      },
      {
        'mb-2 sm:mb-8': background
      }
    ]}
  >
    <div class="flex items-center gap-4 sm:gap-8">
      {
        showLogo && (
          <Image
            loading="eager"
            alt="Nordlys logo"
            src={logo}
            class="h-[48px] max-w-fit object-scale-down sm:h-24"
          />
        )
      }
      <div>
        <slot />
      </div>
    </div>
    {
      background && (
        <span
          class:list={[
            'pointer-events-none absolute inset-0 h-full w-full opacity-[0.04] blur-3xl',
            { 'ml-12 sm:ml-20': showLogo }
          ]}
          style="background: var(--gradient-brand);"
        />
      )
    }
  </h1>
</div>
