---
export interface QuizQuestion {
  question: string
  options: string[]
  correct: number  // 0-indexed
  explanation: string
}

export interface Props {
  questions: QuizQuestion[]
  title?: string
  lang?: 'es' | 'en'
}

const { questions, title, lang = 'es' } = Astro.props

const labels = lang === 'en'
  ? { title: 'Quiz', check: 'Check answer', next: 'Next', seeResult: 'See result', retry: 'Retry', result: 'Result', of: 'of', correct: 'correct', perfect: 'Perfect score!', great: 'Great job!', good: 'Good, review the missed ones.', tryAgain: 'Review the lesson and try again.' }
  : { title: 'Quiz', check: 'Verificar', next: 'Siguiente', seeResult: 'Ver resultado', retry: 'Reintentar', result: 'Resultado', of: 'de', correct: 'correctas', perfect: '¡Puntuación perfecta!', great: '¡Muy bien!', good: 'Bien, repasa las que fallaste.', tryAgain: 'Repasa la lección e inténtalo de nuevo.' }

// Deterministic ID based on first question content (1.8)
const quizId = `quiz-${questions.length > 0 ? questions[0].question.slice(0, 20).replace(/\W/g, '-').toLowerCase() : 'empty'}`
---

<div class="quiz" id={quizId} data-quiz data-questions={JSON.stringify(questions)} data-lang={lang} role="region" aria-label={title || labels.title}>
  <div class="quiz-header">
    <span class="quiz-icon" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
        <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0ZM8.94 6.94a.75.75 0 1 1-1.061-1.061 3.75 3.75 0 1 1 0 5.304.75.75 0 0 1 1.06-1.06 2.25 2.25 0 1 0 0-3.183Zm2.12 2.12a.75.75 0 0 1 0 1.061l-.53.53.53.53a.75.75 0 1 1-1.06 1.06l-.53-.53-.53.53a.75.75 0 0 1-1.061-1.06l.53-.53-.53-.53a.75.75 0 0 1 1.06-1.061l.53.53.53-.53a.75.75 0 0 1 1.061 0Z" clip-rule="evenodd"/>
      </svg>
    </span>
    <span class="quiz-title">{title || labels.title}</span>
    <span class="quiz-progress" data-quiz-progress aria-live="polite">1/{questions.length}</span>
  </div>

  <!-- Question area -->
  <div class="quiz-body" data-quiz-body>
    <p class="quiz-question" data-quiz-question></p>
    <div class="quiz-options" data-quiz-options role="radiogroup"></div>
    <div class="quiz-explanation hidden" data-quiz-explanation aria-live="polite" role="status"></div>
  </div>

  <!-- Actions -->
  <div class="quiz-actions">
    <button class="quiz-btn quiz-btn-check" data-quiz-check disabled>{labels.check}</button>
    <button class="quiz-btn quiz-btn-next hidden" data-quiz-next>{labels.next}</button>
  </div>

  <!-- Result screen -->
  <div class="quiz-result hidden" data-quiz-result aria-live="assertive">
    <div class="quiz-result-circle" data-quiz-circle>
      <span class="quiz-result-score" data-quiz-score></span>
    </div>
    <p class="quiz-result-text" data-quiz-result-text></p>
    <button class="quiz-btn quiz-btn-retry" data-quiz-retry>{labels.retry}</button>
  </div>
</div>

<style>
  .quiz {
    margin: 2.5rem 0;
    border: 1px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-radius: 14px;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }

  .quiz-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  .quiz-icon {
    color: var(--color-accent);
    display: flex;
    opacity: 0.6;
  }
  .quiz-title {
    font-size: 0.8125rem;
    font-weight: 600;
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .quiz-progress {
    margin-left: auto;
    font-size: 0.75rem;
    font-weight: 500;
    opacity: 0.3;
    font-variant-numeric: tabular-nums;
  }

  .quiz-body {
    padding: 1.5rem 1.25rem 1rem;
  }
  .quiz-question {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    margin-bottom: 1.25rem;
    opacity: 0.85;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .quiz :global(.quiz-option) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.125rem;
    border: 1.5px solid color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-radius: 10px;
    background: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.875rem;
    line-height: 1.5;
    color: inherit;
    text-align: left;
    width: 100%;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s, opacity 0.2s;
    opacity: 0.65;
  }
  .quiz :global(.quiz-option:hover:not(.quiz-option--locked)) {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
    opacity: 0.85;
  }
  .quiz :global(.quiz-option--selected) {
    border-color: var(--color-accent) !important;
    background: color-mix(in srgb, var(--color-accent) 14%, transparent) !important;
    opacity: 1 !important;
    box-shadow: 0 0 0 2px var(--color-accent);
  }
  .quiz :global(.quiz-option--dimmed) {
    opacity: 0.4;
  }
  .quiz :global(.quiz-option--correct) {
    border-color: #22c55e !important;
    background: color-mix(in srgb, #22c55e 6%, transparent) !important;
    opacity: 1 !important;
  }
  .quiz :global(.quiz-option--wrong) {
    border-color: #ef4444 !important;
    background: color-mix(in srgb, #ef4444 5%, transparent) !important;
    opacity: 0.6 !important;
  }
  .quiz :global(.quiz-option--locked) {
    cursor: default;
  }

  .quiz :global(.quiz-option-letter) {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 600;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    opacity: 0.6;
    transition: background 0.15s, color 0.15s;
  }
  .quiz :global(.quiz-option-text) {
    flex: 1;
  }
  .quiz :global(.quiz-option--selected .quiz-option-letter) {
    background: var(--color-accent);
    color: white;
    opacity: 1;
  }
  .quiz :global(.quiz-option--correct .quiz-option-letter) {
    background: #22c55e;
    color: white;
    opacity: 1;
  }
  .quiz :global(.quiz-option--wrong .quiz-option-letter) {
    background: #ef4444;
    color: white;
    opacity: 1;
  }

  .quiz-explanation {
    margin-top: 1rem;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    font-size: 0.8125rem;
    line-height: 1.6;
    animation: quiz-fade-in 0.3s ease-out;
  }
  .quiz :global(.quiz-explanation--correct) {
    background: color-mix(in srgb, #22c55e 8%, transparent);
    border-left: 3px solid #22c55e;
    opacity: 0.8;
  }
  .quiz :global(.quiz-explanation--wrong) {
    background: color-mix(in srgb, #ef4444 7%, transparent);
    border-left: 3px solid #ef4444;
    opacity: 0.8;
  }
  @keyframes quiz-fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 0.8; transform: translateY(0); }
  }

  .quiz-actions {
    padding: 0 1.25rem 1.25rem;
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .quiz-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    border: none;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, opacity 0.15s;
  }
  .quiz-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .quiz-btn-check {
    background: var(--color-accent);
    color: white;
  }
  .quiz-btn-check:hover:not(:disabled) {
    opacity: 0.85;
  }
  .quiz-btn-next {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
  }
  .quiz-btn-next:hover {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
  }
  .quiz-btn-retry {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    margin-top: 0.5rem;
  }
  .quiz-btn-retry:hover {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
  }

  /* Result */
  .quiz-result {
    padding: 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    animation: quiz-fade-in 0.4s ease-out;
  }
  .quiz-result-circle {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .quiz-result-circle[data-grade="perfect"] {
    background: color-mix(in srgb, #22c55e 12%, transparent);
    color: #22c55e;
  }
  .quiz-result-circle[data-grade="great"] {
    background: color-mix(in srgb, #3b82f6 12%, transparent);
    color: #3b82f6;
  }
  .quiz-result-circle[data-grade="good"] {
    background: color-mix(in srgb, #f59e0b 12%, transparent);
    color: #f59e0b;
  }
  .quiz-result-circle[data-grade="retry"] {
    background: color-mix(in srgb, #ef4444 10%, transparent);
    color: #ef4444;
  }
  .quiz-result-text {
    font-size: 0.875rem;
    opacity: 0.5;
    text-align: center;
  }

  .hidden { display: none !important; }
</style>

<script>
  function initQuizzes() {
    document.querySelectorAll('[data-quiz]').forEach(el => {
      const quiz = el as HTMLElement
      if (quiz.dataset.initialized === 'true') return
      quiz.dataset.initialized = 'true'

      const questions = JSON.parse(quiz.dataset.questions || '[]')
      const lang = quiz.dataset.lang || 'es'
      const labels = lang === 'en'
        ? { of: 'of', correct: 'correct', perfect: 'Perfect score!', great: 'Great job!', good: 'Good, review the missed ones.', tryAgain: 'Review the lesson and try again.', correctAnswer: 'Correct!', wrongAnswer: 'Incorrect.', seeResult: 'See result' }
        : { of: 'de', correct: 'correctas', perfect: '¡Puntuación perfecta!', great: '¡Muy bien!', good: 'Bien, repasa las que fallaste.', tryAgain: 'Repasa la lección e inténtalo de nuevo.', correctAnswer: '¡Correcto!', wrongAnswer: 'Incorrecto.', seeResult: 'Ver resultado' }

      let current = 0
      let selected = -1
      let score = 0
      let answered = false

      const progressEl = quiz.querySelector('[data-quiz-progress]') as HTMLElement
      const questionEl = quiz.querySelector('[data-quiz-question]') as HTMLElement
      const optionsEl = quiz.querySelector('[data-quiz-options]') as HTMLElement
      const explanationEl = quiz.querySelector('[data-quiz-explanation]') as HTMLElement
      const checkBtn = quiz.querySelector('[data-quiz-check]') as HTMLButtonElement
      const nextBtn = quiz.querySelector('[data-quiz-next]') as HTMLElement
      const bodyEl = quiz.querySelector('[data-quiz-body]') as HTMLElement
      const resultEl = quiz.querySelector('[data-quiz-result]') as HTMLElement
      const scoreEl = quiz.querySelector('[data-quiz-score]') as HTMLElement
      const circleEl = quiz.querySelector('[data-quiz-circle]') as HTMLElement
      const resultTextEl = quiz.querySelector('[data-quiz-result-text]') as HTMLElement
      const retryBtn = quiz.querySelector('[data-quiz-retry]') as HTMLElement

      const letters = ['A', 'B', 'C', 'D', 'E', 'F']

      function render() {
        const q = questions[current]
        progressEl.textContent = `${current + 1}/${questions.length}`
        questionEl.textContent = q.question
        explanationEl.classList.add('hidden')
        explanationEl.classList.remove('quiz-explanation--correct', 'quiz-explanation--wrong')
        checkBtn.classList.remove('hidden')
        checkBtn.disabled = true
        nextBtn.classList.add('hidden')
        selected = -1
        answered = false

        optionsEl.innerHTML = ''
        optionsEl.setAttribute('aria-label', q.question)
        q.options.forEach((opt: string, i: number) => {
          const btn = document.createElement('button')
          btn.className = 'quiz-option'
          btn.type = 'button'
          btn.setAttribute('role', 'radio')
          btn.setAttribute('aria-checked', 'false')
          btn.setAttribute('aria-label', `${letters[i]}: ${opt}`)
          btn.innerHTML = `<span class="quiz-option-letter">${letters[i]}</span><span class="quiz-option-text">${opt}</span>`
          btn.addEventListener('click', () => {
            if (answered) return
            selected = i
            optionsEl.querySelectorAll('.quiz-option').forEach((b, j) => {
              b.classList.toggle('quiz-option--selected', j === i)
              b.classList.toggle('quiz-option--dimmed', j !== i)
              b.setAttribute('aria-checked', String(j === i))
            })
            checkBtn.disabled = false
          })
          optionsEl.appendChild(btn)
        })
      }

      checkBtn.addEventListener('click', () => {
        if (selected < 0 || answered) return
        answered = true
        const q = questions[current]
        const isCorrect = selected === q.correct

        if (isCorrect) score++

        optionsEl.querySelectorAll('.quiz-option').forEach((btn, i) => {
          btn.classList.add('quiz-option--locked')
          btn.classList.remove('quiz-option--selected', 'quiz-option--dimmed')
          if (i === q.correct) btn.classList.add('quiz-option--correct')
          else if (i === selected && !isCorrect) btn.classList.add('quiz-option--wrong')
        })

        explanationEl.classList.remove('quiz-explanation--correct', 'quiz-explanation--wrong')
        explanationEl.classList.add(isCorrect ? 'quiz-explanation--correct' : 'quiz-explanation--wrong')
        explanationEl.innerHTML = `<strong>${isCorrect ? labels.correctAnswer : labels.wrongAnswer}</strong> ${q.explanation}`
        explanationEl.classList.remove('hidden')
        checkBtn.classList.add('hidden')

        nextBtn.classList.remove('hidden')
        if (current >= questions.length - 1) {
          nextBtn.textContent = labels.seeResult
        }
      })

      nextBtn.addEventListener('click', () => {
        if (current >= questions.length - 1) {
          showResult()
        } else {
          current++
          nextBtn.textContent = lang === 'en' ? 'Next' : 'Siguiente'
          render()
        }
      })

      function showResult() {
        bodyEl.classList.add('hidden')
        quiz.querySelector('.quiz-actions')?.classList.add('hidden')
        resultEl.classList.remove('hidden')

        const pct = score / questions.length
        scoreEl.textContent = `${score}/${questions.length}`

        let grade = 'retry'
        let text = labels.tryAgain
        if (pct === 1) { grade = 'perfect'; text = labels.perfect }
        else if (pct >= 0.75) { grade = 'great'; text = labels.great }
        else if (pct >= 0.5) { grade = 'good'; text = labels.good }

        circleEl.dataset.grade = grade
        resultTextEl.textContent = text
      }

      retryBtn.addEventListener('click', () => {
        current = 0
        score = 0
        resultEl.classList.add('hidden')
        bodyEl.classList.remove('hidden')
        quiz.querySelector('.quiz-actions')?.classList.remove('hidden')
        render()
      })

      render()
    })
  }

  initQuizzes()
  document.addEventListener('astro:after-swap', initQuizzes)
</script>
