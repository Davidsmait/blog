---
import FooterItem from '@/components/layout/FooterItem.astro'
import ModeToggle from '@/components/mode/ModeToggle.astro'
import config from '@/theme.config'

const currentYear = new Date().getFullYear()
---

<footer class="relative mt-auto pb-10 pt-6 sm:pb-14 sm:pt-8">
  <div class="h-[1px] w-full bg-accent/[0.04]"></div>

  <div class="pt-8 sm:pt-10">
    <!-- Signature -->
    <div class="mb-6 sm:mb-8">
      <span class="font-serif text-[clamp(1.5rem,4vw,2.5rem)] italic leading-[1] tracking-tight text-accent opacity-15">
        {config.author}
      </span>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-6">
        <span class="text-[10px] font-medium uppercase tracking-[0.2em] opacity-12 sm:text-[11px]">
          Desarrollo &amp; Café de especialidad
        </span>
        <span class="hidden h-3 w-[1px] bg-accent/6 sm:block"></span>
        <span class="text-[10px] font-medium uppercase tracking-[0.2em] opacity-12 sm:text-[11px]">
          México
        </span>
        <span class="hidden h-3 w-[1px] bg-accent/6 sm:block"></span>
        <span class="font-serif text-[10px] italic opacity-10">&copy; {currentYear}</span>
      </div>

      <div class="flex items-center gap-5 text-lg">
        {config.footerItems.map((item) => <FooterItem {item} />)}
      </div>
    </div>
  </div>
</footer>
