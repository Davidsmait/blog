---
import type { NavItem } from '@/types'

export interface Props {
  item: NavItem
  isActive: boolean
}

const {
  isActive,
  item: { href, icon, label }
} = Astro.props
---

<a
  href={href}
  class:list={[
    'flex items-center gap-1.5 rounded-lg px-2 py-1 transition-all duration-300',
    isActive
      ? 'bg-accent/10 text-accent'
      : 'clickable hover:bg-accent/5'
  ]}
  target={!href.startsWith('/') ? '_blank' : '_self'}
>
  {icon && <span class={`iconify text-lg ${icon}`} />}
  <span class:list={[{ 'font-medium': isActive }]}>
    {label}
  </span>
</a>
