---
import type { NavItem } from '@/types'

export interface Props {
  item: NavItem
  isActive: boolean
}

const {
  isActive,
  item: { href, label }
} = Astro.props
---

<a
  href={href}
  class:list={[
    'relative px-3 py-1.5 text-[13px] tracking-tight-brand no-underline transition-all duration-500',
    isActive
      ? 'text-accent font-medium opacity-100'
      : 'text-accent opacity-35 hover:opacity-70'
  ]}
  style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
  target={!href.startsWith('/') ? '_blank' : '_self'}
>
  {label}
  {isActive && (
    <span class="absolute bottom-0 left-3 right-3 h-[1px] bg-accent/30"></span>
  )}
</a>
